---
import '../styles/global.css';
import { Font } from 'astro:assets';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { languages } from '../i18n/translations';
import type { Lang } from '../i18n/translations';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  hasHero?: boolean;
}

const {
  title,
  description = 'MKT Makina Kalıp Takım — Havacılık ve otomotiv sanayii için hassas işleme ve plastik enjeksiyon çözümleri.',
  lang = 'tr',
  hasHero = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Route slug maps: TR path segment → localized segment
const trToLocalized: Record<string, string> = {
  'kurumsal': 'about',
  'urunler': 'products',
  'belgeler': 'certificates',
  'makina-parkimiz': 'machines',
  'referanslar': 'references',
  'iletisim': 'contact',
  'haberler': 'news',
  'insan-kaynaklari': 'careers',
};
const localizedToTr: Record<string, string> = Object.fromEntries(
  Object.entries(trToLocalized).map(([tr, loc]) => [loc, tr])
);

const ogLocaleMap: Record<Lang, string> = {
  tr: 'tr_TR',
  en: 'en_US',
  de: 'de_DE',
  ar: 'ar_SA',
};

function getPathForLang(targetLang: Lang): string {
  const currentPath = Astro.url.pathname;
  const langPrefixes = ['en', 'de', 'ar'] as const;
  let sourceLang: Lang = 'tr';
  let rest = currentPath;

  for (const prefix of langPrefixes) {
    if (currentPath === `/${prefix}` || currentPath.startsWith(`/${prefix}/`)) {
      sourceLang = prefix;
      rest = currentPath.slice(prefix.length + 1) || '/';
      break;
    }
  }

  // Normalize rest to TR slug form
  let trPath: string;
  if (rest === '/') {
    trPath = '/';
  } else {
    const parts = rest.replace(/^\//, '').split('/');
    const firstSegment = sourceLang === 'tr' ? parts[0] : (localizedToTr[parts[0]] ?? parts[0]);
    trPath = '/' + [firstSegment, ...parts.slice(1)].join('/');
  }

  if (targetLang === 'tr') return trPath;
  if (trPath === '/') return `/${targetLang}`;

  const parts = trPath.replace(/^\//, '').split('/');
  const localizedSegment = trToLocalized[parts[0]] ?? parts[0];
  return `/${targetLang}/` + [localizedSegment, ...parts.slice(1)].join('/');
}

const hreflangLinks = (Object.keys(languages) as Lang[]).map((l) => ({
  lang: l,
  href: new URL(getPathForLang(l), Astro.site).toString(),
}));
const trHref = new URL(getPathForLang('tr'), Astro.site).toString();
---

<!doctype html>
<html lang={lang} dir={lang === 'ar' ? 'rtl' : 'ltr'} class="scroll-smooth js-ready">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonicalURL} />
    {hreflangLinks.map(({ lang: l, href }) => (
      <link rel="alternate" hreflang={l} href={href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={trHref} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="MKT Makina Kalıp Takım" />
    <meta property="og:locale" content={ogLocaleMap[lang]} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <Font cssVariable="--font-sans" />
    <Font cssVariable="--font-heading" />
    <Font cssVariable="--font-mono" />
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <Header lang={lang} hasHero={hasHero} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />

    <button class="scroll-to-top" id="scrollToTop" aria-label="Scroll to top">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
      </svg>
    </button>

    <script is:inline>
      document.documentElement.classList.add('js-ready');
    </script>

    <script>
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            const el = entry.target as HTMLElement;

            if (el.hasAttribute('data-animate')) {
              el.classList.add('is-visible');
            }

            if (el.hasAttribute('data-counter')) {
              const target = parseInt(el.dataset.target || '0', 10);
              const suffix = el.dataset.suffix || '';
              const dur = 1500;
              const t0 = performance.now();
              const tick = (now: number) => {
                const p = Math.min((now - t0) / dur, 1);
                el.textContent = Math.floor((1 - (1 - p) ** 3) * target) + suffix;
                if (p < 1) requestAnimationFrame(tick);
              };
              requestAnimationFrame(tick);
            }

            io.unobserve(el);
          }
        },
        { threshold: 0.1, rootMargin: '0px 0px -20px 0px' }
      );
      document.querySelectorAll('[data-animate],[data-counter]').forEach((el) => io.observe(el));

      // Parallax
      const parallaxEls = document.querySelectorAll<HTMLElement>('.parallax-bg');
      const sttBtn = document.getElementById('scrollToTop');
      let ticking = false;

      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          const sy = window.scrollY;
          for (const el of parallaxEls) {
            const rect = el.parentElement!.getBoundingClientRect();
            if (rect.bottom > 0 && rect.top < window.innerHeight) {
              const offset = (rect.top / window.innerHeight) * 40;
              el.style.transform = `translateY(${offset}px)`;
            }
          }
          sttBtn?.classList.toggle('is-visible', sy > 500);
          ticking = false;
        });
      };
      window.addEventListener('scroll', onScroll, { passive: true });

      sttBtn?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.querySelectorAll('[data-animate]').forEach((el) => {
          el.classList.add('is-visible');
          io.unobserve(el);
        });
      }
    </script>
  </body>
</html>
