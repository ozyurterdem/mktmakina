---
import '../styles/global.css';
import { Font } from 'astro:assets';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n/translations';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
}

const { title, description = 'MKT Makina Kalıp Takım — Havacılık ve otomotiv sanayii için hassas işleme ve plastik enjeksiyon çözümleri.', lang = 'tr' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const alternateLang = lang === 'tr' ? 'en' : 'tr';
const alternatePath = lang === 'tr' ? `/en${Astro.url.pathname}` : Astro.url.pathname.replace(/^\/en/, '') || '/';
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang={lang} href={canonicalURL} />
    <link rel="alternate" hreflang={alternateLang} href={new URL(alternatePath, Astro.site)} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="MKT Makina Kalıp Takım" />
    <meta property="og:locale" content={lang === 'tr' ? 'tr_TR' : 'en_US'} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <Font cssVariable="--font-sans" />
    <Font cssVariable="--font-heading" />
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <Header lang={lang} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />

    <!-- Scroll-to-Top Button (Volo style) -->
    <button class="scroll-to-top" id="scrollToTop" aria-label="Scroll to top">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
      </svg>
    </button>

    <!-- Waypoint Animation Observer + Performance-optimized scroll -->
    <script>
      // Single IntersectionObserver for all [data-animate] and [data-counter]
      const io = new IntersectionObserver(
        (entries) => {
          for (let i = 0; i < entries.length; i++) {
            if (!entries[i].isIntersecting) continue;
            const el = entries[i].target as HTMLElement;

            if (el.hasAttribute('data-animate')) {
              el.classList.add('is-visible');
            }

            if (el.hasAttribute('data-counter')) {
              const target = parseInt(el.dataset.target || '0', 10);
              const suffix = el.dataset.suffix || '';
              const dur = 1500;
              const t0 = performance.now();
              const tick = (now: number) => {
                const p = Math.min((now - t0) / dur, 1);
                el.textContent = Math.floor((1 - (1 - p) ** 3) * target) + suffix;
                if (p < 1) requestAnimationFrame(tick);
              };
              requestAnimationFrame(tick);
            }

            io.unobserve(el);
          }
        },
        { threshold: 0.1, rootMargin: '0px 0px -20px 0px' }
      );
      document.querySelectorAll('[data-animate],[data-counter]').forEach((el) => io.observe(el));

      // Parallax backgrounds — rAF-throttled scroll
      const parallaxEls = document.querySelectorAll<HTMLElement>('.parallax-bg');
      const sttBtn = document.getElementById('scrollToTop');
      let ticking = false;

      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          const sy = window.scrollY;
          // Parallax backgrounds
          for (let i = 0; i < parallaxEls.length; i++) {
            const rect = parallaxEls[i].parentElement!.getBoundingClientRect();
            if (rect.bottom > 0 && rect.top < window.innerHeight) {
              const offset = (rect.top / window.innerHeight) * 40;
              parallaxEls[i].style.transform = `translate3d(0,${offset}px,0)`;
            }
          }
          // Scroll-to-top
          sttBtn?.classList.toggle('is-visible', sy > 500);
          ticking = false;
        });
      };
      window.addEventListener('scroll', onScroll, { passive: true });

      sttBtn?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      // Reduce motion preference
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.querySelectorAll('[data-animate]').forEach((el) => {
          el.classList.add('is-visible');
          io.unobserve(el);
        });
      }
    </script>
  </body>
</html>
