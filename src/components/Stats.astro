---
import { t, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const stats = [
  { value: '2007', label: lang === 'tr' ? 'Yılından Beri' : 'Since', suffix: '' },
  { value: 'AS9100', label: lang === 'tr' ? 'Sertifikalı' : 'Certified', suffix: '' },
  { value: '20', label: lang === 'tr' ? 'Tezgah' : 'Machines', suffix: '+' },
  { value: '5', label: lang === 'tr' ? 'Eksen CNC' : 'Axis CNC', suffix: '' },
  { value: '9', label: lang === 'tr' ? 'Referans' : 'References', suffix: '+' },
];
---

<section class="relative bg-navy-900 py-0 overflow-hidden">
  <!-- Subtle diagonal stripe -->
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: repeating-linear-gradient(45deg, transparent, transparent 40px, white 40px, white 41px);"></div>

  <div class="max-w-[1400px] mx-auto px-6">
    <div class="flex flex-wrap justify-center lg:justify-between items-center gap-6 lg:gap-0 py-10 lg:py-12">
      {stats.map((stat, i) => (
        <div class={`reveal delay-${i + 1} flex items-center gap-3 lg:gap-4 px-6 lg:px-8 ${i < stats.length - 1 ? 'lg:border-r lg:border-white/10' : ''}`}>
          <span class="font-heading text-2xl sm:text-3xl lg:text-4xl font-bold text-accent-500 tracking-tight">{stat.value}{stat.suffix}</span>
          <span class="text-white/50 text-xs sm:text-sm uppercase tracking-wider font-medium">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
