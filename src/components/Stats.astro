---
import { type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const brands = ['DMG MORI', 'HAAS', 'GF Machining', 'FANUC', 'LS Mtron', 'TCI', 'Toyota Boshoku', 'Mikrosan', 'Elimsan'];
---

<section class="relative bg-primary border-y border-white/[0.04] overflow-hidden">
  <div class="py-4">
    <div class="ticker-track">
      {[...brands, ...brands, ...brands].map((brand) => (
        <span class="text-white/20 text-sm font-mono uppercase tracking-[0.2em] whitespace-nowrap px-8 hover:text-accent/60 transition-colors duration-300">
          {brand}
        </span>
      ))}
    </div>
  </div>
</section>
