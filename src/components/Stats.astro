---
import { type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const brands = ['DMG MORI', 'HAAS', 'GF Machining', 'FANUC', 'LS Mtron', 'Toyota Boshoku', 'TSI Aviation', 'Mikrosan', 'Elimsan'];
---

<!-- Light brand ticker — clean separator between hero and about -->
<section class="border-y border-border bg-surface overflow-hidden">
  <div class="py-5">
    <div class="ticker-track">
      {[...brands, ...brands, ...brands].map((brand) => (
        <span class="ticker-item text-text-muted text-sm font-mono uppercase tracking-[0.15em] whitespace-nowrap px-8 hover:text-accent transition-colors">
          {brand}
        </span>
      ))}
    </div>
  </div>
</section>
