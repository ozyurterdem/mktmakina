---
import { t, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const galleryLabel = ({tr:'Galeri', en:'Gallery', de:'Galerie', ar:'معرض'} as Record<string,string>)[lang];

const items = [
  { image: '/images/categories/aparatlar_7.jpg', title: ({tr:'Aparatlar', en:'Apparatus', de:'Vorrichtungen', ar:'أجهزة'} as Record<string,string>)[lang] ?? 'Apparatus', span: false },
  { image: '/images/categories/fikstur_8.jpg', title: ({tr:'Fikstür', en:'Fixtures', de:'Spannvorrichtungen', ar:'تركيبات'} as Record<string,string>)[lang] ?? 'Fixtures', span: true },
  { image: '/images/categories/kaliplar_12.jpg', title: ({tr:'Kalıplar', en:'Molds', de:'Formen', ar:'قوالب'} as Record<string,string>)[lang] ?? 'Molds', span: false },
  { image: '/images/slide2.jpg', title: ({tr:'CNC İşleme', en:'CNC Machining', de:'CNC-Bearbeitung', ar:'التصنيع باستخدام الحاسب'} as Record<string,string>)[lang] ?? 'CNC Machining', span: true },
  { image: '/images/categories/parcalar_13.jpg', title: ({tr:'Parçalar', en:'Parts', de:'Teile', ar:'قطع'} as Record<string,string>)[lang] ?? 'Parts', span: false },
  { image: '/images/categories/mastarlar_14.jpg', title: ({tr:'Mastarlar', en:'Gauges', de:'Lehren', ar:'مقاييس'} as Record<string,string>)[lang] ?? 'Gauges', span: false },
];
---

<section class="section-padding bg-steel-50" id="gallery">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-14" data-animate="fade-up">
      <div class="section-label justify-center">{galleryLabel}</div>
      <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-navy-800 mb-4">
        {t(lang, 'gallery.title')}
      </h2>
      <p class="text-steel-500 text-base leading-relaxed">
        {t(lang, 'gallery.subtitle')}
      </p>
    </div>

    <!-- Masonry Grid -->
    <div class="gallery-grid">
      {items.map((item, i) => (
        <div
          class:list={['gallery-item', item.span && 'span-2']}
          data-animate="zoom-in"
          data-delay={String(((i % 3) + 1) * 100)}
        >
          <img src={item.image} alt={item.title} loading="lazy" />
          <div class="gallery-overlay">
            <span class="text-white font-heading text-sm sm:text-base lg:text-lg font-bold uppercase tracking-wider drop-shadow-lg">
              {item.title}
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
