---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const featured = [
  { name: 'DMU 85', type: '5 Eksen CNC', brand: 'DMG MORI' },
  { name: 'DMU 75', type: '5 Eksen CNC', brand: 'DMG MORI' },
  { name: 'HAAS UMC VF3', type: '5 Eksen CNC', brand: 'HAAS' },
  { name: 'HAAS UMC 750', type: '5 Eksen CNC', brand: 'HAAS' },
  { name: 'DMC 1035 V', type: '3 Eksen CNC', brand: 'DMG MORI' },
  { name: 'CUT 30P', type: 'Tel Erozyon', brand: 'GF Machining' },
  { name: 'LS LST 280', type: 'Plastik Enjeksiyon', brand: 'LS' },
  { name: 'Laser Markalama', type: 'Markalama', brand: 'MKT' },
];
---

<section class="relative py-28 lg:py-36 overflow-hidden" id="machines">
  <!-- Dark premium background -->
  <div class="absolute inset-0 bg-navy-950"></div>
  <!-- Subtle pattern -->
  <div class="absolute inset-0" style="background-image: radial-gradient(rgba(232, 135, 14, 0.04) 1px, transparent 1px); background-size: 40px 40px;"></div>
  <!-- Gradient accents -->
  <div class="absolute top-0 left-0 w-96 h-96 bg-accent-500/5 rounded-full blur-[120px]"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-navy-600/10 rounded-full blur-[120px]"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-16">
      <div class="reveal">
        <span class="inline-block text-accent-500 text-sm font-semibold uppercase tracking-[0.2em] mb-3">{lang === 'tr' ? 'Üretim Altyapısı' : 'Production Infrastructure'}</span>
        <h2 class="font-heading text-4xl sm:text-5xl font-bold text-white mb-4">
          {t(lang, 'machines.title')}
        </h2>
        <div class="accent-bar"></div>
      </div>

      <!-- Summary stats -->
      <div class="flex gap-8 reveal">
        {[
          { val: '4', label: '5-Axis' },
          { val: '3', label: '3-Axis' },
          { val: '3', label: 'EDM' },
          { val: '20+', label: 'Total' },
        ].map((s) => (
          <div class="text-center">
            <div class="font-heading text-2xl sm:text-3xl font-bold text-accent-500">{s.val}</div>
            <div class="text-steel-500 text-xs uppercase tracking-wider mt-0.5">{s.label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Machine Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
      {featured.map((machine, i) => (
        <div class={`reveal delay-${(i % 4) + 1} group relative p-6 rounded-2xl glass hover:bg-white/[0.06] transition-all duration-500`}>
          <!-- Top accent line -->
          <div class="absolute top-0 left-6 right-6 h-px bg-gradient-to-r from-transparent via-accent-500/0 group-hover:via-accent-500/40 to-transparent transition-all duration-500"></div>
          
          <div class="text-accent-500/60 text-xs font-medium uppercase tracking-wider mb-3">{machine.brand}</div>
          <h3 class="font-heading text-base sm:text-lg font-semibold text-white mb-1.5 tracking-wide group-hover:text-accent-400 transition-colors">{machine.name}</h3>
          <p class="text-steel-500 text-sm">{machine.type}</p>

          <!-- Corner decoration -->
          <div class="absolute bottom-4 right-4 w-6 h-6 border-b border-r border-accent-500/0 group-hover:border-accent-500/30 rounded-br-lg transition-all duration-500"></div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-14 reveal">
      <a
        href={getLocalePath(lang, '/makina-parkimiz')}
        class="group inline-flex items-center gap-3 px-7 py-3.5 border border-accent-500/50 text-accent-400 font-semibold uppercase tracking-wider rounded-lg hover:bg-accent-500 hover:text-white hover:border-accent-500 transition-all text-sm"
      >
        {t(lang, 'about.more')}
        <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
