---
import { t, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;
const l = (map: Record<string, string>) => map[lang] || map['en'] || '';

const categories = [
  {
    title: ({tr:'5 Eksen CNC', en:'5-Axis CNC', de:'5-Achs-CNC', ar:'ماكينات 5 محاور'} as Record<string,string>)[lang],
    count: 4,
    machines: ['DMU 85 monoBLOCK', 'DMU 75 monoBLOCK', 'HAAS UMC VF3', 'HAAS UMC 750'],
    brand: 'DMG MORI / HAAS',
  },
  {
    title: ({tr:'3 Eksen CNC', en:'3-Axis CNC', de:'3-Achs-CNC', ar:'ماكينات 3 محاور'} as Record<string,string>)[lang],
    count: 3,
    machines: ['DMC 1035 V', 'DMC 635 V', 'HAAS VF2'],
    brand: 'DMG MORI / HAAS',
  },
  {
    title: ({tr:'Yatay CNC İşleme Merkezleri', en:'Horizontal CNC Machining Centers', de:'Horizontale CNC-Bearbeitungszentren', ar:'مراكز التشغيل الأفقية CNC'} as Record<string,string>)[lang],
    count: 3,
    machines: ['NHC 5000 (1)', 'NHC 5000 (2)', 'NHC 5000 (3)'],
    brand: 'Horizontal Machining',
  },
  {
    title: ({tr:'Tel Erozyon', en:'Wire EDM', de:'Drahterodieren', ar:'التآكل السلكي'} as Record<string,string>)[lang],
    count: 3,
    machines: ['CUT 30P', 'CUT 20P', 'FANUC a-C400iA'],
    brand: 'GF / FANUC',
  },
  {
    title: ({tr:'Plastik Enjeksiyon', en:'Plastic Injection', de:'Kunststoffspritzguss', ar:'حقن البلاستيك'} as Record<string,string>)[lang],
    count: 2,
    machines: ['LS LST 280', 'LS LST 150'],
    brand: 'LS Mtron',
  },
];
---

<section class="relative section-padding noise-overlay" id="machines">
  <div class="absolute inset-0 bg-gradient-to-b from-primary via-primary-dark to-primary"></div>

  <div class="relative z-10 container-custom">
    <div class="max-w-2xl mb-14" data-animate="fade-up">
      <div class="section-label">{l({tr:'Üretim Altyapısı', en:'Production Infrastructure', de:'Produktionsinfrastruktur', ar:'البنية التحتية للإنتاج'})}</div>
      <h2 class="text-3xl sm:text-4xl lg:text-[2.75rem] font-heading font-bold text-white mb-4">
        {t(lang, 'machines.title')}
      </h2>
      <p class="text-text-light text-base leading-relaxed">
        {l({tr:'İleri teknoloji tezgahlarımız ile mikron seviyesinde hassasiyet.', en:'Micron-level precision with our advanced technology machines.', de:'Mikrogenaue Präzision mit unseren hochmodernen Maschinen.', ar:'دقة على مستوى الميكرون مع آلاتنا التكنولوجية المتقدمة.'})}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {categories.map((cat, i) => (
        <div
          class="group glass-card p-6 lg:p-8"
          data-animate="fade-up"
          data-delay={String((i + 1) * 100)}
        >
          <div class="flex items-center justify-between mb-6">
            <h3 class="font-heading text-xl lg:text-2xl font-bold text-white group-hover:text-accent transition-colors">
              {cat.title}
            </h3>
            <span class="font-mono text-3xl font-bold text-white/[0.06] group-hover:text-accent/20 transition-colors">
              {String(cat.count).padStart(2, '0')}
            </span>
          </div>
          <ul class="space-y-3 mb-6">
            {cat.machines.map((m) => (
              <li class="flex items-center gap-3 text-text-light text-sm">
                <span class="w-1 h-1 bg-accent/50 shrink-0"></span>
                {m}
              </li>
            ))}
          </ul>
          <div class="text-text-muted text-[10px] font-mono uppercase tracking-[0.25em] pt-4 border-t border-white/[0.04]">
            {cat.brand}
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-12" data-animate="fade-up">
      <a
        href={l({tr:'/makina-parkimiz', en:'/en/machines', de:'/de/machines', ar:'/ar/machines'})}
        class="inline-flex items-center gap-2 text-accent/60 text-sm font-mono uppercase tracking-wider hover:text-accent hover:gap-3 transition-all"
      >
        {t(lang, 'about.more')}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>
