---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const machines = [
  { name: 'DMU 85', type: '5 Eksen CNC', category: 'cnc' },
  { name: 'DMU 75', type: '5 Eksen CNC', category: 'cnc' },
  { name: 'HAAS UMC VF3', type: '5 Eksen CNC İşleme Merkezi', category: 'cnc' },
  { name: 'HAAS UMC 750', type: '5 Eksen CNC İşleme Merkezi', category: 'cnc' },
  { name: 'DMC 1035 V', type: '3 Eksen İşleme Merkezi', category: 'cnc' },
  { name: 'DMC 835 V', type: '3 Eksen İşleme Merkezi', category: 'cnc' },
  { name: 'CUT 30P', type: 'Tel Erozyon', category: 'erozyon' },
  { name: 'CUT 20P', type: 'Tel Erozyon', category: 'erozyon' },
  { name: 'LS LST 280', type: 'Plastik Enjeksiyon', category: 'injection' },
  { name: 'Laser Markalama', type: 'Markalama Sistemi', category: 'other' },
];
---

<section class="section-padding bg-navy-900 text-white" id="machines">
  <div class="max-w-7xl mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center mb-14 reveal">
      <div class="accent-bar mx-auto mb-4"></div>
      <h2 class="font-heading text-3xl sm:text-4xl font-bold mb-3">
        {t(lang, 'machines.title')}
      </h2>
      <p class="text-steel-400 text-lg max-w-2xl mx-auto">
        {t(lang, 'machines.subtitle')}
      </p>
    </div>

    <!-- Machine Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
      {machines.map((machine) => (
        <div class="group bg-navy-800 border border-navy-700 rounded-lg p-5 hover:border-accent-500/50 hover:bg-navy-800/80 transition-all duration-300 reveal">
          <div class="w-10 h-10 bg-accent-500/10 rounded-lg flex items-center justify-center mb-4">
            {machine.category === 'cnc' ? (
              <svg class="w-5 h-5 text-accent-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            ) : (
              <svg class="w-5 h-5 text-accent-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
              </svg>
            )}
          </div>
          <h3 class="font-heading text-sm font-semibold text-white mb-1 tracking-wide">{machine.name}</h3>
          <p class="text-steel-500 text-xs">{machine.type}</p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-10 reveal">
      <a
        href={getLocalePath(lang, '/makina-parkimiz')}
        class="inline-flex items-center gap-2 px-6 py-3 border border-accent-500 text-accent-500 font-semibold uppercase tracking-wide rounded-md hover:bg-accent-500 hover:text-white transition-all text-sm"
      >
        {t(lang, 'about.more')}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
