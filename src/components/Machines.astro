---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const categories = [
  {
    title: lang === 'tr' ? '5 Eksen CNC' : '5-Axis CNC',
    count: 4,
    machines: ['DMU 85 monoBLOCK', 'DMU 75 monoBLOCK', 'HAAS UMC VF3', 'HAAS UMC 750'],
    brand: 'DMG MORI / HAAS',
  },
  {
    title: lang === 'tr' ? '3 Eksen CNC' : '3-Axis CNC',
    count: 3,
    machines: ['DMC 1035 V', 'DMC 635 V', 'HAAS VF2'],
    brand: 'DMG MORI / HAAS',
  },
  {
    title: lang === 'tr' ? 'Tel Erozyon' : 'Wire EDM',
    count: 3,
    machines: ['CUT 30P', 'CUT 20P', 'FANUC a-C400iA'],
    brand: 'GF / FANUC',
  },
  {
    title: lang === 'tr' ? 'Plastik Enjeksiyon' : 'Plastic Injection',
    count: 2,
    machines: ['LS LST 280', 'LS LST 150'],
    brand: 'LS Mtron',
  },
];
---

<!-- Light Machines section — clean white bg -->
<section class="section-padding bg-white" id="machines">
  <div class="container-custom">
    <!-- Header -->
    <div class="max-w-2xl mb-14" data-animate="fade-up">
      <div class="section-label">{lang === 'tr' ? 'Uretim Altyapisi' : 'Production Infrastructure'}</div>
      <h2 class="text-3xl sm:text-4xl lg:text-[2.75rem] font-heading font-bold text-primary mb-4">
        {t(lang, 'machines.title')}
      </h2>
      <p class="text-text-light text-base leading-relaxed">
        {lang === 'tr'
          ? 'Ileri teknoloji tezgahlarimiz ile hassas uretim kapasitemiz.'
          : 'Our precision manufacturing capacity with advanced technology machines.'}
      </p>
    </div>

    <!-- Machine Cards — light bordered -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {categories.map((cat, i) => (
        <div
          class="group p-6 lg:p-8 border border-border rounded-xl hover:border-accent/40 hover:shadow-lg transition-all duration-400 bg-white"
          data-animate="fade-up"
          data-delay={String((i + 1) * 100)}
        >
          <div class="flex items-center justify-between mb-5">
            <h3 class="font-heading text-xl lg:text-2xl font-bold text-primary group-hover:text-accent transition-colors">
              {cat.title}
            </h3>
            <span class="font-mono text-2xl font-bold text-accent/20 group-hover:text-accent transition-colors">
              {String(cat.count).padStart(2, '0')}
            </span>
          </div>
          <ul class="space-y-2.5 mb-5">
            {cat.machines.map((m) => (
              <li class="flex items-center gap-3 text-text-light text-sm">
                <span class="w-1.5 h-1.5 bg-accent/40 rounded-full shrink-0"></span>
                {m}
              </li>
            ))}
          </ul>
          <div class="text-text-muted text-[10px] uppercase tracking-[0.2em] pt-4 border-t border-border-light">
            {cat.brand}
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-12" data-animate="fade-up">
      <a
        href={getLocalePath(lang, lang === 'tr' ? '/makina-parkimiz' : '/machines')}
        class="btn-outline-dark"
      >
        {t(lang, 'about.more')}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>
