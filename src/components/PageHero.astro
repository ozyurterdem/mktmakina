---
interface Props {
  title: string;
  subtitle?: string;
  image?: string;
}

const { title, subtitle, image = '/images/slide2.jpg' } = Astro.props;
---

<section class="relative h-64 sm:h-80 flex items-end overflow-hidden" id="page-hero">
  <div class="absolute inset-0">
    <img src={image} alt={title} class="w-full h-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-navy-950/85"></div>
  </div>

  <!-- Vertical accent -->
  <div class="absolute top-0 left-[8%] w-px h-full bg-gradient-to-b from-transparent via-white/10 to-transparent hidden lg:block"></div>

  <div class="relative z-10 max-w-[1400px] mx-auto px-6 w-full pb-10 sm:pb-14">
    <div class="w-10 h-[2px] bg-accent-500 mb-4"></div>
    <h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-2 tracking-tight">{title}</h1>
    {subtitle && <p class="text-white/40 text-sm sm:text-base max-w-xl">{subtitle}</p>}
  </div>
</section>
