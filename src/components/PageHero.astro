---
interface Props {
  title: string;
  subtitle?: string;
  image?: string;
}

const { title, subtitle, image = '/images/slide2.jpg' } = Astro.props;
---

<section class="relative h-64 sm:h-72 lg:h-80 flex items-center justify-center overflow-hidden" id="page-hero">
  <div class="absolute inset-0">
    <img src={`${image}?v=20260429`} alt={title} class="w-full h-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-b from-primary-dark/80 via-primary/70 to-primary-dark/90"></div>
  </div>

  <div class="relative z-10 text-center px-6">
    <div class="w-10 h-[2px] bg-accent mx-auto mb-5" data-animate="zoom-in"></div>
    <h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-3 tracking-tight" data-animate="fade-up">{title}</h1>
    {subtitle && <p class="text-white/50 text-sm sm:text-base max-w-xl mx-auto" data-animate="fade-up" data-delay="200">{subtitle}</p>}
  </div>
</section>
