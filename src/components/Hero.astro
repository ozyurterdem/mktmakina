---
import { t, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;
---

<!-- Light, airy hero — image on right, content on left with white bg -->
<section class="relative min-h-[85vh] flex items-center bg-white overflow-hidden" id="hero">
  <!-- Right side: full-height image -->
  <div class="absolute top-0 right-0 w-full lg:w-[55%] h-full">
    <img src="/images/slide1.jpg" alt="MKT Makina" class="w-full h-full object-cover" loading="eager" />
    <!-- Soft left fade into white -->
    <div class="absolute inset-0 bg-gradient-to-r from-white via-white/80 to-transparent lg:via-white/40"></div>
  </div>

  <!-- Content — left side -->
  <div class="relative z-10 container-custom py-20 lg:py-28">
    <div class="max-w-xl">
      <!-- Overline -->
      <div data-animate="fade-up" class="flex items-center gap-3 mb-6">
        <span class="w-10 h-[2px] bg-accent"></span>
        <span class="text-accent text-xs font-mono uppercase tracking-[0.2em] font-medium">{t(lang, 'hero.slide1.subtitle')}</span>
      </div>

      <!-- Title -->
      <h1 data-animate="fade-up" data-delay="100" class="text-4xl md:text-5xl lg:text-[3.5rem] font-heading font-bold text-primary leading-[1.1] mb-6">
        {t(lang, 'hero.title')}
      </h1>

      <!-- Subtitle -->
      <p data-animate="fade-up" data-delay="200" class="text-base lg:text-lg text-text-light leading-relaxed mb-10 max-w-md">
        {t(lang, 'hero.subtitle')}
      </p>

      <!-- CTAs -->
      <div data-animate="fade-up" data-delay="300" class="flex flex-wrap gap-4">
        <a href={lang === 'tr' ? '/iletisim' : '/en/contact'} class="btn-primary">
          {t(lang, 'hero.cta')}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href={lang === 'tr' ? '/urunler' : '/en/products'} class="btn-outline-dark">{t(lang, 'hero.explore')}</a>
      </div>

      <!-- Mini stats row -->
      <div data-animate="fade-up" data-delay="400" class="flex gap-8 mt-12 pt-8 border-t border-border">
        <div>
          <div class="font-mono text-2xl font-bold text-primary">2007</div>
          <div class="text-text-muted text-xs uppercase tracking-wider">{lang === 'tr' ? 'Kurulus' : 'Since'}</div>
        </div>
        <div>
          <div class="font-mono text-2xl font-bold text-primary">20+</div>
          <div class="text-text-muted text-xs uppercase tracking-wider">CNC</div>
        </div>
        <div>
          <div class="font-mono text-2xl font-bold text-accent">AS9100</div>
          <div class="text-text-muted text-xs uppercase tracking-wider">{lang === 'tr' ? 'Sertifika' : 'Certified'}</div>
        </div>
      </div>
    </div>
  </div>
</section>
