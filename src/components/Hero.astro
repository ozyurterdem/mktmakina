---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const categories = lang === 'tr'
  ? [
      { name: 'CNC İşleme', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z', href: '/urunler/uygulamalar' },
      { name: 'Kalıp & Fikstür', icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z', href: '/urunler/kaliplar' },
      { name: 'Plastik Enjeksiyon', icon: 'M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z', href: '/urunler/plastik-enjeksiyon' },
      { name: 'Kalite Kontrol', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', href: '/urunler/kalite-kontrol-mastarlari' },
    ]
  : [
      { name: 'CNC Machining', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z', href: '/en/products' },
      { name: 'Molds & Fixtures', icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z', href: '/en/products' },
      { name: 'Plastic Injection', icon: 'M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z', href: '/en/products' },
      { name: 'Quality Control', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', href: '/en/products' },
    ];
---

<section class="relative min-h-screen flex items-center" id="hero">
  <!-- Background -->
  <div class="absolute inset-0">
    <img
      src="/images/slide1.jpg"
      alt="MKT Makina CNC İşleme"
      class="w-full h-full object-cover"
      loading="eager"
      id="hero-img"
    />
    <div class="hero-overlay absolute inset-0"></div>
  </div>

  <!-- Vertical accent line -->
  <div class="absolute top-0 left-[8%] w-px h-full bg-gradient-to-b from-transparent via-white/10 to-transparent hidden lg:block"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-[1400px] mx-auto px-6 w-full pt-32 pb-48 lg:pb-56">
    <div class="max-w-3xl">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-8 bg-white/10 backdrop-blur-sm border border-white/10 text-white/80 text-xs font-medium tracking-wider uppercase">
        <span class="w-1.5 h-1.5 bg-accent-500 rounded-full"></span>
        AS9100 {t(lang, 'stats.certification')}
      </div>

      <!-- Title -->
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold text-white leading-[1.05] mb-6">
        {lang === 'tr' ? (
          <>
            <span class="block">Havacılık</span>
            <span class="block">Hassasiyetinde</span>
            <span class="block text-accent-400">Üretim</span>
          </>
        ) : (
          <>
            <span class="block">Aviation-Grade</span>
            <span class="block">Precision</span>
            <span class="block text-accent-400">Manufacturing</span>
          </>
        )}
      </h1>

      <!-- Accent bar -->
      <div class="w-16 h-[3px] bg-accent-500 mb-6"></div>

      <!-- Subtitle -->
      <p class="text-white/60 text-base sm:text-lg leading-relaxed mb-10 max-w-xl">
        {t(lang, 'hero.subtitle')}
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-3">
        <a
          href={lang === 'tr' ? '/iletisim' : '/en/contact'}
          class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-accent-500 text-white text-sm font-semibold uppercase tracking-wider hover:bg-accent-600 transition-colors"
        >
          {t(lang, 'hero.cta')}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
        <a
          href={getLocalePath(lang, '/urunler')}
          class="inline-flex items-center justify-center gap-2 px-7 py-3.5 border border-white/30 text-white text-sm font-semibold uppercase tracking-wider hover:bg-white/10 transition-colors"
        >
          {t(lang, 'hero.explore')}
        </a>
      </div>
    </div>
  </div>

  <!-- Category Cards (Aselsan-style) — Bottom overlay -->
  <div class="absolute bottom-0 left-0 right-0 z-20">
    <div class="max-w-[1400px] mx-auto px-6">
      <div class="grid grid-cols-2 lg:grid-cols-4">
        {categories.map((cat, i) => (
          <a
            href={cat.href}
            class="group relative flex items-center gap-4 px-6 py-5 lg:py-6 bg-navy-800/80 backdrop-blur-md border-r border-white/5 last:border-r-0 hover:bg-accent-500 transition-all duration-300"
          >
            <div class="w-10 h-10 border border-white/20 flex items-center justify-center group-hover:border-white/40 transition-colors shrink-0">
              <svg class="w-5 h-5 text-accent-400 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={cat.icon} />
              </svg>
            </div>
            <div>
              <span class="block text-white text-sm font-heading font-semibold tracking-wide uppercase">{cat.name}</span>
              <span class="block text-white/40 text-xs mt-0.5 group-hover:text-white/70 transition-colors">{lang === 'tr' ? 'Daha Fazla' : 'Learn More'} →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-32 lg:bottom-28 right-6 z-10 hidden lg:flex flex-col items-center gap-2">
    <div class="w-[1px] h-12 bg-gradient-to-b from-white/40 to-transparent"></div>
    <span class="text-white/30 text-[10px] uppercase tracking-[0.3em] [writing-mode:vertical-lr]">Scroll</span>
  </div>
</section>

<script>
  const heroImg = document.getElementById('hero-img');
  if (heroImg && window.innerWidth > 768) {
    window.addEventListener('scroll', () => {
      const y = window.scrollY;
      if (y < window.innerHeight) {
        heroImg.style.transform = `translateY(${y * 0.12}px)`;
      }
    }, { passive: true });
  }
</script>
