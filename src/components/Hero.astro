---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden" id="hero">
  <!-- Parallax Background -->
  <div class="absolute inset-0" id="hero-parallax">
    <img
      src="/images/slide1.jpg"
      alt="MKT Makina CNC İşleme"
      class="w-full h-[120%] object-cover will-change-transform"
      loading="eager"
      id="hero-img"
    />
    <div class="hero-overlay-v2 absolute inset-0"></div>
  </div>

  <!-- Decorative: vertical lines -->
  <div class="absolute inset-0 max-w-7xl mx-auto px-10 hidden lg:block pointer-events-none">
    <div class="absolute top-0 left-[20%] w-px h-full bg-gradient-to-b from-transparent via-white/[0.06] to-transparent"></div>
    <div class="absolute top-0 right-[20%] w-px h-full bg-gradient-to-b from-transparent via-white/[0.06] to-transparent"></div>
  </div>

  <!-- Content (Centered - Gage/Volo style) -->
  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center py-32 lg:py-40">
    <!-- Badge -->
    <div
      class="inline-flex items-center gap-2 px-5 py-2 mb-8 bg-white/[0.08] backdrop-blur-sm border border-white/10 text-white/70 text-xs font-medium tracking-[0.2em] uppercase"
      data-animate="fade-down" data-delay="200"
    >
      <span class="w-2 h-2 bg-accent-500 rounded-full animate-pulse"></span>
      AS9100 {t(lang, 'stats.certification')}
    </div>

    <!-- Title -->
    <h1
      class="font-heading text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold text-white leading-[1.05] mb-8"
      data-animate="fade-up" data-duration="1200"
    >
      {lang === 'tr' ? (
        <>
          <span class="block">Havacılık</span>
          <span class="block mt-1">Hassasiyetinde</span>
          <span class="block mt-1 text-accent-400">Üretim</span>
        </>
      ) : (
        <>
          <span class="block">Aviation-Grade</span>
          <span class="block mt-1">Precision</span>
          <span class="block mt-1 text-accent-400">Manufacturing</span>
        </>
      )}
    </h1>

    <!-- Accent bar centered -->
    <div class="w-16 h-[3px] bg-accent-500 mx-auto mb-8" data-animate="zoom-in" data-delay="300"></div>

    <!-- Subtitle -->
    <p
      class="text-white/50 text-base sm:text-lg lg:text-xl leading-relaxed mb-12 max-w-2xl mx-auto"
      data-animate="fade-up" data-delay="400"
    >
      {t(lang, 'hero.subtitle')}
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center" data-animate="fade-up" data-delay="500">
      <a href={lang === 'tr' ? '/iletisim' : '/en/contact'} class="btn-primary">
        {t(lang, 'hero.cta')}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
      <a href={getLocalePath(lang, '/urunler')} class="btn-ghost">
        {t(lang, 'hero.explore')}
      </a>
    </div>
  </div>

  <!-- Bottom: Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-3" data-animate="fade-up" data-delay="800">
    <div class="w-[1px] h-10 bg-gradient-to-b from-white/30 to-transparent"></div>
    <span class="text-white/25 text-[10px] uppercase tracking-[0.3em]">Scroll</span>
  </div>
</section>

<script>
  const heroImg = document.getElementById('hero-img');
  if (heroImg && window.innerWidth > 768 && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let hTick = false;
    window.addEventListener('scroll', () => {
      if (hTick) return;
      hTick = true;
      requestAnimationFrame(() => {
        const y = window.scrollY;
        if (y < window.innerHeight) {
          heroImg.style.transform = `translate3d(0,${y * 0.2}px,0)`;
        }
        hTick = false;
      });
    }, { passive: true });
  }
</script>
