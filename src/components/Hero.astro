---
import { t, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;
const l = (map: Record<string, string>) => map[lang] || map['en'] || '';

type Slide = {
  overline: string;
  title: [string, string, string];
  desc: string;
};

const slides: Slide[] = [
  {
    overline: t(lang, 'hero.slide1.subtitle'),
    title: [
      l({ tr: 'Havacılık',     en: 'Aviation-Grade',   de: 'Luftfahrt-',     ar: 'جودة' }),
      l({ tr: 'Hassasiyetinde', en: 'Precision',        de: 'Präzision',      ar: 'الطيران' }),
      l({ tr: 'Üretim',         en: 'Manufacturing',    de: 'Fertigung',      ar: 'التصنيع' }),
    ],
    desc: t(lang, 'hero.subtitle'),
  },
  {
    overline: t(lang, 'hero.slide2.subtitle'),
    title: [
      l({ tr: 'Mikron',      en: 'Micron-Level',  de: 'Mikrometer',    ar: 'دقة' }),
      l({ tr: 'Seviyesinde', en: 'DMG MORI',      de: 'mit DMG MORI',  ar: 'بمستوى' }),
      l({ tr: 'Hassasiyet',  en: '& HAAS',        de: '& HAAS',        ar: 'الميكرون' }),
    ],
    desc: t(lang, 'hero.slide2.desc'),
  },
  {
    overline: t(lang, 'hero.slide3.subtitle'),
    title: [
      l({ tr: 'Montaj Grubu', en: 'Sub-Assembly',  de: 'Baugruppen-',          ar: 'قطع' }),
      l({ tr: 'Parçalar &',   en: 'Parts &',       de: 'teile &',              ar: 'مجموعات التجميع' }),
      l({ tr: 'Fikstürler',   en: 'Fixtures',      de: 'Spannvorrichtungen',   ar: 'وتركيبات التثبيت' }),
    ],
    desc: l({
      tr: 'Havacılık yapısal parçaları ve montaj grupları üretiminde güvenilir çözüm ortağınız.',
      en: 'Your trusted partner in aerospace structural parts and sub-assembly production.',
      de: 'Ihr vertrauenswürdiger Partner für Strukturbauteile und Baugruppen in der Luftfahrt.',
      ar: 'شريكك الموثوق في إنتاج القطع الهيكلية ومجموعات التجميع في مجال الطيران.',
    }),
  },
];

const ctaContactHref  = l({ tr: '/iletisim', en: '/en/contact',  de: '/de/contact',  ar: '/ar/contact' });
const ctaProductsHref = l({ tr: '/urunler',  en: '/en/products', de: '/de/products', ar: '/ar/products' });
---

<section class="relative min-h-screen flex items-center overflow-hidden" id="hero">
  <!-- Static Background (slide1.jpg) + Ken Burns -->
  <div class="absolute inset-0">
    <img src="/images/slide1.jpg" alt="MKT Makina" class="w-full h-full object-cover hero-bg-kb" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-b from-[#060a12]/70 via-[#060a12]/50 to-[#060a12]/90"></div>
    <div class="absolute inset-0 grid-overlay"></div>
  </div>

  <!-- Corner Calibration Markers (CNC L-brackets) -->
  <div class="corner-markers pointer-events-none absolute inset-0 z-[2]" aria-hidden="true">
    <span class="corner corner-tl"></span>
    <span class="corner corner-tr"></span>
    <span class="corner corner-bl"></span>
    <span class="corner corner-br"></span>
  </div>

  <!-- CNC Probe / Coordinate Crosshair -->
  <div class="cnc-probe pointer-events-none absolute z-[2] hidden md:block" id="cncProbe" aria-hidden="true">
    <svg class="w-8 h-8 text-accent/60" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1">
      <circle cx="16" cy="16" r="6" />
      <circle cx="16" cy="16" r="1.5" fill="currentColor" />
      <line x1="16" y1="0"  x2="16" y2="10" />
      <line x1="16" y1="22" x2="16" y2="32" />
      <line x1="0"  y1="16" x2="10" y2="16" />
      <line x1="22" y1="16" x2="32" y2="16" />
    </svg>
  </div>

  <!-- Coordinate Readout -->
  <div class="cnc-readout pointer-events-none absolute bottom-24 right-6 lg:right-8 z-[3] hidden md:flex flex-col items-end gap-0.5 font-mono text-[10px] tracking-[0.15em] text-white/35" aria-hidden="true">
    <span class="flex items-center gap-2">
      <span class="w-1.5 h-1.5 bg-accent/70 rounded-full animate-pulse"></span>
      <span>NHC 5000 · LIVE</span>
    </span>
    <span>X <span id="probeX" class="text-white/60">000.000</span> mm</span>
    <span>Y <span id="probeY" class="text-white/60">000.000</span> mm</span>
    <span>Z <span id="probeZ" class="text-white/60">000.000</span> mm</span>
    <span>A <span id="probeA" class="text-white/60">+00.00</span>°</span>
    <span>B <span id="probeB" class="text-white/60">+00.00</span>°</span>
  </div>

  <!-- Content carousel -->
  <div class="relative z-10 container-custom py-32 lg:py-40 w-full">
    <div class="max-w-3xl relative hero-slides">
      {slides.map((slide, i) => (
        <div
          class:list={[
            'hero-slide',
            i === 0 ? 'is-active' : '',
          ]}
          data-slide-index={i}
        >
          <div class="flex items-center gap-4 mb-8 hero-anim" style="--d:0ms">
            <span class="w-12 h-px bg-accent"></span>
            <span class="text-accent text-xs font-mono uppercase tracking-[0.3em] font-medium">{slide.overline}</span>
          </div>

          {i === 0 ? (
            <h1 class="text-4xl sm:text-5xl lg:text-[4rem] xl:text-[4.5rem] font-heading font-bold text-white leading-[1.05] mb-8 tracking-tight hero-anim" style="--d:100ms">
              {slide.title[0]}<br />
              <span class="text-accent">{slide.title[1]}</span><br />
              {slide.title[2]}
            </h1>
          ) : (
            <h2 class="text-4xl sm:text-5xl lg:text-[4rem] xl:text-[4.5rem] font-heading font-bold text-white leading-[1.05] mb-8 tracking-tight hero-anim" style="--d:100ms">
              {slide.title[0]}<br />
              <span class="text-accent">{slide.title[1]}</span><br />
              {slide.title[2]}
            </h2>
          )}

          <p class="text-base lg:text-lg text-white/50 leading-relaxed mb-12 max-w-xl hero-anim" style="--d:200ms">
            {slide.desc}
          </p>

          <div class="flex flex-wrap gap-4 hero-anim" style="--d:300ms">
            <a href={ctaContactHref} class="btn-primary">
              {t(lang, 'hero.cta')}
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href={ctaProductsHref} class="btn-outline">{t(lang, 'hero.explore')}</a>
          </div>
        </div>
      ))}

      <div class="hero-dots flex gap-2 mt-10">
        {slides.map((_, i) => (
          <button
            type="button"
            data-dot={i}
            aria-label={`Slide ${i + 1}`}
            class:list={['hero-dot', i === 0 ? 'is-active' : '']}
          ></button>
        ))}
      </div>
    </div>
  </div>

  <!-- Bottom Stats Bar -->
  <div class="absolute bottom-0 left-0 right-0 z-10 border-t border-white/[0.06]">
    <div class="container-custom">
      <div class="grid grid-cols-3 divide-x divide-white/[0.06]">
        <div class="py-6 lg:py-8 px-4 lg:px-8" data-animate="fade-up" data-delay="400">
          <div class="font-mono text-2xl lg:text-3xl font-bold text-accent">2007</div>
          <div class="text-white/30 text-xs uppercase tracking-widest mt-1">{l({tr:'Kuruluş', en:'Since', de:'Seit', ar:'منذ'})}</div>
        </div>
        <div class="py-6 lg:py-8 px-4 lg:px-8" data-animate="fade-up" data-delay="480">
          <div class="font-mono text-2xl lg:text-3xl font-bold text-white">20<span class="text-accent">+</span></div>
          <div class="text-white/30 text-xs uppercase tracking-widest mt-1">CNC</div>
        </div>
        <div class="py-6 lg:py-8 px-4 lg:px-8" data-animate="fade-up" data-delay="560">
          <div class="font-mono text-2xl lg:text-3xl font-bold text-accent">AS9100</div>
          <div class="text-white/30 text-xs uppercase tracking-widest mt-1">{l({tr:'Sertifikalı', en:'Certified', de:'Zertifiziert', ar:'معتمد'})}</div>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-28 left-1/2 -translate-x-1/2 z-10 hidden lg:block">
    <div class="scroll-bounce">
      <svg class="w-5 h-5 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </div>
</section>

<style>
  /* Ken Burns çok yavaş zoom (daha yumuşak) */
  .hero-bg-kb {
    transform: scale(1.05);
    animation: heroBgKB 36s ease-in-out infinite alternate;
    transform-origin: center center;
    will-change: transform;
  }
  @keyframes heroBgKB {
    from { transform: scale(1.05) translate(0, 0); }
    to   { transform: scale(1.14) translate(-0.8%, 0.8%); }
  }

  /* Carousel — daha yumuşak crossfade */
  .hero-slides { min-height: 460px; }
  .hero-slide {
    position: absolute; inset: 0;
    opacity: 0; pointer-events: none;
    transition: opacity 1100ms cubic-bezier(0.4, 0, 0.2, 1);
    will-change: opacity;
  }
  .hero-slide.is-active { opacity: 1; pointer-events: auto; }

  .hero-slide .hero-anim {
    opacity: 0; transform: translateY(14px);
    transition:
      opacity 950ms cubic-bezier(0.4, 0, 0.2, 1) var(--d),
      transform 950ms cubic-bezier(0.22, 0.61, 0.36, 1) var(--d);
    will-change: opacity, transform;
  }
  .hero-slide.is-active .hero-anim { opacity: 1; transform: translateY(0); }

  /* Dots */
  .hero-dots { position: relative; z-index: 5; padding-top: 460px; }
  .hero-dot {
    width: 44px; height: 3px;
    background: rgba(255,255,255,0.15);
    transition: background-color 300ms ease;
    cursor: pointer; border: 0; padding: 0;
  }
  .hero-dot:hover      { background: rgba(255,255,255,0.35); }
  .hero-dot.is-active  { background: var(--color-accent, #c8a23c); }

  /* Corner markers — CNC calibration L-brackets (daha yumuşak pulse) */
  .corner {
    position: absolute;
    width: 28px; height: 28px;
    opacity: 0.28;
    transition: opacity 900ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .corner::before,
  .corner::after {
    content: '';
    position: absolute;
    background: var(--color-accent, #c8a23c);
  }
  .corner::before { /* yatay çubuk */
    left: 0; width: 14px; height: 1px;
  }
  .corner::after { /* dikey çubuk */
    top: 0; width: 1px; height: 14px;
  }
  .corner-tl { top: 20px; left: 20px; }
  .corner-tr { top: 20px; right: 20px; transform: scaleX(-1); }
  .corner-bl { bottom: 20px; left: 20px; transform: scaleY(-1); }
  .corner-br { bottom: 20px; right: 20px; transform: scale(-1, -1); }

  /* Slide geçişinde köşeleri flash'la (pulse) */
  #hero.slide-changing .corner { opacity: 0.7; }

  /* CNC Probe (crosshair) — daha uzun ve yumuşak */
  .cnc-probe {
    top: 20%; left: 55%;
    transform: translate(-50%, -50%);
    transition: top 9s cubic-bezier(0.4, 0, 0.2, 1),
                left 9s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 1200ms ease;
    filter: drop-shadow(0 0 6px rgba(200, 162, 60, 0.3));
    opacity: 0.55;
    will-change: top, left;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .hero-bg-kb,
    .cnc-probe,
    .corner { animation: none; transition: none; }
    .hero-slide, .hero-slide .hero-anim { transition: none; }
  }
</style>

<script>
  (() => {
    const root = document.getElementById('hero');
    if (!root) return;

    const slides = root.querySelectorAll<HTMLElement>('.hero-slide');
    const dots   = root.querySelectorAll<HTMLButtonElement>('.hero-dot');
    const probe  = document.getElementById('cncProbe') as HTMLElement | null;
    const xEl = document.getElementById('probeX');
    const yEl = document.getElementById('probeY');
    const zEl = document.getElementById('probeZ');
    const aEl = document.getElementById('probeA');
    const bEl = document.getElementById('probeB');

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* ---------- Slide carousel (daha uzun aralık) ---------- */
    let index = 0;
    let timer: number | undefined;
    const INTERVAL = 7000;

    const show = (n: number) => {
      index = ((n % slides.length) + slides.length) % slides.length;
      slides.forEach((s, i) => s.classList.toggle('is-active', i === index));
      dots.forEach((d, i) => d.classList.toggle('is-active', i === index));

      // Corner markers kısa pulse (yumuşak)
      root.classList.add('slide-changing');
      window.setTimeout(() => root.classList.remove('slide-changing'), 1200);

      // Probe'u yeni bir konuma yumuşak taşı
      moveProbe();
    };

    const start = () => { stop(); timer = window.setInterval(() => show(index + 1), INTERVAL); };
    const stop  = () => { if (timer !== undefined) window.clearInterval(timer); timer = undefined; };

    dots.forEach((dot, i) => dot.addEventListener('click', () => { show(i); start(); }));

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stop(); else start();
    });

    /* ---------- CNC Probe hareketi ---------- */
    const probePositions: Array<[string, string]> = [
      ['20%', '62%'],
      ['35%', '22%'],
      ['68%', '40%'],
      ['82%', '72%'],
      ['48%', '55%'],
    ];
    let probePosIdx = 0;
    const moveProbe = () => {
      if (!probe || reducedMotion) return;
      probePosIdx = (probePosIdx + 1) % probePositions.length;
      const [left, top] = probePositions[probePosIdx];
      probe.style.left = left;
      probe.style.top = top;
    };

    /* ---------- Koordinat readout (sahte canlı değerler) ---------- */
    const pad = (n: number, w: number, dp: number) =>
      n.toFixed(dp).padStart(w, '0');

    let phase = 0;
    const tickReadout = () => {
      if (!xEl || !yEl || !zEl || !aEl || !bEl || reducedMotion) return;
      phase += 0.03;
      // plausible micro-mm oscillations
      const x = 234.567 + Math.sin(phase * 0.7) * 8.321;
      const y = 189.024 + Math.cos(phase * 0.5) * 6.102;
      const z =  12.000 + Math.sin(phase * 1.3) * 0.085;
      const a =  15.40 + Math.sin(phase * 0.9) * 3.15;
      const b = -22.85 + Math.cos(phase * 0.6) * 4.40;
      xEl.textContent = pad(x, 7, 3);
      yEl.textContent = pad(y, 7, 3);
      zEl.textContent = pad(z, 7, 3);
      aEl.textContent = (a >= 0 ? '+' : '') + a.toFixed(2).padStart(5, '0');
      bEl.textContent = (b >= 0 ? '+' : '') + b.toFixed(2).padStart(5, '0');
    };

    if (!reducedMotion) {
      moveProbe();
      start();
      window.setInterval(tickReadout, 200);
    }
  })();
</script>
