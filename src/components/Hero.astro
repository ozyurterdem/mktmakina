---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const contactPath = lang === 'tr' ? '/iletisim' : '/en/contact';
const productsPath = getLocalePath(lang, '/urunler');

const slides = [
  {
    image: '/images/slide1.jpg',
    subtitle: t(lang, 'hero.slide1.subtitle'),
    titleLines: lang === 'tr'
      ? ['Havacılık', 'Hassasiyetinde', 'Üretim']
      : ['Aviation-Grade', 'Precision', 'Manufacturing'],
    accentLast: true,
    desc: t(lang, 'hero.subtitle'),
  },
  {
    image: '/images/slide2.jpg',
    subtitle: t(lang, 'hero.slide2.subtitle'),
    titleLines: lang === 'tr'
      ? ['5 Eksen CNC', 'Hassas İşleme']
      : ['5-Axis CNC', 'Precision Machining'],
    accentLast: false,
    desc: t(lang, 'hero.slide2.desc'),
  },
  {
    image: '/images/slide3.jpg',
    subtitle: t(lang, 'hero.slide3.subtitle'),
    titleLines: lang === 'tr'
      ? ['Kalıp & Enjeksiyon', 'Çözümleri']
      : ['Mold & Injection', 'Solutions'],
    accentLast: false,
    desc: t(lang, 'hero.slide3.desc'),
  },
];
---

<section class="relative min-h-screen overflow-hidden" id="hero">
  <!-- Slides -->
  {slides.map((slide, i) => (
    <div class:list={['hero-slide', i === 0 && 'is-active']} data-slide={i}>
      <!-- Background Image -->
      <img
        src={slide.image}
        alt=""
        class="w-full h-full object-cover"
        loading={i === 0 ? 'eager' : 'lazy'}
      />
      <!-- Cinematic Gradient Overlay -->
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at bottom, rgba(5,11,20,0.25) 0%, rgba(5,11,20,0.6) 50%, rgba(5,11,20,0.88) 100%)"></div>

      <!-- Slide Content -->
      <div class="hero-slide-content absolute inset-0 flex items-center justify-center">
        <div class="max-w-4xl mx-auto px-6 text-center">
          <!-- Subtitle Badge -->
          <div class="text-accent-400 text-[11px] sm:text-xs font-semibold tracking-[0.25em] uppercase mb-6 lg:mb-8">
            <span class="inline-flex items-center gap-2">
              <span class="w-6 h-px bg-accent-500"></span>
              {slide.subtitle}
              <span class="w-6 h-px bg-accent-500"></span>
            </span>
          </div>

          <!-- Title -->
          <h1 class="font-heading mb-0">
            {slide.titleLines.map((line, li) => (
              <span
                class:list={[
                  'block text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold leading-[1.05] mt-1',
                  li === slide.titleLines.length - 1 && slide.accentLast
                    ? 'text-accent-400'
                    : 'text-white',
                ]}
              >
                {line}
              </span>
            ))}
          </h1>

          <!-- Accent Bar -->
          <div class="w-16 h-[3px] bg-accent-500 mx-auto mt-8 mb-8"></div>

          <!-- Description -->
          <p class="text-white/45 text-base sm:text-lg lg:text-xl leading-relaxed mb-10 lg:mb-12 max-w-2xl mx-auto">
            {slide.desc}
          </p>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={contactPath} class="btn-primary">
              {t(lang, 'hero.cta')}
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a href={productsPath} class="btn-ghost">
              {t(lang, 'hero.explore')}
            </a>
          </div>
        </div>
      </div>
    </div>
  ))}

  <!-- Decorative vertical lines -->
  <div class="absolute inset-0 max-w-7xl mx-auto px-10 hidden lg:block pointer-events-none z-10">
    <div class="absolute top-0 left-[20%] w-px h-full bg-gradient-to-b from-transparent via-white/[0.04] to-transparent"></div>
    <div class="absolute top-0 right-[20%] w-px h-full bg-gradient-to-b from-transparent via-white/[0.04] to-transparent"></div>
  </div>

  <!-- Progress Bar -->
  <div class="slide-progress is-animating" id="slide-progress"></div>

  <!-- Slide Indicators -->
  <div class="absolute bottom-20 left-1/2 -translate-x-1/2 z-20 flex gap-3">
    {slides.map((_, i) => (
      <button
        class:list={['slide-indicator', i === 0 && 'is-active']}
        data-slide-btn={i}
        aria-label={`Slide ${i + 1}`}
      ></button>
    ))}
  </div>

  <!-- Scroll Indicator (Bouncing Chevron) -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-1 scroll-bounce">
    <svg class="w-5 h-5 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>

<script>
  const slides = document.querySelectorAll<HTMLElement>('[data-slide]');
  const btns = document.querySelectorAll<HTMLElement>('[data-slide-btn]');
  const progress = document.getElementById('slide-progress');
  let current = 0;
  let autoplayTimer: ReturnType<typeof setInterval> | null = null;

  function goTo(idx: number) {
    if (idx === current) return;
    slides[current]?.classList.remove('is-active');
    btns[current]?.classList.remove('is-active');
    current = idx;
    slides[current]?.classList.add('is-active');
    btns[current]?.classList.add('is-active');
    resetProgress();
  }

  function next() {
    goTo((current + 1) % slides.length);
  }

  function resetProgress() {
    if (!progress) return;
    progress.classList.remove('is-animating');
    void progress.offsetWidth; // force reflow
    progress.classList.add('is-animating');
  }

  function startAutoplay() {
    if (autoplayTimer) clearInterval(autoplayTimer);
    autoplayTimer = setInterval(next, 6000);
    resetProgress();
  }

  // Indicator click
  btns.forEach((btn, i) => {
    btn.addEventListener('click', () => {
      goTo(i);
      startAutoplay();
    });
  });

  // Pause on hover (optional premium feel)
  const heroEl = document.getElementById('hero');
  heroEl?.addEventListener('mouseenter', () => {
    if (autoplayTimer) clearInterval(autoplayTimer);
    autoplayTimer = null;
    progress?.classList.add('paused');
  });
  heroEl?.addEventListener('mouseleave', () => {
    startAutoplay();
    progress?.classList.remove('paused');
  });

  // Start
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    startAutoplay();
  } else {
    // Show first slide without animation
    slides[0]?.classList.add('is-active');
  }
</script>
