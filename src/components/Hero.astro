---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;
---

<section class="relative min-h-screen flex items-center overflow-hidden" id="hero">
  <!-- Background Image with parallax -->
  <div class="absolute inset-0">
    <img
      src="/images/slide1.jpg"
      alt="MKT Makina CNC İşleme"
      class="w-full h-full object-cover scale-105"
      loading="eager"
      id="hero-img"
    />
    <div class="hero-overlay absolute inset-0"></div>
  </div>

  <!-- Animated geometric lines -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <!-- Vertical accent line -->
    <div class="absolute top-0 right-[20%] w-px h-full bg-gradient-to-b from-transparent via-accent-500/20 to-transparent"></div>
    <!-- Horizontal line -->
    <div class="absolute top-[40%] left-0 w-full h-px bg-gradient-to-r from-transparent via-white/5 to-transparent"></div>
    <!-- Corner accent -->
    <div class="absolute top-20 right-16 lg:right-32">
      <div class="w-32 h-32 border border-accent-500/10 rounded-sm rotate-45 animate-float"></div>
    </div>
    <div class="absolute bottom-32 right-24 lg:right-48">
      <div class="w-20 h-20 border border-white/5 rounded-sm rotate-12" style="animation: float 8s ease-in-out 2s infinite;"></div>
    </div>
    <!-- Dot grid pattern -->
    <div class="absolute top-32 right-8 lg:right-20 grid grid-cols-5 gap-3 opacity-20">
      {Array.from({ length: 25 }).map(() => (
        <div class="w-1 h-1 rounded-full bg-accent-500"></div>
      ))}
    </div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32">
    <div class="max-w-3xl">
      <!-- AS9100 Badge -->
      <div class="inline-flex items-center gap-2.5 px-4 py-2 mb-10 glass rounded-full">
        <div class="w-2 h-2 rounded-full bg-accent-500 animate-pulse"></div>
        <span class="text-white/80 text-sm font-medium tracking-wide">AS9100 {t(lang, 'stats.certification')}</span>
      </div>

      <!-- Title with premium typography -->
      <h1 class="font-heading text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-bold text-white leading-[0.95] mb-8 tracking-tight">
        <span class="block">{lang === 'tr' ? 'Havacılık' : 'Aviation-Grade'}</span>
        <span class="block">{lang === 'tr' ? 'Hassasiyetinde' : 'Precision'}</span>
        <span class="block text-transparent bg-clip-text bg-gradient-to-r from-accent-400 to-accent-600">{lang === 'tr' ? 'Üretim' : 'Manufacturing'}</span>
      </h1>

      <!-- Accent Bar animated -->
      <div class="w-20 h-1 bg-gradient-to-r from-accent-500 to-accent-300 rounded-full mb-8"></div>

      <!-- Subtitle -->
      <p class="text-lg sm:text-xl text-steel-300/90 leading-relaxed mb-12 max-w-xl font-light">
        {t(lang, 'hero.subtitle')}
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href={lang === 'tr' ? '/iletisim' : '/en/contact'}
          class="group inline-flex items-center justify-center gap-3 px-8 py-4.5 bg-gradient-to-r from-accent-500 to-accent-600 text-white font-semibold uppercase tracking-wider rounded-lg hover:from-accent-600 hover:to-accent-700 transition-all shadow-xl shadow-accent-500/20 hover:shadow-accent-500/40 text-sm"
        >
          {t(lang, 'hero.cta')}
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href={getLocalePath(lang, '/urunler')}
          class="group inline-flex items-center justify-center gap-3 px-8 py-4.5 glass text-white font-semibold uppercase tracking-wider rounded-lg hover:bg-white/15 transition-all text-sm"
        >
          {t(lang, 'hero.explore')}
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 opacity-60">
    <span class="text-white/50 text-xs uppercase tracking-[0.3em] font-light">Scroll</span>
    <div class="w-5 h-8 rounded-full border border-white/30 flex justify-center pt-1.5">
      <div class="w-1 h-2 bg-accent-500 rounded-full animate-bounce"></div>
    </div>
  </div>

  <!-- Bottom gradient -->
  <div class="absolute bottom-0 left-0 right-0 h-48 bg-gradient-to-t from-white via-white/50 to-transparent"></div>
</section>

<script>
  // Subtle parallax on hero image
  const heroImg = document.getElementById('hero-img');
  if (heroImg && window.innerWidth > 768) {
    window.addEventListener('scroll', () => {
      const y = window.scrollY;
      if (y < window.innerHeight) {
        heroImg.style.transform = `scale(1.05) translateY(${y * 0.15}px)`;
      }
    }, { passive: true });
  }
</script>
