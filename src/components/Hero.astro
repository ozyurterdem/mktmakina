---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;
---

<section class="relative min-h-[85vh] flex items-center overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0">
    <img
      src="/images/slide1.jpg"
      alt="MKT Makina CNC İşleme"
      class="w-full h-full object-cover"
      loading="eager"
    />
    <div class="hero-overlay absolute inset-0"></div>
  </div>

  <!-- Geometric Accent Lines -->
  <div class="absolute top-0 right-0 w-1/3 h-full opacity-10">
    <div class="absolute top-20 right-20 w-px h-[60%] bg-accent-500"></div>
    <div class="absolute top-[30%] right-20 w-[40%] h-px bg-accent-500"></div>
    <div class="absolute top-20 right-[280px] w-px h-[30%] bg-white/30"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 py-20">
    <div class="max-w-2xl">
      <!-- AS9100 Badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-8 bg-white/10 backdrop-blur-sm rounded-full border border-white/20">
        <svg class="w-4 h-4 text-accent-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <span class="text-white/90 text-sm font-medium">AS9100 {t(lang, 'stats.certification')}</span>
      </div>

      <!-- Title -->
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
        {t(lang, 'hero.title').split(' ').slice(0, -1).join(' ')}
        <span class="text-accent-500"> {t(lang, 'hero.title').split(' ').slice(-1)}</span>
      </h1>

      <!-- Accent Bar -->
      <div class="accent-bar mb-6"></div>

      <!-- Subtitle -->
      <p class="text-lg sm:text-xl text-steel-300 leading-relaxed mb-10 max-w-lg">
        {t(lang, 'hero.subtitle')}
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href={getLocalePath(lang, '/talep-formu')}
          class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-accent-500 text-white font-semibold uppercase tracking-wide rounded-md hover:bg-accent-600 transition-all shadow-lg hover:shadow-accent-500/30 text-sm"
        >
          {t(lang, 'hero.cta')}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href={getLocalePath(lang, '/urunler')}
          class="inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-white/30 text-white font-semibold uppercase tracking-wide rounded-md hover:bg-white/10 transition-all text-sm"
        >
          {t(lang, 'hero.explore')}
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom gradient fade -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-white to-transparent"></div>
</section>
