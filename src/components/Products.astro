---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const products = [
  { key: 'products.apparatus', image: '/images/categories/aparatlar_7.jpg', slug: 'aparatlar' },
  { key: 'products.fixtures', image: '/images/categories/fikstur_8.jpg', slug: 'fikstur' },
  { key: 'products.molds', image: '/images/categories/kaliplar_12.jpg', slug: 'kaliplar' },
  { key: 'products.applications', image: '/images/categories/parcalar_13.jpg', slug: 'uygulamalar' },
  { key: 'products.gauges', image: '/images/categories/mastarlar_14.jpg', slug: 'kalite-kontrol-mastarlari' },
  { key: 'products.injection', image: '/images/categories/parcalar_13.jpg', slug: 'plastik-enjeksiyon' },
];
---

<section class="relative section-padding noise-overlay" id="products">
  <div class="absolute inset-0 bg-surface"></div>

  <div class="relative z-10 container-custom">
    <div class="max-w-2xl mb-14" data-animate="fade-up">
      <div class="section-label">{lang === 'tr' ? 'Faaliyet Alanları' : 'Business Areas'}</div>
      <h2 class="text-3xl sm:text-4xl lg:text-[2.75rem] font-heading font-bold text-white mb-4">
        {t(lang, 'products.title')}
      </h2>
      <p class="text-text-light text-base leading-relaxed">{t(lang, 'products.subtitle')}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {products.map((product, i) => (
        <a
          href={lang === 'tr' ? `/urunler/${product.slug}` : `/en/products/${product.slug}`}
          class="group glass-card overflow-hidden"
          data-animate="fade-up"
          data-delay={String(((i % 3) + 1) * 100)}
        >
          <div class="relative aspect-[4/3] overflow-hidden">
            <img
              src={product.image}
              alt={t(lang, product.key)}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-primary-dark/80 via-transparent to-transparent"></div>
          </div>
          <div class="p-5">
            <h3 class="font-heading text-base font-semibold text-white tracking-wide mb-3 group-hover:text-accent transition-colors">
              {t(lang, product.key)}
            </h3>
            <div class="flex items-center gap-2 text-accent/70 text-xs font-mono uppercase tracking-wider group-hover:text-accent transition-colors">
              {lang === 'tr' ? 'Detaylar' : 'Details'}
              <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
