---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const products = [
  { key: 'products.apparatus', image: '/images/categories/aparatlar_7.jpg', slug: 'aparatlar', desc: lang === 'tr' ? 'Üretim süreçleri için özel tasarım aparatlar' : 'Custom apparatus for production processes' },
  { key: 'products.fixtures', image: '/images/categories/fikstur_8.jpg', slug: 'fikstur', desc: lang === 'tr' ? 'CNC ve montaj hatları için hassas fikstür' : 'Precision fixtures for CNC and assembly' },
  { key: 'products.molds', image: '/images/categories/kaliplar_12.jpg', slug: 'kaliplar', desc: lang === 'tr' ? 'Plastik enjeksiyon ve özel kalıp çözümleri' : 'Injection molds and custom solutions' },
  { key: 'products.applications', image: '/images/categories/parcalar_13.jpg', slug: 'uygulamalar', desc: lang === 'tr' ? 'Talaşlı imalat parçaları ve montaj grupları' : 'Machined parts and sub-assemblies' },
  { key: 'products.gauges', image: '/images/categories/mastarlar_14.jpg', slug: 'kalite-kontrol-mastarlari', desc: lang === 'tr' ? 'Hassas ölçüm ve kontrol mastarları' : 'Precision measurement gauges' },
  { key: 'products.injection', image: '/images/categories/parcalar_13.jpg', slug: 'plastik-enjeksiyon', desc: lang === 'tr' ? 'Seri üretim plastik enjeksiyon baskı' : 'Serial plastic injection molding' },
];
---

<section class="section-padding bg-white" id="products">
  <div class="max-w-[1400px] mx-auto px-6">
    <!-- Section Header -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-12 reveal">
      <div>
        <span class="text-accent-500 text-xs font-semibold uppercase tracking-[0.2em] mb-2 block">{lang === 'tr' ? 'Faaliyet Alanları' : 'Business Areas'}</span>
        <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-navy-800">
          {t(lang, 'products.title')}
        </h2>
      </div>
      <div class="accent-bar lg:hidden"></div>
      <p class="text-steel-500 text-base max-w-md lg:text-right">
        {t(lang, 'products.subtitle')}
      </p>
    </div>

    <!-- Product Grid — 3 col, Aselsan sector card style -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-[2px] bg-steel-200">
      {products.map((product, i) => (
        <a
          href={lang === 'tr' ? `/urunler/${product.slug}` : `/en/products/${product.slug}`}
          class={`reveal delay-${(i % 3) + 1} group relative block overflow-hidden bg-white`}
        >
          <!-- Image -->
          <div class="relative aspect-[16/10] overflow-hidden">
            <img
              src={product.image}
              alt={t(lang, product.key)}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-navy-950/80 via-navy-950/20 to-transparent"></div>
            <!-- Hover overlay -->
            <div class="absolute inset-0 bg-accent-500/0 group-hover:bg-accent-500/20 transition-colors duration-500"></div>
          </div>

          <!-- Text overlay bottom -->
          <div class="absolute bottom-0 left-0 right-0 p-5 lg:p-6">
            <h3 class="font-heading text-base sm:text-lg font-semibold text-white tracking-wide mb-1">
              {t(lang, product.key)}
            </h3>
            <p class="text-white/50 text-xs sm:text-sm leading-relaxed mb-3 line-clamp-1">{product.desc}</p>
            <div class="flex items-center gap-2 text-accent-400 text-xs font-semibold uppercase tracking-wider opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-300">
              {lang === 'tr' ? 'Daha Fazla' : 'Learn More'}
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </div>
          </div>

          <!-- Top-right accent corner -->
          <div class="absolute top-0 right-0 w-0 h-0 border-t-[40px] border-t-accent-500/0 border-l-[40px] border-l-transparent group-hover:border-t-accent-500 transition-colors duration-300"></div>
        </a>
      ))}
    </div>

    <!-- View all link -->
    <div class="text-center mt-10 reveal">
      <a
        href={getLocalePath(lang, '/urunler')}
        class="inline-flex items-center gap-2 text-navy-800 text-sm font-semibold uppercase tracking-wider hover:text-accent-500 transition-colors"
      >
        {lang === 'tr' ? 'Tüm Ürünleri Görüntüle' : 'View All Products'}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>
  </div>
</section>
