---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const products = [
  {
    key: 'products.apparatus',
    image: '/images/categories/aparatlar_7.jpg',
    slug: 'aparatlar',
  },
  {
    key: 'products.fixtures',
    image: '/images/categories/fikstur_8.jpg',
    slug: 'fikstur',
  },
  {
    key: 'products.molds',
    image: '/images/categories/kaliplar_12.jpg',
    slug: 'kaliplar',
  },
  {
    key: 'products.applications',
    image: '/images/categories/parcalar_13.jpg',
    slug: 'uygulamalar',
  },
  {
    key: 'products.gauges',
    image: '/images/categories/mastarlar_14.jpg',
    slug: 'kalite-kontrol-mastarlari',
  },
  {
    key: 'products.injection',
    image: '/images/categories/parcalar_13.jpg',
    slug: 'plastik-enjeksiyon',
  },
];
---

<section class="section-padding bg-white" id="products">
  <div class="max-w-7xl mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center mb-14 reveal">
      <div class="accent-bar mx-auto mb-4"></div>
      <h2 class="font-heading text-3xl sm:text-4xl font-bold text-navy-800 mb-3">
        {t(lang, 'products.title')}
      </h2>
      <p class="text-steel-500 text-lg max-w-2xl mx-auto">
        {t(lang, 'products.subtitle')}
      </p>
    </div>

    <!-- Product Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {products.map((product) => (
        <a
          href={getLocalePath(lang, `/urunler/${product.slug}`)}
          class="group relative block aspect-[4/3] overflow-hidden rounded-xl shadow-md hover:shadow-2xl transition-all duration-500 reveal"
        >
          <img
            src={product.image}
            alt={t(lang, product.key)}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            loading="lazy"
          />
          <!-- Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-navy-900/90 via-navy-900/30 to-transparent transition-opacity duration-300"></div>
          <!-- Hover overlay -->
          <div class="absolute inset-0 bg-accent-500/0 group-hover:bg-accent-500/20 transition-colors duration-500 flex items-center justify-center">
            <div class="w-14 h-14 rounded-full bg-white/0 group-hover:bg-white/90 flex items-center justify-center transition-all duration-500 scale-0 group-hover:scale-100">
              <svg class="w-6 h-6 text-accent-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </div>
          <!-- Title -->
          <div class="absolute bottom-0 left-0 right-0 p-5">
            <h3 class="font-heading text-lg font-semibold text-white tracking-wide">
              {t(lang, product.key)}
            </h3>
            <div class="w-8 h-0.5 bg-accent-500 mt-2 transition-all duration-500 group-hover:w-16"></div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
