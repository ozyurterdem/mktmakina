---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;
const l = (map: Record<string, string>) => map[lang] || map['en'] || '';
const year = new Date().getFullYear();

const quickLinksMap: Record<string, { key: string; href: string }[]> = {
  tr: [
    { key: 'nav.about', href: '/kurumsal' },
    { key: 'nav.products', href: '/urunler' },
    { key: 'nav.machines', href: '/makina-parkimiz' },
    { key: 'nav.references', href: '/referanslar' },
    { key: 'nav.certificates', href: '/belgeler' },
    { key: 'nav.contact', href: '/iletisim' },
    { key: 'nav.hr', href: '/insan-kaynaklari' },
  ],
  en: [
    { key: 'nav.about', href: '/en/about' },
    { key: 'nav.products', href: '/en/products' },
    { key: 'nav.machines', href: '/en/machines' },
    { key: 'nav.references', href: '/en/references' },
    { key: 'nav.certificates', href: '/en/certificates' },
    { key: 'nav.contact', href: '/en/contact' },
    { key: 'nav.hr', href: '/en/careers' },
  ],
  de: [
    { key: 'nav.about', href: '/de/about' },
    { key: 'nav.products', href: '/de/products' },
    { key: 'nav.machines', href: '/de/machines' },
    { key: 'nav.references', href: '/de/references' },
    { key: 'nav.certificates', href: '/de/certificates' },
    { key: 'nav.contact', href: '/de/contact' },
    { key: 'nav.hr', href: '/de/careers' },
  ],
  ar: [
    { key: 'nav.about', href: '/ar/about' },
    { key: 'nav.products', href: '/ar/products' },
    { key: 'nav.machines', href: '/ar/machines' },
    { key: 'nav.references', href: '/ar/references' },
    { key: 'nav.certificates', href: '/ar/certificates' },
    { key: 'nav.contact', href: '/ar/contact' },
    { key: 'nav.hr', href: '/ar/careers' },
  ],
};
const quickLinks = quickLinksMap[lang] ?? quickLinksMap['en'];

const productLinks = ['products.assemblies', 'products.fixtures', 'products.apparatus', 'products.molds', 'products.gauges', 'products.injection'];
---

<footer class="bg-primary-dark">
  <div class="container-custom py-16 lg:py-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-12 gap-10 lg:gap-8">
      <!-- Brand -->
      <div class="lg:col-span-4">
        <a href={getLocalePath(lang, '/')} class="flex items-center gap-3 mb-6">
          <img src="/images/logo.png" alt="MKT Makina" class="h-10 brightness-0 invert opacity-80" />
          <div class="leading-tight">
            <span class="block font-heading text-white text-sm font-semibold tracking-[0.12em] whitespace-nowrap">MKT MAKINA {t(lang, 'company.suffix')}</span>
            <span class="block text-white/40 text-[9px] font-medium tracking-[0.12em] whitespace-nowrap leading-[1.35]">{t(lang, 'company.tagline.l1')}</span>
            <span class="block text-white/40 text-[9px] font-medium tracking-[0.12em] whitespace-nowrap leading-[1.35]">{t(lang, 'company.tagline.l2')}</span>
          </div>
        </a>
        <p class="text-white/40 text-sm leading-relaxed mb-6 max-w-xs">
          {l({
            tr: 'Havacılık ve otomotiv sanayii için yüksek kaliteli hassas işleme parçalar ve plastik enjeksiyon çözümleri.',
            en: 'High quality precision machined parts and plastic injection solutions for aviation and automotive industry.',
            de: 'Hochwertige Präzisionsteile und Kunststoffspritzgusslösungen für die Luft- und Automobilindustrie.',
            ar: 'قطع دقيقة عالية الجودة وحلول حقن البلاستيك لصناعة الطيران والسيارات.',
          })}
        </p>
        <div class="flex flex-wrap gap-2">
          <div class="inline-flex items-center gap-2 px-3 py-2 bg-white/[0.04] border border-white/[0.06] text-xs text-white/60">
            <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            AS9100 Certified
          </div>
          <div class="inline-flex items-center gap-2 px-3 py-2 bg-white/[0.04] border border-white/[0.06] text-xs text-white/60">
            <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            ISO 9001
          </div>
          <div class="inline-flex items-center gap-2 px-3 py-2 bg-white/[0.04] border border-white/[0.06] text-xs text-white/60">
            <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            MES System
          </div>
          <div class="inline-flex items-center gap-2 px-3 py-2 bg-white/[0.04] border border-white/[0.06] text-xs text-white/60">
            <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/></svg>
            ERP System
          </div>
        </div>
      </div>

      <!-- Quick Links (başlıksız) -->
      <div class="lg:col-span-2">
        <ul class="space-y-2.5 lg:pt-2">
          {quickLinks.map((item) => (
            <li>
              <a href={item.href} class="text-white/50 text-sm hover:text-accent transition-colors">{t(lang, item.key)}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Products (başlıksız) -->
      <div class="lg:col-span-2">
        <ul class="space-y-2.5 lg:pt-2">
          {productLinks.map((key) => (
            <li>
              <a href={lang === 'tr' ? '/urunler' : `/${lang}/products`} class="text-white/50 text-sm hover:text-accent transition-colors">{t(lang, key)}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact (başlıksız) -->
      <div class="lg:col-span-4">
        <address class="not-italic space-y-4 text-sm text-white/50 lg:pt-2">
          <div class="flex gap-3">
            <svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <a href="https://www.google.com/maps/search/?api=1&query=40.7257778,30.3876111" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">{t(lang, 'footer.address')}</a>
          </div>
          <div class="flex gap-3">
            <svg class="w-4 h-4 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <div>
              <a href="tel:+902642761880" class="hover:text-accent transition-colors block">+90 264 276 18 80</a>
              <span class="text-white/20 text-xs">Fax: +90 264 276 18 77</span>
            </div>
          </div>
          <div class="flex gap-3">
            <svg class="w-4 h-4 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <a href="mailto:info@mktmakina.com" class="hover:text-accent transition-colors">info@mktmakina.com</a>
          </div>
          <div class="flex gap-3">
            <svg class="w-4 h-4 text-accent shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.049c.476-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            <a href="https://www.linkedin.com/company/mkt-incorporated/" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">LinkedIn</a>
          </div>
        </address>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/[0.04]">
    <div class="container-custom py-5 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-white/15 text-xs">&copy; {year} {t(lang, 'company.full')}. {t(lang, 'footer.rights')}</p>
      <p class="text-white/10 text-xs">
        <a href="https://siberkale.com" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">SiberKale</a>
        <span class="mx-1.5 text-white/5" aria-hidden="true">·</span>
        <a href="https://erdemozyurt.com" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">Erdem Özyurt</a>
      </p>
    </div>
  </div>
</footer>
