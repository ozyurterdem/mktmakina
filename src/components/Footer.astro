---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const year = new Date().getFullYear();
---

<footer class="bg-navy-900 text-white">
  <!-- Main Footer -->
  <div class="max-w-7xl mx-auto px-4 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand -->
      <div>
        <a href={getLocalePath(lang, '/')} class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 bg-accent-500 rounded-lg flex items-center justify-center">
            <span class="text-white font-heading font-bold text-sm">MKT</span>
          </div>
          <div>
            <span class="block font-heading text-white text-base font-semibold tracking-wide">MAKİNA KALIP TAKIM</span>
          </div>
        </a>
        <p class="text-steel-400 text-sm leading-relaxed mb-6">
          {lang === 'tr'
            ? 'Havacılık ve otomotiv sanayii için yüksek kaliteli hassas işleme parçalar ve plastik enjeksiyon çözümleri.'
            : 'High quality precision machined parts and plastic injection solutions for aviation and automotive industry.'}
        </p>
        <!-- AS9100 Badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-navy-800 rounded-md border border-navy-700">
          <svg class="w-5 h-5 text-accent-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          <span class="text-xs font-semibold text-steel-300">AS9100 Certified</span>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-heading text-sm font-semibold uppercase tracking-widest text-accent-500 mb-6">{t(lang, 'footer.quicklinks')}</h3>
        <ul class="space-y-3">
          {[
            { key: 'nav.about', href: '/kurumsal' },
            { key: 'nav.products', href: '/urunler' },
            { key: 'nav.machines', href: '/makina-parkimiz' },
            { key: 'nav.references', href: '/referanslar' },
            { key: 'nav.certificates', href: '/belgeler' },
          ].map((item) => (
            <li>
              <a href={getLocalePath(lang, item.href)} class="text-steel-400 text-sm hover:text-accent-400 transition-colors">
                {t(lang, item.key)}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Products -->
      <div>
        <h3 class="font-heading text-sm font-semibold uppercase tracking-widest text-accent-500 mb-6">{t(lang, 'products.title')}</h3>
        <ul class="space-y-3">
          {[
            'products.apparatus',
            'products.fixtures',
            'products.molds',
            'products.gauges',
            'products.injection',
          ].map((key) => (
            <li>
              <a href={getLocalePath(lang, '/urunler')} class="text-steel-400 text-sm hover:text-accent-400 transition-colors">
                {t(lang, key)}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-heading text-sm font-semibold uppercase tracking-widest text-accent-500 mb-6">{t(lang, 'footer.contact')}</h3>
        <address class="not-italic space-y-4 text-sm text-steel-400">
          <div class="flex gap-3">
            <svg class="w-5 h-5 text-accent-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>{t(lang, 'footer.address')}</span>
          </div>
          <div class="flex gap-3">
            <svg class="w-5 h-5 text-accent-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+902642761880" class="hover:text-accent-400 transition-colors">+90 264 276 18 80</a>
          </div>
          <div class="flex gap-3">
            <svg class="w-5 h-5 text-accent-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:info@mktmakina.com" class="hover:text-accent-400 transition-colors">info@mktmakina.com</a>
          </div>
        </address>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-navy-800">
    <div class="max-w-7xl mx-auto px-4 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-steel-500 text-xs">
        &copy; {year} MKT Makina Kalıp Takım. {t(lang, 'footer.rights')}
      </p>
      <p class="text-steel-600 text-xs">
        <a href="https://siberkale.com" target="_blank" rel="noopener noreferrer" class="hover:text-accent-400 transition-colors">
          SiberKale
        </a>
      </p>
    </div>
  </div>
</footer>
