---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;
const currentPath = Astro.url.pathname;

const navItemsTr = [
  { key: 'nav.home', href: '/' },
  { key: 'nav.about', href: '/kurumsal' },
  { key: 'nav.products', href: '/urunler' },
  { key: 'nav.machines', href: '/makina-parkimiz' },
  { key: 'nav.references', href: '/referanslar' },
  { key: 'nav.certificates', href: '/belgeler' },
  { key: 'nav.contact', href: '/iletisim' },
];

const navItemsEn = [
  { key: 'nav.home', href: '/en' },
  { key: 'nav.about', href: '/en/about' },
  { key: 'nav.products', href: '/en/products' },
  { key: 'nav.machines', href: '/en/machines' },
  { key: 'nav.references', href: '/en/references' },
  { key: 'nav.contact', href: '/en/contact' },
];

const navItems = lang === 'en' ? navItemsEn : navItemsTr;
const quoteHref = lang === 'en' ? '/en/contact' : '/talep-formu';
---

<!-- Top Bar -->
<div class="bg-navy-950 text-white/70 text-xs">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center justify-between h-9">
    <div class="flex items-center gap-6">
      <a href="tel:+902642761880" class="flex items-center gap-1.5 hover:text-accent-400 transition-colors">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        <span class="hidden sm:inline">0 264 276 18 80</span>
      </a>
      <a href="mailto:info@mktmakina.com" class="flex items-center gap-1.5 hover:text-accent-400 transition-colors">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        <span class="hidden sm:inline">info@mktmakina.com</span>
      </a>
    </div>
    <a href={lang === 'tr' ? `/en${currentPath}` : currentPath.replace(/^\/en/, '') || '/'}
       class="flex items-center gap-1.5 px-2.5 py-0.5 rounded text-xs font-medium border border-white/10 hover:border-accent-500/40 hover:text-accent-400 transition-all">
      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
      </svg>
      {lang === 'tr' ? 'EN' : 'TR'}
    </a>
  </div>
</div>

<!-- Main Navigation -->
<header class="bg-white/95 backdrop-blur-md sticky top-0 z-50 border-b border-steel-200/50" id="main-header">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center justify-between h-[72px]">
    <!-- Logo -->
    <a href={getLocalePath(lang, '/')} class="flex items-center gap-3 group">
      <div class="relative w-11 h-11 bg-navy-800 rounded-xl flex items-center justify-center overflow-hidden group-hover:shadow-lg transition-shadow">
        <span class="text-accent-500 font-heading font-bold text-base tracking-tight">MKT</span>
        <div class="absolute inset-0 bg-gradient-to-br from-accent-500/0 to-accent-500/10 group-hover:to-accent-500/20 transition-all"></div>
      </div>
      <div class="hidden sm:block">
        <span class="block font-heading text-navy-800 text-base font-semibold tracking-wider leading-tight">MAKİNA KALIP</span>
        <span class="block text-steel-400 text-[10px] tracking-[0.3em] uppercase font-medium">Takım</span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-0.5">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'relative px-3.5 py-2 text-[13px] font-medium tracking-wide uppercase transition-all rounded-lg',
            currentPath === item.href
              ? 'text-accent-600'
              : 'text-navy-800/70 hover:text-navy-800 hover:bg-steel-50',
          ]}
        >
          {t(lang, item.key)}
          {currentPath === item.href && (
            <span class="absolute bottom-0 left-3.5 right-3.5 h-0.5 bg-accent-500 rounded-full"></span>
          )}
        </a>
      ))}
      <a
        href={quoteHref}
        class="ml-4 px-6 py-2.5 bg-gradient-to-r from-accent-500 to-accent-600 text-white text-[13px] font-semibold uppercase tracking-wider rounded-lg hover:from-accent-600 hover:to-accent-700 transition-all shadow-md shadow-accent-500/15 hover:shadow-lg hover:shadow-accent-500/25"
      >
        {t(lang, 'nav.quote')}
      </a>
    </nav>

    <!-- Mobile Menu Button -->
    <button
      class="lg:hidden p-2 text-navy-800 hover:text-accent-600 transition-colors rounded-lg hover:bg-steel-50"
      id="mobile-menu-btn"
      aria-label="Menü"
    >
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div class="lg:hidden hidden bg-white border-t border-steel-100" id="mobile-menu">
    <nav class="px-4 py-5 space-y-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="block px-4 py-3 text-sm font-medium uppercase tracking-wide text-navy-800/70 hover:text-accent-600 hover:bg-accent-50 rounded-lg transition-colors"
        >
          {t(lang, item.key)}
        </a>
      ))}
      <a
        href={quoteHref}
        class="block mt-3 px-4 py-3.5 bg-gradient-to-r from-accent-500 to-accent-600 text-white text-sm font-semibold uppercase tracking-wider rounded-lg text-center shadow-md"
      >
        {t(lang, 'nav.quote')}
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  // Header shadow on scroll
  const header = document.getElementById('main-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.classList.add('shadow-md');
    } else {
      header?.classList.remove('shadow-md');
    }
  }, { passive: true });
</script>
