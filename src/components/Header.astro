---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;
const currentPath = Astro.url.pathname;

const navItemsTr = [
  { key: 'nav.home', href: '/' },
  { key: 'nav.about', href: '/kurumsal' },
  { key: 'nav.products', href: '/urunler' },
  { key: 'nav.machines', href: '/makina-parkimiz' },
  { key: 'nav.references', href: '/referanslar' },
  { key: 'nav.certificates', href: '/belgeler' },
  { key: 'nav.contact', href: '/iletisim' },
];

const navItemsEn = [
  { key: 'nav.home', href: '/en' },
  { key: 'nav.about', href: '/en/about' },
  { key: 'nav.products', href: '/en/products' },
  { key: 'nav.machines', href: '/en/machines' },
  { key: 'nav.references', href: '/en/references' },
  { key: 'nav.certificates', href: '/en/certificates' },
  { key: 'nav.contact', href: '/en/contact' },
];

const navItems = lang === 'en' ? navItemsEn : navItemsTr;
---

<!-- Top Info Bar -->
<div class="bg-navy-950 text-white/60 text-xs hidden sm:block">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 flex items-center justify-between h-8">
    <div class="flex items-center gap-5">
      <a href="tel:+902642761880" class="flex items-center gap-1.5 hover:text-accent-400 transition-colors">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        0 264 276 18 80
      </a>
      <span class="w-px h-3 bg-white/20"></span>
      <a href="mailto:info@mktmakina.com" class="hover:text-accent-400 transition-colors">info@mktmakina.com</a>
    </div>
    <div class="flex items-center gap-3">
      <span class="text-white/30">|</span>
      <a href={lang === 'tr' ? `/en${currentPath}` : currentPath.replace(/^\/en/, '') || '/'}
         class="font-medium hover:text-accent-400 transition-colors tracking-wider">
        {lang === 'tr' ? 'EN' : 'TR'}
      </a>
    </div>
  </div>
</div>

<!-- Main Header (V2 - shrink on scroll) -->
<header class="header-v2 is-top sticky top-0 z-50" id="main-header">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 flex items-center justify-between h-20 lg:h-[88px] transition-all duration-400" id="header-inner">
    <!-- Logo -->
    <a href={getLocalePath(lang, '/')} class="flex items-center gap-3 group shrink-0">
      <img src="/images/logo.png" alt="MKT Makina" class="header-logo h-10 lg:h-11 transition-all duration-400" />
      <div class="hidden sm:block leading-tight">
        <span class="block font-heading text-sm font-semibold tracking-[0.15em] header-brand transition-colors">MKT MAKİNA</span>
        <span class="block text-[10px] tracking-[0.25em] uppercase header-brand-sub transition-colors">Kalıp Takım</span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'nav-link relative px-3 xl:px-4 py-2 text-[12px] xl:text-[13px] font-medium tracking-wider uppercase transition-colors',
            currentPath === item.href && 'text-accent-500!',
          ]}
        >
          {t(lang, item.key)}
          {currentPath === item.href && (
            <span class="absolute bottom-0 left-3 right-3 h-[2px] bg-accent-500"></span>
          )}
        </a>
      ))}
    </nav>

    <!-- Right: CTA + Lang + Mobile -->
    <div class="flex items-center gap-3">
      <a
        href={lang === 'tr' ? '/iletisim' : '/en/contact'}
        class="hidden lg:inline-flex btn-primary text-xs py-2.5 px-5"
      >
        {t(lang, 'nav.quote')}
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>

      <!-- Language (mobile) -->
      <a href={lang === 'tr' ? `/en${currentPath}` : currentPath.replace(/^\/en/, '') || '/'}
         class="sm:hidden text-xs font-medium nav-link transition-colors px-2">
        {lang === 'tr' ? 'EN' : 'TR'}
      </a>

      <!-- Mobile Menu Toggle -->
      <button class="lg:hidden p-2 nav-link transition-colors relative z-[110]" id="mobile-menu-btn" aria-label="Menü">
        <svg class="w-6 h-6 menu-icon-open" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg class="w-6 h-6 menu-icon-close hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Fullscreen Mobile Menu Overlay -->
<div class="mobile-overlay" id="mobile-overlay">
  <nav class="flex flex-col items-center gap-1">
    {navItems.map((item) => (
      <a
        href={item.href}
        class:list={[
          'text-2xl font-heading font-semibold uppercase tracking-wider py-3 transition-colors',
          currentPath === item.href ? 'text-accent-500' : 'text-white/70 hover:text-accent-400',
        ]}
      >
        {t(lang, item.key)}
      </a>
    ))}
    <div class="mt-6 pt-6 border-t border-white/10">
      <a
        href={lang === 'tr' ? '/iletisim' : '/en/contact'}
        class="btn-primary"
      >
        {t(lang, 'nav.quote')}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>
  </nav>
</div>

<script>
  const header = document.getElementById('main-header') as HTMLElement;
  const headerInner = document.getElementById('header-inner') as HTMLElement;
  const hero = document.getElementById('hero');
  const btn = document.getElementById('mobile-menu-btn');
  const overlay = document.getElementById('mobile-overlay');
  const openIcon = btn?.querySelector('.menu-icon-open');
  const closeIcon = btn?.querySelector('.menu-icon-close');

  // Shrink header on scroll
  if (!hero) {
    header?.classList.remove('is-top');
    header?.classList.add('no-hero');
  } else {
    const onScroll = () => {
      if (window.scrollY > 80) {
        header?.classList.remove('is-top');
        header?.classList.add('is-scrolled');
        headerInner && (headerInner.style.height = '64px');
      } else {
        header?.classList.add('is-top');
        header?.classList.remove('is-scrolled');
        headerInner && (headerInner.style.height = '');
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // Fullscreen mobile menu
  btn?.addEventListener('click', () => {
    const isOpen = overlay?.classList.contains('is-open');
    if (isOpen) {
      overlay?.classList.remove('is-open');
      openIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      document.body.style.overflow = '';
    } else {
      overlay?.classList.add('is-open');
      openIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
  });
</script>
