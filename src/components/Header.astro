---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;
const currentPath = Astro.url.pathname;

const navItemsTr = [
  { key: 'nav.home', href: '/' },
  { key: 'nav.about', href: '/kurumsal' },
  { key: 'nav.products', href: '/urunler' },
  { key: 'nav.machines', href: '/makina-parkimiz' },
  { key: 'nav.references', href: '/referanslar' },
  { key: 'nav.certificates', href: '/belgeler' },
  { key: 'nav.contact', href: '/iletisim' },
];

const navItemsEn = [
  { key: 'nav.home', href: '/en' },
  { key: 'nav.about', href: '/en/about' },
  { key: 'nav.products', href: '/en/products' },
  { key: 'nav.machines', href: '/en/machines' },
  { key: 'nav.references', href: '/en/references' },
  { key: 'nav.certificates', href: '/en/certificates' },
  { key: 'nav.contact', href: '/en/contact' },
];

const navItems = lang === 'en' ? navItemsEn : navItemsTr;
---

<!-- Top Info Bar -->
<div class="bg-navy-950 text-white/60 text-xs hidden sm:block">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 flex items-center justify-between h-8">
    <div class="flex items-center gap-5">
      <a href="tel:+902642761880" class="flex items-center gap-1.5 hover:text-accent-400 transition-colors">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        0 264 276 18 80
      </a>
      <span class="w-px h-3 bg-white/20"></span>
      <a href="mailto:info@mktmakina.com" class="hover:text-accent-400 transition-colors">info@mktmakina.com</a>
    </div>
    <div class="flex items-center gap-3">
      <span class="text-white/30">|</span>
      <a href={lang === 'tr' ? `/en${currentPath}` : currentPath.replace(/^\/en/, '') || '/'}
         class="font-medium hover:text-accent-400 transition-colors tracking-wider">
        {lang === 'tr' ? 'EN' : 'TR'}
      </a>
    </div>
  </div>
</div>

<!-- Main Header (V3 - Volo style with hamburger overlay) -->
<header class="header-v2 is-top sticky top-0 z-50" id="main-header">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 flex items-center justify-between h-20 lg:h-[88px] transition-all duration-400" id="header-inner">
    <!-- Logo -->
    <a href={getLocalePath(lang, '/')} class="flex items-center gap-3 group shrink-0 relative z-[110]">
      <img src="/images/logo.png" alt="MKT Makina" class="header-logo h-10 lg:h-11 transition-all duration-400" id="header-logo" />
      <div class="hidden sm:block leading-tight">
        <span class="block font-heading text-sm font-semibold tracking-[0.15em] header-brand transition-colors">MKT MAKİNA</span>
        <span class="block text-[10px] tracking-[0.25em] uppercase header-brand-sub transition-colors">Kalıp Takım</span>
      </div>
    </a>

    <!-- Right: CTA + Lang + Hamburger -->
    <div class="flex items-center gap-4">
      <!-- Language switcher -->
      <a href={lang === 'tr' ? `/en${currentPath}` : currentPath.replace(/^\/en/, '') || '/'}
         class="hidden sm:inline-flex text-xs font-medium nav-link transition-colors tracking-wider relative z-[110]">
        {lang === 'tr' ? 'EN' : 'TR'}
      </a>

      <!-- Language (mobile only) -->
      <a href={lang === 'tr' ? `/en${currentPath}` : currentPath.replace(/^\/en/, '') || '/'}
         class="sm:hidden text-xs font-medium nav-link transition-colors px-2 relative z-[110]">
        {lang === 'tr' ? 'EN' : 'TR'}
      </a>

      <!-- Hamburger Toggle (always visible — Volo/TapTap style) -->
      <button class="hamburger p-2 nav-link transition-colors relative z-[110]" id="menu-toggle" aria-label="Menü">
        <span class="hamburger-line mb-1.5"></span>
        <span class="hamburger-line mb-1.5"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>
</header>

<!-- Fullscreen Overlay Menu (desktop + mobile) -->
<div class="fullscreen-overlay" id="fullscreen-overlay">
  <nav class="flex flex-col items-center gap-1">
    {navItems.map((item) => (
      <a
        href={item.href}
        class:list={[
          'overlay-link text-2xl sm:text-3xl lg:text-5xl font-heading font-bold uppercase tracking-wider py-2 sm:py-3 lg:py-4 transition-colors',
          currentPath === item.href ? 'text-accent-500' : 'text-white/70 hover:text-accent-400',
        ]}
      >
        {t(lang, item.key)}
      </a>
    ))}
  </nav>

  <!-- Overlay Footer: Contact Info -->
  <div class="overlay-footer mt-10 lg:mt-14 pt-8 border-t border-white/10 text-center">
    <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-6 text-white/40 text-sm mb-4">
      <a href="tel:+902642761880" class="flex items-center gap-2 hover:text-accent-400 transition-colors">
        <svg class="w-4 h-4 text-accent-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        +90 264 276 18 80
      </a>
      <span class="hidden sm:inline w-px h-4 bg-white/20"></span>
      <a href="mailto:info@mktmakina.com" class="flex items-center gap-2 hover:text-accent-400 transition-colors">
        <svg class="w-4 h-4 text-accent-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
        info@mktmakina.com
      </a>
    </div>
    <p class="text-white/20 text-xs tracking-wider uppercase">{t(lang, 'footer.address')}</p>
  </div>
</div>

<script>
  const header = document.getElementById('main-header') as HTMLElement;
  const headerInner = document.getElementById('header-inner') as HTMLElement;
  const hero = document.getElementById('hero');
  const toggle = document.getElementById('menu-toggle');
  const overlay = document.getElementById('fullscreen-overlay');

  // Shrink header on scroll — rAF throttled
  if (!hero) {
    header?.classList.remove('is-top');
    header?.classList.add('no-hero');
  } else {
    let scrolled = false;
    let hdrTick = false;
    const onScroll = () => {
      if (hdrTick) return;
      hdrTick = true;
      requestAnimationFrame(() => {
        const isDown = window.scrollY > 80;
        if (isDown !== scrolled) {
          scrolled = isDown;
          header?.classList.toggle('is-top', !isDown);
          header?.classList.toggle('is-scrolled', isDown);
          if (headerInner) headerInner.style.height = isDown ? '64px' : '';
        }
        hdrTick = false;
      });
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // Fullscreen overlay toggle (Volo/TapTap style)
  toggle?.addEventListener('click', () => {
    const isOpen = overlay?.classList.contains('is-open');
    overlay?.classList.toggle('is-open', !isOpen);
    toggle.classList.toggle('is-active', !isOpen);
    document.body.style.overflow = isOpen ? '' : 'hidden';

    // When overlay opens, make hamburger white; header brand white
    if (!isOpen) {
      toggle.style.color = 'white';
    } else {
      toggle.style.color = '';
    }
  });

  // Close overlay on link click
  overlay?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      overlay?.classList.remove('is-open');
      toggle?.classList.remove('is-active');
      document.body.style.overflow = '';
      if (toggle) toggle.style.color = '';
    });
  });
</script>
