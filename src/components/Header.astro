---
import { t, languages, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
  hasHero?: boolean;
}

const { lang = 'tr', hasHero = false } = Astro.props;
const currentPath = Astro.url.pathname;

// Route map: all 4 languages
const routes: Record<Lang, { label: string; href: string }[]> = {
  tr: [
    { label: t('tr', 'nav.home'),         href: '/' },
    { label: t('tr', 'nav.about'),        href: '/kurumsal' },
    { label: t('tr', 'nav.products'),     href: '/urunler' },
    { label: t('tr', 'nav.machines'),     href: '/makina-parkimiz' },
    { label: t('tr', 'nav.references'),   href: '/referanslar' },
    { label: t('tr', 'nav.certificates'), href: '/belgeler' },
    { label: t('tr', 'nav.contact'),      href: '/iletisim' },
  ],
  en: [
    { label: t('en', 'nav.home'),         href: '/en' },
    { label: t('en', 'nav.about'),        href: '/en/about' },
    { label: t('en', 'nav.products'),     href: '/en/products' },
    { label: t('en', 'nav.machines'),     href: '/en/machines' },
    { label: t('en', 'nav.references'),   href: '/en/references' },
    { label: t('en', 'nav.certificates'), href: '/en/certificates' },
    { label: t('en', 'nav.contact'),      href: '/en/contact' },
  ],
  de: [
    { label: t('de', 'nav.home'),         href: '/de' },
    { label: t('de', 'nav.about'),        href: '/de/about' },
    { label: t('de', 'nav.products'),     href: '/de/products' },
    { label: t('de', 'nav.machines'),     href: '/de/machines' },
    { label: t('de', 'nav.references'),   href: '/de/references' },
    { label: t('de', 'nav.certificates'), href: '/de/certificates' },
    { label: t('de', 'nav.contact'),      href: '/de/contact' },
  ],
  ar: [
    { label: t('ar', 'nav.home'),         href: '/ar' },
    { label: t('ar', 'nav.about'),        href: '/ar/about' },
    { label: t('ar', 'nav.products'),     href: '/ar/products' },
    { label: t('ar', 'nav.machines'),     href: '/ar/machines' },
    { label: t('ar', 'nav.references'),   href: '/ar/references' },
    { label: t('ar', 'nav.certificates'), href: '/ar/certificates' },
    { label: t('ar', 'nav.contact'),      href: '/ar/contact' },
  ],
};

const navItems = routes[lang];

// Slug mapping: TR slugs ↔ shared slugs for EN/DE/AR
const trToShared: Record<string, string> = {
  'kurumsal': 'about',
  'urunler': 'products',
  'makina-parkimiz': 'machines',
  'belgeler': 'certificates',
  'referanslar': 'references',
  'iletisim': 'contact',
  'haberler': 'news',
  'insan-kaynaklari': 'careers',
};
const sharedToTr: Record<string, string> = Object.fromEntries(
  Object.entries(trToShared).map(([tr, sh]) => [sh, tr])
);

// Given current path, return equivalent path for target language
function pathForLang(from: Lang, to: Lang, path: string): string {
  if (from === to) return path;

  // Strip trailing slash + source lang prefix to get the slug
  let slug = path.replace(/\/$/, '');
  if (from === 'tr') {
    slug = slug.replace(/^\//, '') || ''; // e.g. "kurumsal"
  } else {
    slug = slug.replace(new RegExp(`^\\/${from}\\/?`), ''); // e.g. "about"
  }
  slug = slug.replace(/\/$/, ''); // clean any remaining trailing slash

  // Normalise slug (TR → shared, shared → shared)
  const sharedSlug = from === 'tr' ? (trToShared[slug] ?? slug) : slug;
  // shared → target
  const targetSlug = to === 'tr' ? (sharedToTr[sharedSlug] ?? sharedSlug) : sharedSlug;

  if (to === 'tr') {
    return targetSlug ? `/${targetSlug}` : '/';
  }
  return targetSlug ? `/${to}/${targetSlug}` : `/${to}`;
}

const langLabels: Record<Lang, string> = { tr: 'TR', en: 'EN', de: 'DE', ar: 'AR' };


const quoteHref: Record<Lang, string> = {
  tr: '/iletisim',
  en: '/en/contact',
  de: '/de/contact',
  ar: '/ar/contact',
};

const allLangs = Object.keys(languages) as Lang[];
---

<!-- Top Bar -->
<div class="top-bar hidden md:block">
  <div class="container-custom flex justify-between items-center">
    <div class="flex items-center gap-6">
      <a href="tel:+902642761880" class="flex items-center gap-1.5 hover:text-accent transition-colors">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        +90 264 276 18 80
      </a>
      <span class="w-px h-3 bg-white/20"></span>
      <a href="mailto:info@mktmakina.com" class="hover:text-accent transition-colors">info@mktmakina.com</a>
    </div>
    <!-- Desktop language dropdown -->
    <div class="lang-switcher group relative">
      <button class="flex items-center gap-1 font-semibold text-white/90 hover:text-accent uppercase text-xs tracking-wider transition-colors py-1" aria-haspopup="true">
        {langLabels[lang]}
        <svg class="w-3 h-3 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div class="lang-dropdown absolute right-0 top-full mt-1 min-w-[100px] rounded border border-white/10 bg-primary-dark shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all duration-150 z-[200]">
        {allLangs.map((l) => (
          <a
            href={pathForLang(lang, l, currentPath)}
            class:list={[
              'block px-3 py-2 text-xs tracking-wider uppercase transition-colors',
              l === lang
                ? 'text-accent font-semibold'
                : 'text-white/70 hover:text-accent hover:bg-white/5',
            ]}
          >
            {languages[l]}
          </a>
        ))}
      </div>
    </div>
  </div>
</div>

<!-- Main Header -->
<header
  class:list={['header-main fixed w-full z-50 md:top-[32px] top-0', hasHero ? 'is-top' : 'no-hero']}
  id="mainHeader"
  data-has-hero={String(hasHero)}
>
  <div class="container-custom flex items-center justify-between h-[72px] transition-all duration-300" id="headerInner">
    <!-- Logo -->
    <a href={getLocalePath(lang, '/')} class="flex items-center gap-3 shrink-0 relative z-[110]">
      <img src="/images/logo.png" alt="MKT Makina" class="h-10 lg:h-11 header-logo transition-all duration-300" />
      <div class="hidden sm:block leading-tight">
        <span class="block font-heading text-sm font-semibold tracking-[0.12em] logo-text transition-colors">MKT MAKINA</span>
        <span class="block text-[10px] tracking-[0.2em] uppercase logo-sub transition-colors">Kalip Takim</span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-0.5">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'nav-link px-3 py-2 text-[0.78rem] font-medium uppercase tracking-wider transition-colors',
            currentPath === item.href ? 'text-accent' : '',
          ]}
        >
          {item.label}
        </a>
      ))}
      <a
        href={quoteHref[lang]}
        class="ml-3 btn-primary !py-2 !px-5 !text-[0.7rem]"
      >
        {t(lang, 'nav.quote')}
      </a>
    </nav>

    <!-- Mobile: Lang + Hamburger -->
    <div class="flex items-center gap-3 lg:hidden">
      <!-- Mobile lang switcher - inline links -->
      <div class="flex items-center gap-1 md:hidden">
        {allLangs.map((l) => (
          <a
            href={pathForLang(lang, l, currentPath)}
            class:list={[
              'text-[10px] font-semibold uppercase tracking-wider px-1.5 py-1 transition-colors',
              l === lang ? 'text-accent' : 'nav-link opacity-50 hover:opacity-100',
            ]}
          >
            {langLabels[l]}
          </a>
        ))}
      </div>
      <button class="hamburger p-2 relative z-[110]" id="menuToggle" aria-label="Menu">
        <span class="flex flex-col gap-1.5">
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div class="mobile-menu" id="mobileMenu">
  <button class="absolute top-6 right-6 text-white/60 hover:text-white p-2 z-[110]" id="closeMenu" aria-label="Close">
    <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <nav class="flex flex-col items-center gap-5">
    {navItems.map((item) => (
      <a
        href={item.href}
        class:list={[
          'menu-link text-2xl font-heading font-semibold uppercase tracking-wider transition-colors',
          currentPath === item.href ? 'text-accent' : 'text-white/70 hover:text-accent',
        ]}
      >
        {item.label}
      </a>
    ))}
  </nav>

  <!-- Mobile language row -->
  <div class="absolute bottom-20 flex items-center gap-3 justify-center w-full px-6">
    {allLangs.map((l) => (
      <a
        href={pathForLang(lang, l, currentPath)}
        class:list={[
          'px-3 py-1.5 rounded border text-xs font-semibold uppercase tracking-wider transition-colors',
          l === lang
            ? 'border-accent text-accent'
            : 'border-white/15 text-white/50 hover:text-accent hover:border-accent',
        ]}
      >
        {langLabels[l]}
      </a>
    ))}
  </div>

  <div class="absolute bottom-8 text-center space-y-2">
    <a href="tel:+902642761880" class="block text-white/50 text-sm hover:text-accent transition-colors">+90 264 276 18 80</a>
    <a href="mailto:info@mktmakina.com" class="block text-white/50 text-sm hover:text-accent transition-colors">info@mktmakina.com</a>
  </div>
</div>

<!-- Spacer for non-hero pages -->
{!hasHero && <div class="h-[72px] md:h-[104px]"></div>}
{hasHero && <div class="hidden md:block h-[32px]"></div>}

<script>
  const header = document.getElementById('mainHeader');
  const hamburger = document.getElementById('menuToggle');
  const mobileMenu = document.getElementById('mobileMenu');
  const closeBtn = document.getElementById('closeMenu');
  const hasHero = header?.dataset.hasHero === 'true';

  // Scroll behavior for hero pages
  if (hasHero && header) {
    let scrolled = false;
    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const isDown = window.scrollY > 80;
        if (isDown !== scrolled) {
          scrolled = isDown;
          header.classList.toggle('is-top', !isDown);
          header.classList.toggle('is-scrolled', isDown);
        }
        ticking = false;
      });
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // Mobile menu toggle
  const toggleMenu = () => {
    const isOpen = mobileMenu?.classList.contains('is-open');
    mobileMenu?.classList.toggle('is-open', !isOpen);
    hamburger?.classList.toggle('is-active', !isOpen);
    document.body.style.overflow = !isOpen ? 'hidden' : '';
  };

  hamburger?.addEventListener('click', toggleMenu);
  closeBtn?.addEventListener('click', toggleMenu);
  mobileMenu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => {
    mobileMenu?.classList.remove('is-open');
    hamburger?.classList.remove('is-active');
    document.body.style.overflow = '';
  }));
</script>
