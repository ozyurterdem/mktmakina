---
import { t, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;
---

<!-- Light CTA — subtle accent bg, not heavy -->
<section class="relative py-20 lg:py-24 bg-surface overflow-hidden">
  <!-- Subtle accent tint -->
  <div class="absolute inset-0 bg-gradient-to-br from-accent/[0.04] to-accent/[0.02]"></div>

  <div class="relative z-10 container-custom">
    <div class="max-w-3xl mx-auto text-center">
      <div data-animate="fade-up">
        <div class="section-label justify-center">{lang === 'tr' ? 'Iletisim' : 'Contact'}</div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-primary mb-6">
          {lang === 'tr' ? 'Projeniz Icin Teklif Alin' : 'Get a Quote for Your Project'}
        </h2>
        <p class="text-text-light text-base sm:text-lg leading-relaxed mb-10 max-w-xl mx-auto">
          {lang === 'tr'
            ? 'Havacilik, otomotiv ve savunma sanayii icin hassas parca uretiminde cozum ortaginiz.'
            : 'Your solution partner in precision parts manufacturing for aviation, automotive and defense industries.'}
        </p>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center" data-animate="fade-up" data-delay="200">
        <a href={lang === 'tr' ? '/iletisim' : '/en/contact'} class="btn-primary">
          {t(lang, 'hero.cta')}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="tel:+902642761880" class="btn-outline-dark">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          0 264 276 18 80
        </a>
      </div>
    </div>
  </div>
</section>
