---
import { t, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const ctaLabel = ({tr:'İletişim', en:'Contact', de:'Kontakt', ar:'اتصل بنا'} as Record<string,string>)[lang];
const ctaTitle = ({tr:'Projeniz İçin Teklif Alın', en:'Get a Quote for Your Project', de:'Angebot für Ihr Projekt anfordern', ar:'احصل على عرض سعر لمشروعك'} as Record<string,string>)[lang];
const ctaSubtitle = ({tr:'Havacılık ve otomotiv sanayii için hassas parça üretiminde çözüm ortağınız.', en:'Your solution partner in precision parts manufacturing for aviation and automotive industries.', de:'Ihr Lösungspartner für die Präzisionsteileherstellung in Luft- und Raumfahrt sowie Automobil.', ar:'شريكك في تصنيع القطع الدقيقة لصناعتَي الطيران والسيارات.'} as Record<string,string>)[lang];
const ctaHref = ({tr:'/iletisim', en:'/en/contact', de:'/de/contact', ar:'/ar/contact'} as Record<string,string>)[lang];
---

<section class="relative py-24 lg:py-32 overflow-hidden">
  <div class="absolute inset-0">
    <img src="/images/slide3.jpg?v=20260429" alt="" class="w-full h-full object-cover" loading="lazy" />
    <div class="absolute inset-0 bg-gradient-to-b from-[#060a12]/85 via-[#060a12]/75 to-[#060a12]/90"></div>
    <div class="absolute inset-0 grid-overlay"></div>
  </div>

  <div class="relative z-10 container-custom">
    <div class="max-w-3xl mx-auto text-center">
      <div data-animate="fade-up">
        <div class="section-label justify-center">{ctaLabel}</div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white mb-6">
          {ctaTitle}
        </h2>
        <p class="text-white/40 text-base sm:text-lg leading-relaxed mb-12 max-w-xl mx-auto">
          {ctaSubtitle}
        </p>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center" data-animate="fade-up" data-delay="200">
        <a href={ctaHref} class="btn-primary">
          {t(lang, 'hero.cta')}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="tel:+902642761880" class="btn-outline">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          0 264 276 18 80
        </a>
      </div>
    </div>
  </div>
</section>
