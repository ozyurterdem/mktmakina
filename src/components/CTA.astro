---
import { t, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;
---

<!-- CTA Section with parallax background -->
<section class="relative py-24 lg:py-32 overflow-hidden">
  <!-- Background with parallax-like effect -->
  <div class="absolute inset-0 bg-navy-800">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: repeating-linear-gradient(45deg, transparent, transparent 60px, white 60px, white 61px);"></div>
    <!-- Accent glow -->
    <div class="absolute -top-20 right-0 w-[600px] h-[600px] bg-accent-500/8 rounded-full blur-[200px]"></div>
    <div class="absolute -bottom-20 left-0 w-[400px] h-[400px] bg-accent-500/5 rounded-full blur-[150px]"></div>
  </div>

  <div class="relative z-10 max-w-3xl mx-auto px-6 lg:px-10 text-center">
    <div data-animate="fade-up">
      <div class="section-label justify-center text-accent-400">{lang === 'tr' ? 'İletişim' : 'Contact'}</div>
      <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6">
        {lang === 'tr'
          ? 'Projeniz İçin Teklif Alın'
          : 'Get a Quote for Your Project'}
      </h2>
      <p class="text-white/40 text-base sm:text-lg leading-relaxed mb-10 max-w-xl mx-auto">
        {lang === 'tr'
          ? 'Havacılık, otomotiv ve savunma sanayii için hassas parça üretiminde çözüm ortağınız.'
          : 'Your solution partner in precision parts manufacturing for aviation, automotive and defense industries.'}
      </p>
    </div>

    <div class="flex flex-col sm:flex-row gap-4 justify-center" data-animate="fade-up" data-delay="200">
      <a
        href={lang === 'tr' ? '/iletisim' : '/en/contact'}
        class="btn-primary"
      >
        {t(lang, 'hero.cta')}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
      <a
        href="tel:+902642761880"
        class="btn-ghost border-white/20"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        0 264 276 18 80
      </a>
    </div>
  </div>
</section>
