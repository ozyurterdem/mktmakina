---
import { t, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;
---

<section class="relative py-20 lg:py-28 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0">
    <img
      src="/images/slide3.jpg"
      alt="MKT Makina"
      class="w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-navy-950/90"></div>
  </div>

  <!-- Accent line -->
  <div class="absolute top-0 left-0 right-0 h-[3px] bg-accent-500"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-3xl mx-auto px-6 text-center reveal">
    <span class="text-accent-500 text-xs font-semibold uppercase tracking-[0.2em] mb-3 block">{lang === 'tr' ? 'İletişim' : 'Contact'}</span>

    <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4">
      {t(lang, 'cta.title')}
    </h2>
    <div class="accent-bar mx-auto mb-6"></div>
    <p class="text-white/50 text-base sm:text-lg mb-10 max-w-xl mx-auto leading-relaxed">
      {t(lang, 'cta.subtitle')}
    </p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a
        href={lang === 'tr' ? '/iletisim' : '/en/contact'}
        class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-accent-500 text-white text-sm font-semibold uppercase tracking-wider hover:bg-accent-600 transition-colors"
      >
        {t(lang, 'cta.button')}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
      <a
        href="tel:+902642761880"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/20 text-white text-sm font-semibold uppercase tracking-wider hover:bg-white/10 transition-colors"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        {t(lang, 'cta.call')}
      </a>
    </div>
  </div>
</section>
