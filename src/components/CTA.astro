---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;
---

<section class="relative py-20 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0">
    <img
      src="https://mktmakina.com/images/slide3.jpg"
      alt="MKT Makina"
      class="w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-navy-900/90"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto px-4 text-center reveal">
    <div class="accent-bar mx-auto mb-6"></div>
    <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4">
      {t(lang, 'cta.title')}
    </h2>
    <p class="text-steel-300 text-lg mb-10 max-w-2xl mx-auto">
      {t(lang, 'cta.subtitle')}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={getLocalePath(lang, '/talep-formu')}
        class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-accent-500 text-white font-semibold uppercase tracking-wide rounded-md hover:bg-accent-600 transition-all shadow-lg text-sm"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        {t(lang, 'cta.button')}
      </a>
      <a
        href="tel:+902642761880"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-white/30 text-white font-semibold uppercase tracking-wide rounded-md hover:bg-white/10 transition-all text-sm"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {t(lang, 'cta.call')}
      </a>
    </div>
  </div>
</section>
