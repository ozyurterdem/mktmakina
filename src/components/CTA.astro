---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;
---

<section class="relative py-28 lg:py-36 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0">
    <img
      src="/images/slide3.jpg"
      alt="MKT Makina"
      class="w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950/95 via-navy-900/90 to-navy-800/85"></div>
  </div>

  <!-- Decorative -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] border border-accent-500/5 rounded-full"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] border border-accent-500/8 rounded-full"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[200px] h-[200px] border border-accent-500/10 rounded-full"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 text-center reveal">
    <div class="inline-flex items-center gap-2.5 px-4 py-2 mb-8 glass rounded-full">
      <div class="w-2 h-2 rounded-full bg-accent-500 animate-pulse"></div>
      <span class="text-white/70 text-sm font-medium tracking-wide">{lang === 'tr' ? 'Hemen Başlayın' : 'Get Started'}</span>
    </div>

    <h2 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-5 tracking-tight">
      {t(lang, 'cta.title')}
    </h2>
    <div class="accent-bar mx-auto mb-6"></div>
    <p class="text-steel-300/80 text-lg sm:text-xl mb-12 max-w-2xl mx-auto font-light leading-relaxed">
      {t(lang, 'cta.subtitle')}
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={lang === 'tr' ? '/iletisim' : '/en/contact'}
        class="group inline-flex items-center justify-center gap-3 px-9 py-5 bg-gradient-to-r from-accent-500 to-accent-600 text-white font-semibold uppercase tracking-wider rounded-lg hover:from-accent-600 hover:to-accent-700 transition-all shadow-2xl shadow-accent-500/25 hover:shadow-accent-500/40 text-sm"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        {t(lang, 'cta.button')}
        <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a
        href="tel:+902642761880"
        class="group inline-flex items-center justify-center gap-3 px-9 py-5 glass text-white font-semibold uppercase tracking-wider rounded-lg hover:bg-white/15 transition-all text-sm"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {t(lang, 'cta.call')}
      </a>
    </div>
  </div>
</section>
