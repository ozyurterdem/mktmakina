---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const certLabel = ({tr:'Sertifikalı', en:'Certified', de:'Zertifiziert', ar:'معتمد'} as Record<string,string>)[lang];
const aboutLabel = ({tr:'Hakkımızda', en:'About Us', de:'Über uns', ar:'معلومات عنا'} as Record<string,string>)[lang];
const aboutHref = ({tr:'/kurumsal', en:'/en/about', de:'/de/about', ar:'/ar/about'} as Record<string,string>)[lang];

const features = ({
  tr: [
    'Eksiksiz ERP/MRP Entegrasyonu',
    'AS9100 Kalite Yönetim Sistemi',
    'İleri CAD/CAM Yazılım Altyapısı',
    'Hassas Ölçüm ve Kontrol',
  ],
  en: [
    'Complete ERP/MRP Integration',
    'AS9100 Quality Management System',
    'Advanced CAD/CAM Software',
    'Precision Measurement & Control',
  ],
  de: [
    'Vollständige ERP/MRP-Integration',
    'AS9100 Qualitätsmanagementsystem',
    'Erweiterte CAD/CAM-Software',
    'Präzisionsmessung & Kontrolle',
  ],
  ar: [
    'تكامل ERP/MRP الكامل',
    'نظام إدارة الجودة AS9100',
    'برنامج CAD/CAM المتقدم',
    'القياس والتحكم الدقيق',
  ],
} as Record<string, string[]>)[lang] ?? [];

const photos = [
  { src: '/images/slide1.jpg', alt: 'CNC Üretim' },
  { src: '/images/slide2.jpg', alt: 'Makina Parkı' },
  { src: '/images/slide3.jpg', alt: 'Kalıp Üretimi' },
  { src: '/images/categories/aparatlar_7.jpg', alt: 'Aparat Üretimi' },
  { src: '/images/categories/fikstur_8.jpg', alt: 'Fikstür' },
  { src: '/images/categories/kaliplar_12.jpg', alt: 'Kalıp' },
];
---

<section class="relative section-padding overflow-hidden noise-overlay" id="about">
  <div class="absolute inset-0 bg-gradient-to-b from-primary-dark via-primary to-primary-dark"></div>

  <div class="relative z-10 container-custom">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-20 items-center">

      <!-- Left: Photo Grid -->
      <div class="relative" data-animate="fade-right" data-delay="200">
        <div class="grid grid-cols-2 gap-3">
          <div class="space-y-3">
            <div class="aspect-[3/4] overflow-hidden">
              <img src={photos[0].src} alt={photos[0].alt} class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
            </div>
            <div class="aspect-square overflow-hidden">
              <img src={photos[2].src} alt={photos[2].alt} class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
            </div>
          </div>
          <div class="space-y-3 pt-8">
            <div class="aspect-square overflow-hidden">
              <img src={photos[1].src} alt={photos[1].alt} class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
            </div>
            <div class="aspect-[3/4] overflow-hidden">
              <img src={photos[3].src} alt={photos[3].alt} class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
            </div>
          </div>
        </div>

        <!-- Floating badge -->
        <div class="absolute -bottom-4 -right-4 glass-card px-5 py-4 hidden sm:flex items-center gap-3" data-animate="zoom-in" data-delay="500">
          <div class="w-10 h-10 bg-accent flex items-center justify-center">
            <svg class="w-5 h-5 text-primary-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <div>
            <div class="font-heading text-sm font-bold text-white">AS9100D</div>
            <div class="text-white/40 text-xs">{certLabel}</div>
          </div>
        </div>
      </div>

      <!-- Right: Content -->
      <div>
        <div data-animate="fade-up">
          <div class="section-label">{aboutLabel}</div>
          <h2 class="text-3xl sm:text-4xl lg:text-[2.75rem] font-heading font-bold text-white mb-6">
            {t(lang, 'about.title')}
          </h2>
        </div>

        <div class="w-16 h-px bg-accent/30 mb-8" data-animate="fade-up" data-delay="100"></div>

        <p class="text-text-light text-base leading-relaxed mb-10" data-animate="fade-up" data-delay="200">
          {t(lang, 'about.text')}
        </p>

        <!-- Features -->
        <div class="space-y-4 mb-10">
          {features.map((feat, i) => (
            <div
              class="group flex items-center gap-4 py-3 border-b border-white/[0.04] hover:border-accent/20 transition-colors"
              data-animate="fade-up"
              data-delay={String((i + 3) * 100)}
            >
              <span class="w-8 h-8 flex items-center justify-center bg-accent/10 text-accent text-xs font-mono font-bold shrink-0 group-hover:bg-accent group-hover:text-primary-dark transition-all duration-300">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span class="text-text text-sm font-medium">{feat}</span>
            </div>
          ))}
        </div>

        <div data-animate="fade-up" data-delay="600">
          <a href={aboutHref} class="btn-outline">
            {t(lang, 'about.more')}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
