---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const values = lang === 'tr'
  ? [
      { title: 'Yüksek Kalite', desc: 'Havacılık standartlarında üretim' },
      { title: 'Son Teknoloji', desc: 'İleri CNC ve yazılım altyapısı' },
      { title: 'Özel Çözümler', desc: 'Müşteriye özgü mühendislik' },
      { title: 'AS9100', desc: 'Sertifikalı kalite yönetim sistemi' },
    ]
  : [
      { title: 'High Quality', desc: 'Aviation-grade manufacturing' },
      { title: 'Latest Tech', desc: 'Advanced CNC and software' },
      { title: 'Custom Solutions', desc: 'Customer-specific engineering' },
      { title: 'AS9100', desc: 'Certified quality management' },
    ];
---

<section class="section-padding bg-steel-50" id="about">
  <div class="max-w-[1400px] mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Image Side -->
      <div class="relative reveal-left">
        <div class="relative overflow-hidden">
          <img
            src="/images/slide2.jpg"
            alt="MKT Makina Üretim"
            class="w-full aspect-[4/3] object-cover"
            loading="lazy"
          />
          <!-- Accent border bottom-left -->
          <div class="absolute bottom-0 left-0 w-24 h-1 bg-accent-500"></div>
        </div>

        <!-- Floating stat card -->
        <div class="absolute -bottom-6 right-4 sm:right-8 bg-navy-800 text-white px-6 py-5 shadow-xl">
          <div class="font-heading text-3xl lg:text-4xl font-bold text-accent-500">2007</div>
          <div class="text-white/40 text-xs uppercase tracking-[0.2em] mt-1">{t(lang, 'stats.since')}</div>
        </div>
      </div>

      <!-- Text Side -->
      <div class="reveal-right">
        <span class="text-accent-500 text-xs font-semibold uppercase tracking-[0.2em] mb-2 block">{lang === 'tr' ? 'Hakkımızda' : 'About Us'}</span>
        <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-navy-800 mb-4">
          {t(lang, 'about.title')}
        </h2>
        <div class="accent-bar mb-6"></div>
        <p class="text-steel-600 text-base leading-relaxed mb-10">
          {t(lang, 'about.text')}
        </p>

        <!-- Values 2x2 grid -->
        <div class="grid grid-cols-2 gap-4 mb-10">
          {values.map((item, i) => (
            <div class={`reveal delay-${i + 1} p-5 bg-white border border-steel-200 hover:border-accent-500/30 transition-colors`}>
              <h3 class="font-heading text-sm font-semibold text-navy-800 mb-1 tracking-wide">{item.title}</h3>
              <p class="text-steel-500 text-xs leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>

        <a
          href={getLocalePath(lang, '/kurumsal')}
          class="inline-flex items-center gap-2 px-6 py-3 bg-navy-800 text-white text-sm font-semibold uppercase tracking-wider hover:bg-navy-700 transition-colors"
        >
          {t(lang, 'about.more')}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </div>
  </div>
</section>
