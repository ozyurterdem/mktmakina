---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const principles = lang === 'tr'
  ? [
      { title: 'Yüksek Kalite', desc: 'Müşteri gereksinimlerini karşılayan yüksek kalite ürünler' },
      { title: 'Son Teknoloji', desc: 'En güncel ekipman, alet ve yazılım programları' },
      { title: 'Özel Çözümler', desc: 'Her müşteriye özgü mühendislik çözümleri' },
      { title: 'Kalite Sistemi', desc: 'İleri endüstriyel standartlara uygun yönetim sistemi' },
    ]
  : [
      { title: 'High Quality', desc: 'Products meeting customer requirements' },
      { title: 'Latest Tech', desc: 'Cutting-edge equipment, tools and software' },
      { title: 'Custom Solutions', desc: 'Customer-specific engineering solutions' },
      { title: 'Quality System', desc: 'Management system complying with advanced standards' },
    ];
---

<section class="section-padding bg-steel-50 relative overflow-hidden" id="about">
  <!-- Background decoration -->
  <div class="absolute top-0 right-0 w-1/2 h-full opacity-[0.03]">
    <svg viewBox="0 0 400 400" class="w-full h-full">
      <circle cx="200" cy="200" r="180" fill="none" stroke="currentColor" stroke-width="0.5" class="text-navy-800" />
      <circle cx="200" cy="200" r="140" fill="none" stroke="currentColor" stroke-width="0.5" class="text-navy-800" />
      <circle cx="200" cy="200" r="100" fill="none" stroke="currentColor" stroke-width="0.5" class="text-navy-800" />
    </svg>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Image Side -->
      <div class="relative reveal-left">
        <!-- Main image -->
        <div class="relative rounded-2xl overflow-hidden shadow-2xl">
          <img
            src="/images/slide2.jpg"
            alt="MKT Makina Üretim"
            class="w-full aspect-[4/3] object-cover"
            loading="lazy"
          />
          <!-- Gradient overlay -->
          <div class="absolute inset-0 bg-gradient-to-tr from-navy-900/30 to-transparent"></div>
        </div>

        <!-- Floating year card -->
        <div class="absolute -bottom-6 -right-4 sm:right-8 bg-white rounded-2xl shadow-2xl p-6 glow-accent">
          <div class="font-heading text-4xl font-bold text-accent-500">2007</div>
          <div class="text-steel-500 text-xs uppercase tracking-[0.2em] mt-1">{t(lang, 'stats.since')}</div>
        </div>

        <!-- Decorative elements -->
        <div class="absolute -top-6 -left-6 w-32 h-32 border-2 border-accent-500/15 rounded-2xl -z-10 hidden lg:block"></div>
        <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-accent-500/5 rounded-full -z-10 blur-2xl hidden lg:block"></div>
      </div>

      <!-- Text Side -->
      <div class="reveal-right">
        <span class="inline-block text-accent-600 text-sm font-semibold uppercase tracking-[0.2em] mb-3">{lang === 'tr' ? 'Bizi Tanıyın' : 'Get to Know Us'}</span>
        <h2 class="font-heading text-4xl sm:text-5xl font-bold text-navy-800 mb-4">
          {t(lang, 'about.title')}
        </h2>
        <div class="accent-bar mb-8"></div>
        <p class="text-steel-600 text-lg leading-relaxed mb-10 font-light">
          {t(lang, 'about.text')}
        </p>

        <!-- Principles Grid -->
        <div class="grid grid-cols-2 gap-4 mb-10">
          {principles.map((item, i) => (
            <div class={`reveal delay-${i + 1} p-5 rounded-xl bg-white card-premium`}>
              <div class="w-9 h-9 bg-gradient-to-br from-accent-50 to-accent-100 rounded-lg flex items-center justify-center mb-3">
                <svg class="w-4.5 h-4.5 text-accent-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="font-heading text-sm font-semibold text-navy-800 mb-1">{item.title}</h3>
              <p class="text-steel-500 text-xs leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>

        <a
          href={getLocalePath(lang, '/kurumsal')}
          class="group inline-flex items-center gap-3 px-7 py-3.5 bg-navy-800 text-white font-semibold uppercase tracking-wider rounded-lg hover:bg-navy-700 transition-all text-sm shadow-lg hover:shadow-xl"
        >
          {t(lang, 'about.more')}
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
