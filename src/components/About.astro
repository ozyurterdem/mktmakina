---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const features = lang === 'tr'
  ? [
      'Eksiksiz ERP/MRP Entegrasyonu',
      'AS9100 Kalite Yonetim Sistemi',
      'Ileri CAD/CAM Yazilim Altyapisi',
      'Hassas Olcum ve Kontrol',
    ]
  : [
      'Complete ERP/MRP Integration',
      'AS9100 Quality Management System',
      'Advanced CAD/CAM Software',
      'Precision Measurement & Control',
    ];

const photos = [
  { src: '/images/slide1.jpg', alt: 'CNC Uretim' },
  { src: '/images/slide2.jpg', alt: 'Makina Parki' },
  { src: '/images/slide3.jpg', alt: 'Kalip Uretimi' },
  { src: '/images/categories/aparatlar_7.jpg', alt: 'Aparat Uretimi' },
  { src: '/images/categories/fikstur_8.jpg', alt: 'Fikstur' },
  { src: '/images/categories/kaliplar_12.jpg', alt: 'Kalip' },
  { src: '/images/categories/parcalar_13.jpg', alt: 'Parca Isleme' },
  { src: '/images/categories/mastarlar_14.jpg', alt: 'Mastar Uretimi' },
  { src: '/images/slide1.jpg', alt: 'Tesis Genel' },
];
---

<section class="section-padding bg-white overflow-hidden" id="about">
  <div class="container-custom">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-12 items-start">

      <!-- Left: Text Content -->
      <div class="lg:pr-8">
        <div data-animate="fade-up">
          <div class="section-label">{lang === 'tr' ? 'Islem & Takim' : 'Machining & Tooling'}</div>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-primary mb-0">
            {t(lang, 'about.title')}
          </h2>
        </div>

        <div class="w-full h-px bg-border my-8" data-animate="fade-up" data-delay="100"></div>

        <div data-animate="fade-up" data-delay="200">
          <p class="text-text-light text-base lg:text-[1.05rem] leading-relaxed mb-10">
            {t(lang, 'about.text')}
          </p>
        </div>

        <!-- Feature list -->
        <div class="space-y-4 mb-10">
          {features.map((feat, i) => (
            <div
              class="group flex items-center gap-4 p-3 -mx-3 rounded-lg hover:bg-surface transition-colors duration-300"
              data-animate="fade-up"
              data-delay={String((i + 2) * 100)}
            >
              <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center shrink-0 group-hover:bg-accent group-hover:scale-110 transition-all duration-300">
                <svg class="w-4 h-4 text-accent group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
              <span class="text-text font-medium text-[0.95rem] group-hover:text-primary transition-colors">{feat}</span>
            </div>
          ))}
        </div>

        <div data-animate="fade-up" data-delay="600">
          <a href={getLocalePath(lang, lang === 'tr' ? '/kurumsal' : '/about')} class="inline-flex items-center gap-2 text-accent text-sm font-semibold uppercase tracking-wider hover:gap-3 transition-all">
            {t(lang, 'about.more')}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </div>

      <!-- Right: Staggered Photo Mosaic -->
      <div class="relative" data-animate="fade-left" data-delay="200">
        <div class="grid grid-cols-3 gap-3 lg:gap-4">
          <!-- Column 1 -->
          <div class="flex flex-col gap-3 lg:gap-4 pt-8">
            <div class="rounded-xl overflow-hidden aspect-square">
              <img src={photos[0].src} alt={photos[0].alt} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="rounded-xl overflow-hidden aspect-[3/4]">
              <img src={photos[3].src} alt={photos[3].alt} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="rounded-xl overflow-hidden aspect-square">
              <img src={photos[6].src} alt={photos[6].alt} class="w-full h-full object-cover" loading="lazy" />
            </div>
          </div>
          <!-- Column 2 -->
          <div class="flex flex-col gap-3 lg:gap-4 pt-16">
            <div class="rounded-xl overflow-hidden aspect-[3/4]">
              <img src={photos[1].src} alt={photos[1].alt} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="rounded-xl overflow-hidden aspect-square">
              <img src={photos[4].src} alt={photos[4].alt} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="rounded-xl overflow-hidden aspect-[3/4]">
              <img src={photos[7].src} alt={photos[7].alt} class="w-full h-full object-cover" loading="lazy" />
            </div>
          </div>
          <!-- Column 3 -->
          <div class="flex flex-col gap-3 lg:gap-4 pt-4">
            <div class="rounded-xl overflow-hidden aspect-[4/5]">
              <img src={photos[2].src} alt={photos[2].alt} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="rounded-xl overflow-hidden aspect-square">
              <img src={photos[5].src} alt={photos[5].alt} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="rounded-xl overflow-hidden aspect-[3/5]">
              <img src={photos[8].src} alt={photos[8].alt} class="w-full h-full object-cover" loading="lazy" />
            </div>
          </div>
        </div>

        <!-- Floating glass stat card overlapping photos -->
        <div class="absolute -bottom-6 -left-6 glass-card-light px-6 py-5 hidden sm:block" data-animate="zoom-in" data-delay="500">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-accent flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <div>
              <div class="font-heading text-lg font-bold text-primary">AS9100</div>
              <div class="text-text-light text-xs">{lang === 'tr' ? 'Sertifikali Kalite' : 'Certified Quality'}</div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
