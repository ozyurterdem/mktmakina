---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const values = lang === 'tr'
  ? [
      { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', title: 'Yüksek Kalite', desc: 'Havacılık standartlarında üretim' },
      { icon: 'M13 10V3L4 14h7v7l9-11h-7z', title: 'Son Teknoloji', desc: 'İleri CNC ve yazılım altyapısı' },
      { icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z', title: 'Özel Çözümler', desc: 'Müşteriye özgü mühendislik' },
      { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4', title: 'AS9100', desc: 'Sertifikalı kalite yönetim sistemi' },
    ]
  : [
      { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', title: 'High Quality', desc: 'Aviation-grade manufacturing' },
      { icon: 'M13 10V3L4 14h7v7l9-11h-7z', title: 'Latest Tech', desc: 'Advanced CNC and software' },
      { icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z', title: 'Custom Solutions', desc: 'Customer-specific engineering' },
      { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4', title: 'AS9100', desc: 'Certified quality management' },
    ];
---

<section class="section-padding bg-steel-50" id="about">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">

      <!-- Image Side (V2 - parallax-feel with stacked layout) -->
      <div class="relative" data-animate="fade-right">
        <!-- Main image -->
        <div class="relative overflow-hidden shadow-2xl">
          <img
            src="/images/slide2.jpg"
            alt="MKT Makina Üretim"
            class="w-full aspect-[4/3] object-cover"
            loading="lazy"
          />
        </div>

        <!-- Floating accent image (offset) -->
        <div
          class="absolute -bottom-8 -right-4 lg:-right-8 w-40 h-40 lg:w-52 lg:h-52 overflow-hidden shadow-xl border-4 border-white hidden sm:block"
          data-animate="zoom-in" data-delay="400"
        >
          <img
            src="/images/slide1.jpg"
            alt="CNC İşleme"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>

        <!-- Year badge -->
        <div
          class="absolute top-6 left-6 bg-accent-500 text-white px-5 py-4 shadow-lg"
          data-animate="fade-down" data-delay="300"
        >
          <div class="font-heading text-3xl font-bold leading-none">2007</div>
          <div class="text-white/70 text-[10px] uppercase tracking-[0.2em] mt-1">{t(lang, 'stats.since')}</div>
        </div>
      </div>

      <!-- Text Side -->
      <div>
        <div data-animate="fade-left">
          <div class="section-label">{lang === 'tr' ? 'Hakkımızda' : 'About Us'}</div>
          <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-navy-800 mb-4">
            {t(lang, 'about.title')}
          </h2>
          <div class="accent-bar mb-6"></div>
          <p class="text-steel-600 text-base leading-relaxed mb-10">
            {t(lang, 'about.text')}
          </p>
        </div>

        <!-- Values grid (icon cards) -->
        <div class="grid grid-cols-2 gap-5 mb-10">
          {values.map((item, i) => (
            <div
              class="group flex items-start gap-3 p-4 bg-white border border-steel-200 hover:border-accent-500/40 hover:shadow-md transition-all duration-300"
              data-animate="fade-up"
              data-delay={String((i + 1) * 100)}
            >
              <div class="w-9 h-9 bg-accent-500/10 flex items-center justify-center shrink-0 group-hover:bg-accent-500 transition-colors">
                <svg class="w-4 h-4 text-accent-500 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-sm font-semibold text-navy-800 tracking-wide">{item.title}</h3>
                <p class="text-steel-500 text-xs leading-relaxed mt-0.5">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <div data-animate="fade-up" data-delay="500">
          <a
            href={getLocalePath(lang, '/kurumsal')}
            class="btn-primary"
          >
            {t(lang, 'about.more')}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
