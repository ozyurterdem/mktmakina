---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const principles = lang === 'tr'
  ? [
      'Müşteri gereksinimlerini karşılayan yüksek kalite ürünler',
      'Son teknoloji ekipman, alet ve yazılım programları',
      'Müşteriye özgü çözümler',
      'İleri endüstriyel standartlara uygun kalite yönetim sistemi',
    ]
  : [
      'High quality products meeting customer requirements',
      'Latest technology equipment, tools and software',
      'Customer-specific solutions',
      'Quality management system complying with advanced standards',
    ];
---

<section class="section-padding bg-steel-50" id="about">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Image Side -->
      <div class="relative reveal">
        <div class="relative rounded-xl overflow-hidden shadow-2xl">
          <img
            src="/images/slide2.jpg"
            alt="MKT Makina Üretim"
            class="w-full aspect-[4/3] object-cover"
            loading="lazy"
          />
        </div>
        <!-- Floating accent box -->
        <div class="absolute -bottom-6 -right-6 w-48 h-48 bg-accent-500/10 rounded-xl -z-10 hidden lg:block"></div>
        <div class="absolute -top-4 -left-4 w-24 h-24 border-2 border-accent-500 rounded-xl -z-10 hidden lg:block"></div>

        <!-- Year badge -->
        <div class="absolute bottom-6 left-6 bg-navy-800 text-white px-5 py-3 rounded-lg shadow-xl">
          <div class="font-heading text-2xl font-bold text-accent-500">2007</div>
          <div class="text-xs text-steel-400 uppercase tracking-wider">{t(lang, 'stats.since')}</div>
        </div>
      </div>

      <!-- Text Side -->
      <div class="reveal">
        <div class="accent-bar mb-4"></div>
        <h2 class="font-heading text-3xl sm:text-4xl font-bold text-navy-800 mb-6">
          {t(lang, 'about.title')}
        </h2>
        <p class="text-steel-600 text-lg leading-relaxed mb-8">
          {t(lang, 'about.text')}
        </p>

        <!-- Principles -->
        <ul class="space-y-4 mb-8">
          {principles.map((item) => (
            <li class="flex items-start gap-3">
              <div class="w-6 h-6 rounded-full bg-accent-500 flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <span class="text-steel-700">{item}</span>
            </li>
          ))}
        </ul>

        <a
          href={getLocalePath(lang, '/kurumsal')}
          class="inline-flex items-center gap-2 px-6 py-3 bg-navy-800 text-white font-semibold uppercase tracking-wide rounded-md hover:bg-navy-700 transition-colors text-sm"
        >
          {t(lang, 'about.more')}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
