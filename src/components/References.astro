---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const references = [
  { name: 'Toyota Boshoku', image: '/images/references/toyota-boshoku_197.jpg' },
  { name: 'TSI', image: '/images/references/tsi_198.jpg' },
  { name: 'Doğuş', image: '/images/references/dogus_187.jpg' },
  { name: 'Elimsan', image: '/images/references/elimsan_188.jpg' },
  { name: 'Mikrosan', image: '/images/references/mikrosan_192.jpg' },
  { name: 'Demka Dövme Çelik', image: '/images/references/demka-dovme-celik-sanayi_186.jpg' },
  { name: 'Neutec İlaç', image: '/images/references/neutec-ilac-sanayi_193.jpg' },
  { name: 'Rad-Tek Radyatör', image: '/images/references/rad-tek-radyator-metal_195.jpg' },
  { name: 'Arma Filtre', image: '/images/references/arma-filtre-sistemleri_185.jpg' },
];

// Duplicate for seamless marquee
const allRefs = [...references, ...references];
---

<section class="section-padding bg-white" id="references">
  <div class="max-w-[1400px] mx-auto px-6">
    <!-- Header -->
    <div class="text-center mb-12 reveal">
      <span class="text-accent-500 text-xs font-semibold uppercase tracking-[0.2em] mb-2 block">{lang === 'tr' ? 'İş Ortaklarımız' : 'Our Partners'}</span>
      <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-navy-800 mb-3">
        {t(lang, 'references.title')}
      </h2>
      <p class="text-steel-500 text-base max-w-lg mx-auto">
        {t(lang, 'references.subtitle')}
      </p>
    </div>
  </div>

  <!-- Marquee (full width) -->
  <div class="overflow-hidden reveal">
    <div class="flex marquee-track" style="width: max-content;">
      {allRefs.map((ref) => (
        <div class="flex items-center justify-center px-8 sm:px-12 h-24 sm:h-28 shrink-0">
          <img
            src={ref.image}
            alt={ref.name}
            class="max-h-12 sm:max-h-14 max-w-[140px] object-contain ref-logo"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>

  <!-- CTA below marquee -->
  <div class="max-w-[1400px] mx-auto px-6">
    <div class="text-center mt-10 reveal">
      <a
        href={getLocalePath(lang, '/referanslar')}
        class="inline-flex items-center gap-2 text-navy-800 text-sm font-semibold uppercase tracking-wider hover:text-accent-500 transition-colors"
      >
        {t(lang, 'references.all')}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>
  </div>
</section>
