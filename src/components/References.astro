---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const references = [
  { name: 'Toyota Boshoku', image: '/images/references/toyota-boshoku_197.jpg' },
  { name: 'TSI', image: '/images/references/tsi_198.jpg' },
  { name: 'Dogus', image: '/images/references/dogus_187.jpg' },
  { name: 'Elimsan', image: '/images/references/elimsan_188.jpg' },
  { name: 'Mikrosan', image: '/images/references/mikrosan_192.jpg' },
  { name: 'Demka Dovme Celik', image: '/images/references/demka-dovme-celik-sanayi_186.jpg' },
  { name: 'Neutec Ilac', image: '/images/references/neutec-ilac-sanayi_193.jpg' },
  { name: 'Rad-Tek Radyator', image: '/images/references/rad-tek-radyator-metal_195.jpg' },
  { name: 'Arma Filtre', image: '/images/references/arma-filtre-sistemleri_185.jpg' },
];
---

<section class="section-padding bg-surface" id="references">
  <div class="container-custom">
    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-14" data-animate="fade-up">
      <div class="section-label justify-center">{lang === 'tr' ? 'Is Ortaklarimiz' : 'Our Partners'}</div>
      <h2 class="text-3xl sm:text-4xl lg:text-[2.75rem] font-heading font-bold text-primary mb-4">
        {t(lang, 'references.title')}
      </h2>
      <p class="text-text-light text-base leading-relaxed">{t(lang, 'references.subtitle')}</p>
    </div>

    <!-- Logo Grid — sadece logo, isim/sektor yok -->
    <div class="grid grid-cols-3 sm:grid-cols-5 gap-px bg-border rounded-xl overflow-hidden max-w-4xl mx-auto" data-animate="fade-up" data-delay="200">
      {references.map((ref) => (
        <div class="flex items-center justify-center bg-white p-6 sm:p-8 lg:p-10 hover:bg-surface transition-colors duration-300">
          <img
            src={ref.image}
            alt={ref.name}
            class="max-h-8 sm:max-h-10 lg:max-h-12 max-w-full object-contain ref-logo"
            loading="lazy"
            title={ref.name}
          />
        </div>
      ))}
      <!-- 9 logo var, 5 sutunlu grid'de son satir 4 logo. Bos hucre ekle -->
      <div class="hidden sm:flex items-center justify-center bg-white p-6 sm:p-8 lg:p-10">
        <span class="text-text-muted text-xs font-mono">+</span>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-10" data-animate="fade-up">
      <a
        href={getLocalePath(lang, lang === 'tr' ? '/referanslar' : '/references')}
        class="inline-flex items-center gap-2 text-text-light text-sm font-medium hover:text-accent hover:gap-3 transition-all"
      >
        {t(lang, 'references.all')}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>
