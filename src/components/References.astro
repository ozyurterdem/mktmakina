---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const references = [
  { name: 'Toyota Boshoku', image: '/images/references/toyota-boshoku_197.jpg' },
  { name: 'TSI', image: '/images/references/tsi_198.jpg' },
  { name: 'Dogus', image: '/images/references/dogus_187.jpg' },
  { name: 'Elimsan', image: '/images/references/elimsan_188.jpg' },
  { name: 'Mikrosan', image: '/images/references/mikrosan_192.jpg' },
  { name: 'Demka Dovme Celik', image: '/images/references/demka-dovme-celik-sanayi_186.jpg' },
  { name: 'Neutec Ilac', image: '/images/references/neutec-ilac-sanayi_193.jpg' },
  { name: 'Rad-Tek Radyator', image: '/images/references/rad-tek-radyator-metal_195.jpg' },
  { name: 'Arma Filtre', image: '/images/references/arma-filtre-sistemleri_185.jpg' },
];
---

<section class="relative section-padding overflow-hidden noise-overlay" id="references">
  <div class="absolute inset-0 bg-primary-dark"></div>

  <div class="relative z-10 container-custom">
    <div class="text-center max-w-2xl mx-auto mb-16" data-animate="fade-up">
      <div class="section-label justify-center">{lang === 'tr' ? 'İş Ortaklarımız' : 'Our Partners'}</div>
      <h2 class="text-3xl sm:text-4xl lg:text-[2.75rem] font-heading font-bold text-white mb-4">
        {t(lang, 'references.title')}
      </h2>
      <p class="text-text-light text-base leading-relaxed">{t(lang, 'references.subtitle')}</p>
    </div>

    <!-- Marquee (desktop) -->
    <div class="ref-marquee-wrap" data-animate="fade-up" data-delay="200">
      <div class="ref-marquee">
        {[...references, ...references].map((ref) => (
          <div class="ref-item">
            <img src={ref.image} alt={ref.name} class="ref-logo" loading="lazy" />
          </div>
        ))}
      </div>
    </div>

    <!-- Static grid (mobile) -->
    <div class="ref-grid" data-animate="fade-up" data-delay="200">
      {references.map((ref) => (
        <div class="ref-item">
          <img src={ref.image} alt={ref.name} class="ref-logo" loading="lazy" />
        </div>
      ))}
    </div>

    <div class="text-center mt-12" data-animate="fade-up">
      <a
        href={getLocalePath(lang, lang === 'tr' ? '/referanslar' : '/references')}
        class="inline-flex items-center gap-2 text-accent/60 text-sm font-mono uppercase tracking-wider hover:text-accent hover:gap-3 transition-all"
      >
        {t(lang, 'references.all')}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .ref-marquee-wrap {
    display: none;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }
  @media (min-width: 640px) {
    .ref-marquee-wrap { display: block; }
    .ref-grid { display: none !important; }
  }

  .ref-marquee {
    display: flex;
    gap: 1.5rem;
    width: max-content;
    animation: refMarquee 40s linear infinite;
  }
  .ref-marquee:hover {
    animation-play-state: paused;
  }
  @keyframes refMarquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .ref-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 220px;
    height: 100px;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 4px;
    padding: 0.75rem 1rem;
    overflow: hidden;
    transition: all 0.4s ease;
  }
  .ref-item:hover {
    background: #ffffff;
    border-color: rgba(200, 162, 60, 0.3);
    box-shadow: 0 8px 32px rgba(200, 162, 60, 0.1);
  }

  .ref-logo {
    max-height: 100%;
    max-width: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    opacity: 0.85;
    transition: all 0.4s ease;
  }
  .ref-item:hover .ref-logo {
    opacity: 1;
  }

  .ref-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }
  .ref-grid .ref-item {
    width: auto;
    height: 72px;
    padding: 0.5rem;
  }
  .ref-grid .ref-logo {
    max-height: 100%;
  }
</style>
