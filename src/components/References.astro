---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const references = [
  { name: 'Toyota Boshoku', image: '/images/references/toyota-boshoku_197.jpg' },
  { name: 'TSI', image: '/images/references/tsi_198.jpg' },
  { name: 'Dogus', image: '/images/references/dogus_187.jpg' },
  { name: 'Elimsan', image: '/images/references/elimsan_188.jpg' },
  { name: 'Mikrosan', image: '/images/references/mikrosan_192.jpg' },
  { name: 'Demka Dovme Celik', image: '/images/references/demka-dovme-celik-sanayi_186.jpg' },
  { name: 'Neutec Ilac', image: '/images/references/neutec-ilac-sanayi_193.jpg' },
  { name: 'Rad-Tek Radyator', image: '/images/references/rad-tek-radyator-metal_195.jpg' },
  { name: 'Arma Filtre', image: '/images/references/arma-filtre-sistemleri_185.jpg' },
];
---

<section class="ref-section" id="references">
  <div class="container-custom">
    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-16" data-animate="fade-up">
      <div class="section-label justify-center">{lang === 'tr' ? 'Is Ortaklarimiz' : 'Our Partners'}</div>
      <h2 class="text-3xl sm:text-4xl lg:text-[2.75rem] font-heading font-bold text-white mb-4">
        {t(lang, 'references.title')}
      </h2>
      <p class="text-white/60 text-base leading-relaxed">{t(lang, 'references.subtitle')}</p>
    </div>

    <!-- Logo Marquee -->
    <div class="ref-marquee-wrap" data-animate="fade-up" data-delay="200">
      <div class="ref-marquee">
        {[...references, ...references].map((ref) => (
          <div class="ref-card">
            <img
              src={ref.image}
              alt={ref.name}
              class="ref-card-logo"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>

    <!-- Static grid (no-JS fallback + mobile) -->
    <div class="ref-grid" data-animate="fade-up" data-delay="200">
      {references.map((ref) => (
        <div class="ref-card">
          <img
            src={ref.image}
            alt={ref.name}
            class="ref-card-logo"
            loading="lazy"
          />
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-12" data-animate="fade-up">
      <a
        href={getLocalePath(lang, lang === 'tr' ? '/referanslar' : '/references')}
        class="inline-flex items-center gap-2 text-white/50 text-sm font-medium hover:text-accent-light hover:gap-3 transition-all"
      >
        {t(lang, 'references.all')}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  /* Section — koyu arka plan, premium his */
  .ref-section {
    padding-block: 5rem;
    background: linear-gradient(180deg, var(--color-primary-dark) 0%, var(--color-primary) 100%);
    position: relative;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .ref-section { padding-block: 6rem; }
  }

  /* Subtle grain overlay */
  .ref-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
  }

  .ref-section > * {
    position: relative;
    z-index: 1;
  }

  /* Card */
  .ref-card {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 180px;
    height: 100px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    backdrop-filter: blur(8px);
    padding: 1.25rem 1.5rem;
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .ref-card:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.18);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
  }

  .ref-card-logo {
    max-height: 44px;
    max-width: 100%;
    width: auto;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.55;
    transition: all 0.4s ease;
  }

  .ref-card:hover .ref-card-logo {
    opacity: 0.9;
    filter: brightness(0) invert(1);
  }

  /* Marquee — desktop */
  .ref-marquee-wrap {
    display: none;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  @media (min-width: 640px) {
    .ref-marquee-wrap { display: block; }
    .ref-grid { display: none; }
  }

  .ref-marquee {
    display: flex;
    gap: 1.25rem;
    width: max-content;
    animation: marquee 35s linear infinite;
  }

  .ref-marquee:hover {
    animation-play-state: paused;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Static grid — mobile */
  .ref-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    max-width: 600px;
    margin-inline: auto;
  }

  .ref-grid .ref-card {
    width: auto;
    height: 80px;
    padding: 1rem;
  }

  .ref-grid .ref-card-logo {
    max-height: 32px;
  }

  @media (min-width: 640px) {
    .ref-grid { display: none; }
  }
</style>
