---
import { t, getLocalePath, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;

const references = [
  { name: 'Toyota Boshoku', image: '/images/references/toyota-boshoku_197.jpg' },
  { name: 'TSI', image: '/images/references/tsi_198.jpg' },
  { name: 'Doğuş', image: '/images/references/dogus_187.jpg' },
  { name: 'Elimsan', image: '/images/references/elimsan_188.jpg' },
  { name: 'Mikrosan', image: '/images/references/mikrosan_192.jpg' },
  { name: 'Demka Dövme Çelik', image: '/images/references/demka-dovme-celik-sanayi_186.jpg' },
  { name: 'Neutec İlaç', image: '/images/references/neutec-ilac-sanayi_193.jpg' },
  { name: 'Rad-Tek Radyatör', image: '/images/references/rad-tek-radyator-metal_195.jpg' },
  { name: 'Arma Filtre', image: '/images/references/arma-filtre-sistemleri_185.jpg' },
];
---

<section class="section-padding bg-white relative" id="references">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <span class="inline-block text-accent-600 text-sm font-semibold uppercase tracking-[0.2em] mb-3">{lang === 'tr' ? 'İş Ortaklarımız' : 'Our Partners'}</span>
      <h2 class="font-heading text-4xl sm:text-5xl font-bold text-navy-800 mb-4">
        {t(lang, 'references.title')}
      </h2>
      <div class="accent-bar mx-auto mb-5"></div>
      <p class="text-steel-500 text-lg max-w-2xl mx-auto font-light">
        {t(lang, 'references.subtitle')}
      </p>
    </div>

    <!-- Logo Grid — Premium -->
    <div class="grid grid-cols-3 sm:grid-cols-3 lg:grid-cols-5 gap-4 sm:gap-6 reveal">
      {references.map((ref, i) => (
        <div class={`delay-${(i % 5) + 1} group flex items-center justify-center p-6 sm:p-8 h-28 sm:h-32 bg-steel-50/80 rounded-2xl border border-steel-200/50 hover:border-accent-500/20 hover:bg-white hover:shadow-xl transition-all duration-500`}>
          <img
            src={ref.image}
            alt={ref.name}
            class="max-h-14 sm:max-h-16 max-w-full object-contain ref-logo"
            loading="lazy"
          />
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-12 reveal">
      <a
        href={getLocalePath(lang, '/referanslar')}
        class="group inline-flex items-center gap-3 px-7 py-3.5 bg-gradient-to-r from-accent-500 to-accent-600 text-white font-semibold uppercase tracking-wider rounded-lg hover:from-accent-600 hover:to-accent-700 transition-all shadow-lg hover:shadow-xl text-sm"
      >
        {t(lang, 'references.all')}
        <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
