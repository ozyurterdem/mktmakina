---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import FormHandler from '../../components/FormHandler.astro';
---

<BaseLayout title="اتصل بنا — MKT ماكينا" description="معلومات التواصل مع MKT ماكينا." lang="ar" hasHero={false}>
  <PageHero title="اتصل بنا" subtitle="نحن هنا للإجابة على استفساراتكم" />

  <section class="section-padding">
    <div class="container-custom">
      <div class="grid lg:grid-cols-2 gap-12">
        <div data-animate="fade-up">
          <h2 class="font-heading text-2xl font-bold text-white mb-8">MKT Makina ش.م.</h2>
          <div class="space-y-4">
            <a href="https://www.google.com/maps/search/?api=1&query=40.7257778,30.3876111" target="_blank" rel="noopener noreferrer" class="flex gap-4 p-5 bg-primary-light border border-white/[0.06] hover:border-accent/40 transition-colors group">
              <div class="w-10 h-10 bg-accent flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              </div>
              <div>
                <h3 class="text-xs font-semibold text-white uppercase tracking-wider mb-1 group-hover:text-accent transition-colors">العنوان</h3>
                <p class="text-text-light text-sm">Hanlıköy Mah. Akgün Cad. No:1<br />Arifiye / Sakarya, Turkey</p>
              </div>
            </a>
            <div class="flex gap-4 p-5 bg-primary-light border border-white/[0.06]">
              <div class="w-10 h-10 bg-accent flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              </div>
              <div>
                <h3 class="text-xs font-semibold text-white uppercase tracking-wider mb-1">الهاتف</h3>
                <a href="tel:+902642761880" class="text-text-light text-sm hover:text-accent transition-colors">+90 264 276 18 80</a>
              </div>
            </div>
            <div class="flex gap-4 p-5 bg-primary-light border border-white/[0.06]">
              <div class="w-10 h-10 bg-accent flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              </div>
              <div>
                <h3 class="text-xs font-semibold text-white uppercase tracking-wider mb-1">البريد الإلكتروني</h3>
                <a href="mailto:info@mktmakina.com" class="text-text-light text-sm hover:text-accent transition-colors">info@mktmakina.com</a>
              </div>
            </div>
          </div>
        </div>

        <div data-animate="fade-up">
          <div class="bg-primary-dark p-8">
            <h2 class="font-heading text-lg font-bold text-white mb-6">نموذج التواصل</h2>
            <form class="space-y-4" id="contact-form">
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label for="name" class="block text-white/60 text-xs mb-1.5">الاسم الكامل</label>
                  <input type="text" id="name" name="name" required class="form-input bg-primary-dark/50 border-primary-light text-white placeholder-white/20" />
                </div>
                <div>
                  <label for="email" class="block text-white/60 text-xs mb-1.5">البريد الإلكتروني</label>
                  <input type="email" id="email" name="email" required class="form-input bg-primary-dark/50 border-primary-light text-white placeholder-white/20" />
                </div>
              </div>
              <div>
                <label for="message" class="block text-white/60 text-xs mb-1.5">الرسالة</label>
                <textarea id="message" name="message" rows="5" required class="form-input bg-primary-dark/50 border-primary-light text-white placeholder-white/20 resize-none"></textarea>
              </div>
              <button type="submit" class="btn-primary w-full">إرسال</button>
            </form>
          </div>
        </div>
      </div>

    </div>
  </section>
  <FormHandler formId="contact-form" successMessage="تم إرسال الرسالة!" />
</BaseLayout>
