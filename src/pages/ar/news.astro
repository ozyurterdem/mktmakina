---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTA from '../../components/CTA.astro';

const news = [
  {
    title: 'شركاء أقوياء يُضيفون قيمة أكبر لمنتجاتنا',
    image: '/images/news/guclu-partnerler.jpg',
    summary: 'في MKT ماكينا، لا نكتفي بإنتاج تقنيات تصنيع عالية الجودة باستخدام أحدث الفرص التقنية في الهندسة، بل نوفر أيضًا شراكات طويلة الأمد من خلال خدمات الاستشارة والدعم ما بعد البيع.',
    date: '2024',
  },
];
---

<BaseLayout title="الأخبار — MKT ماكينا" description="أخبار وإعلانات MKT ماكينا." lang="ar" hasHero={false}>
  <PageHero title="الأخبار" subtitle="آخر المستجدات والإعلانات" image="/images/hero/atolye-ferah.jpg" />

  <section class="section-padding">
    <div class="container-custom max-w-[1000px]">
      <div class="space-y-6">
        {news.map((item) => (
          <article class="card grid md:grid-cols-[200px_1fr] gap-6 p-5" data-animate="fade-up">
            <div class="aspect-square overflow-hidden bg-surface">
              <img src={item.image} alt={item.title} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="flex flex-col justify-center">
              <span class="text-accent text-xs font-semibold uppercase tracking-wider mb-2">{item.date}</span>
              <h2 class="font-heading text-lg font-bold text-white mb-2">{item.title}</h2>
              <p class="text-text-light text-sm leading-relaxed">{item.summary}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTA lang="ar" />
</BaseLayout>
