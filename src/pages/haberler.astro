---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTA from '../components/CTA.astro';

const news = [
  {
    title: 'Güçlü Partnerler, Ürünlerimize daha da değer katmaktadır.',
    image: '/images/news/guclu-partnerler.jpg',
    summary: 'MKT Makina Kalıp olarak müşterilerimize mühendislik ve yönetim bilimlerindeki en son teknolojik olanakları kullanılarak daima yüksek kalite standartlarında gelişen imalat teknolojileri üretmekle kalmayıp, satış sonrası danışmanlık ve destek hizmetlerimizle uzun vadeli bir işbirliği sağlar.',
    date: '2024',
  },
];
---

<BaseLayout title="Haberler — MKT Makina Kalıp Takım" description="MKT Makina haberleri ve duyuruları." lang="tr">
  <PageHero title="Haberler" subtitle="Güncel gelişmeler ve duyurular" />

  <section class="section-padding bg-white">
    <div class="max-w-[1000px] mx-auto px-6">
      <div class="space-y-6">
        {news.map((item) => (
          <article class="grid md:grid-cols-[200px_1fr] gap-6 p-5 border border-steel-200 hover:border-accent-500/30 transition-colors reveal">
            <div class="aspect-square overflow-hidden bg-steel-100">
              <img src={item.image} alt={item.title} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="flex flex-col justify-center">
              <span class="text-accent-500 text-xs font-semibold uppercase tracking-wider mb-2">{item.date}</span>
              <h2 class="font-heading text-lg font-bold text-navy-800 mb-2">{item.title}</h2>
              <p class="text-steel-600 text-sm leading-relaxed">{item.summary}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTA lang="tr" />
</BaseLayout>
