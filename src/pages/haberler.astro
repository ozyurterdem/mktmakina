---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTA from '../components/CTA.astro';

const news = [
  {
    title: 'Guclu Partnerler, Urunlerimize daha da deger katmaktadir.',
    image: '/images/news/guclu-partnerler.jpg',
    summary: 'MKT Makina Kalip olarak musterilerimize muhendislik ve yonetim bilimlerindeki en son teknolojik olanaklari kullanilarak daima yuksek kalite standartlarinda gelisen imalat teknolojileri uretmekle kalmayip, satis sonrasi danismanlik ve destek hizmetlerimizle uzun vadeli bir isbirligi saglar.',
    date: '2024',
  },
];
---

<BaseLayout title="Haberler — MKT Makina A.Ş." description="MKT Makina haberleri ve duyurulari." lang="tr" hasHero={false}>
  <PageHero title="Haberler" subtitle="Guncel gelismeler ve duyurular" />

  <section class="section-padding">
    <div class="container-custom max-w-[1000px]">
      <div class="space-y-6">
        {news.map((item) => (
          <article class="card grid md:grid-cols-[200px_1fr] gap-6 p-5" data-animate="fade-up">
            <div class="aspect-square overflow-hidden bg-surface">
              <img src={item.image} alt={item.title} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="flex flex-col justify-center">
              <span class="text-accent text-xs font-semibold uppercase tracking-wider mb-2">{item.date}</span>
              <h2 class="font-heading text-lg font-bold text-white mb-2">{item.title}</h2>
              <p class="text-text-light text-sm leading-relaxed">{item.summary}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTA lang="tr" />
</BaseLayout>
