---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTA from '../components/CTA.astro';
import { products } from '../data/products';
---

<BaseLayout title="Ürünlerimiz — MKT Makina Kalıp Takım" description="MKT Makina ürünleri: Aparatlar, fikstürler, kalıplar, kalite kontrol mastarları, plastik enjeksiyon ve talaşlı imalat parçaları." lang="tr">
  <PageHero title="Ürünlerimiz" subtitle="Havacılık ve otomotiv sanayii için hassas mühendislik çözümleri" />

  <section class="section-padding bg-white">
    <div class="max-w-[1400px] mx-auto px-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {products.map((product) => (
          <a href={`/urunler/${product.slug}`} class="group bg-white border border-steel-200 overflow-hidden card-hover reveal">
            <div class="relative aspect-[16/10] overflow-hidden">
              <img
                src={product.image}
                alt={product.name.tr}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-navy-950/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            </div>
            <div class="p-5">
              <h3 class="font-heading text-base font-semibold text-navy-800 mb-2 group-hover:text-accent-600 transition-colors tracking-wide">{product.name.tr}</h3>
              <p class="text-steel-500 text-sm leading-relaxed mb-3">{product.description.tr}</p>
              <div class="w-6 h-[2px] bg-accent-500 transition-all duration-500 group-hover:w-12"></div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTA lang="tr" />
</BaseLayout>
