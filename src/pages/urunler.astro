---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTA from '../components/CTA.astro';
import { products } from '../data/products';
---

<BaseLayout title="Ürünlerimiz — MKT Makina Kalıp Takım" description="MKT Makina ürünleri: Aparatlar, fikstürler, kalıplar, kalite kontrol mastarları, plastik enjeksiyon ve talaşlı imalat parçaları." lang="tr">
  <PageHero title="Ürünlerimiz" subtitle="Havacılık ve otomotiv sanayii için hassas mühendislik çözümleri" />

  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {products.map((product) => (
          <a href={`/urunler/${product.slug}`} class="group bg-white rounded-xl border border-steel-200 overflow-hidden hover:shadow-xl transition-all duration-500 reveal">
            <div class="relative aspect-[4/3] overflow-hidden">
              <img
                src={product.image}
                alt={product.name.tr}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-navy-900/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                <div class="w-14 h-14 rounded-full bg-white/90 flex items-center justify-center scale-0 group-hover:scale-100 transition-transform duration-500">
                  <svg class="w-6 h-6 text-accent-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </div>
              </div>
            </div>
            <div class="p-6">
              <h3 class="font-heading text-lg font-semibold text-navy-800 mb-2 group-hover:text-accent-600 transition-colors">{product.name.tr}</h3>
              <p class="text-steel-500 text-sm leading-relaxed mb-4">{product.description.tr}</p>
              <div class="w-8 h-0.5 bg-accent-500 transition-all duration-500 group-hover:w-16"></div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTA lang="tr" />
</BaseLayout>
