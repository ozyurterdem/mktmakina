---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import FormHandler from '../components/FormHandler.astro';
---

<BaseLayout title="Insan Kaynaklari — MKT Makina Kalip Takim" description="MKT Makina kariyer firsatlari. Ekibimize katilin." lang="tr" hasHero={false}>
  <PageHero title="Insan Kaynaklari" subtitle="Ekibimize katilin" />

  <section class="section-padding bg-white">
    <div class="max-w-2xl mx-auto px-6">
      <div class="card p-8 sm:p-10" data-animate="fade-up">
        <div class="flex items-center gap-4 mb-8 pb-6 border-b border-border">
          <div class="w-12 h-12 bg-primary-dark flex items-center justify-center">
            <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
          </div>
          <div>
            <h2 class="font-heading text-lg font-bold text-primary">Basvuru Formu</h2>
            <p class="text-text-light text-sm">Ekibimize katilmak icin asagidaki formu doldurun</p>
          </div>
        </div>

        <form class="space-y-4" id="hr-form">
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="hr-name" class="block text-primary text-xs font-medium mb-1.5">Ad Soyad *</label>
              <input type="text" id="hr-name" name="name" required class="form-input" />
            </div>
            <div>
              <label for="hr-email" class="block text-primary text-xs font-medium mb-1.5">E-posta *</label>
              <input type="email" id="hr-email" name="email" required class="form-input" />
            </div>
          </div>
          <div>
            <label for="hr-phone" class="block text-primary text-xs font-medium mb-1.5">Telefon *</label>
            <input type="tel" id="hr-phone" name="phone" required class="form-input" />
          </div>
          <div>
            <label for="hr-message" class="block text-primary text-xs font-medium mb-1.5">Mesaj</label>
            <textarea id="hr-message" name="message" rows="4" class="form-input resize-none" placeholder="Kendinizden kisaca bahsedin..."></textarea>
          </div>
          <div>
            <label for="hr-cv" class="block text-primary text-xs font-medium mb-1.5">CV Dosyaniz *</label>
            <input type="file" id="hr-cv" name="cv" required accept=".pdf,.doc,.docx" class="w-full px-4 py-3 border border-border text-text-light text-sm file:mr-4 file:py-1 file:px-4 file:border-0 file:text-xs file:bg-primary-dark file:text-white hover:file:bg-primary" />
            <p class="text-text-muted text-xs mt-1">PDF veya Word — Maks. 5MB</p>
          </div>
          <button type="submit" class="btn-primary w-full">
            Basvuruyu Gonder
          </button>
        </form>
      </div>
    </div>
  </section>
  <FormHandler formId="hr-form" successMessage="Basvurunuz gonderildi!" />
</BaseLayout>
