---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTA from '../../components/CTA.astro';

const machineGroups = [
  { category: '5-Axis CNC Machining Centers', machines: [
    { name: 'DMU 85', specs: 'DMG MORI — 5-Axis Simultaneous' },
    { name: 'DMU 75', specs: 'DMG MORI — 5-Axis Simultaneous' },
    { name: 'HAAS UMC VF3', specs: '5-Axis CNC Machining Center' },
    { name: 'HAAS UMC 750', specs: '5-Axis CNC Machining Center' },
  ]},
  { category: '3-Axis CNC Machining Centers', machines: [
    { name: 'DMC 1035 V', specs: 'DMG MORI — 3-Axis (Unit 1)' },
    { name: 'DMC 1035 V', specs: 'DMG MORI — 3-Axis (Unit 2)' },
    { name: 'DMC 835 V', specs: 'DMG MORI — 3-Axis' },
  ]},
  { category: 'Wire EDM Machines', machines: [
    { name: 'CUT 30P', specs: 'GF Machining — Wire EDM (Unit 1)' },
    { name: 'CUT 30P', specs: 'GF Machining — Wire EDM (Unit 2)' },
    { name: 'CUT 20P', specs: 'GF Machining — Wire EDM' },
  ]},
  { category: 'Lathe & EDM', machines: [
    { name: 'CNC Lathe', specs: 'CNC Turning Machine' },
    { name: 'Sinker EDM', specs: 'Die-Sinking EDM Machine' },
  ]},
  { category: 'Grinding & Sharpening', machines: [
    { name: 'Surface Grinder', specs: 'Surface Grinding Machine' },
    { name: 'Cylindrical & Bore Grinder', specs: 'Cylindrical and Bore Grinding Machine' },
    { name: 'Tool Grinder', specs: 'Tool Sharpening Machine' },
  ]},
  { category: 'Conventional Machines', machines: [
    { name: 'Universal Milling', specs: 'Universal Milling Machine' },
    { name: 'Universal Lathe', specs: 'Universal Lathe Machine' },
  ]},
  { category: 'Plastic Injection & Marking', machines: [
    { name: 'LS LST 280', specs: 'LS — Plastic Injection Machine' },
    { name: 'Laser Marking', specs: 'Laser Marking System' },
  ]},
];
---

<BaseLayout title="Machine Park — MKT Makina" description="MKT Makina machine park: DMG MORI 5-axis CNC, HAAS machining centers, GF Machining wire EDM." lang="en">
  <PageHero title="Machine Park" subtitle="Advanced technology production infrastructure" image="/images/slide3.jpg" />

  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-16 reveal">
        {[{ value: '4', label: '5-Axis CNC' }, { value: '3', label: '3-Axis CNC' }, { value: '3', label: 'Wire EDM' }, { value: '20+', label: 'Total Machines' }].map((stat) => (
          <div class="text-center p-5 bg-navy-800 rounded-lg">
            <div class="font-heading text-3xl font-bold text-accent-500">{stat.value}</div>
            <div class="text-steel-400 text-sm mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
      <div class="space-y-12">
        {machineGroups.map((group) => (
          <div class="reveal">
            <h2 class="font-heading text-xl font-bold text-navy-800 mb-6">{group.category}</h2>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
              {group.machines.map((m) => (
                <div class="p-5 bg-steel-50 rounded-lg border border-steel-200 hover:border-accent-500/30 hover:shadow-md transition-all">
                  <h3 class="font-heading text-base font-semibold text-navy-800 mb-1">{m.name}</h3>
                  <p class="text-steel-500 text-sm">{m.specs}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA lang="en" />
</BaseLayout>
