---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTA from '../../components/CTA.astro';

const machineGroups = [
  { category: '5-Axis CNC Machining Centers', machines: [
    { name: 'DMU 85', specs: 'DMG MORI — 5-Axis Simultaneous' },
    { name: 'DMU 75', specs: 'DMG MORI — 5-Axis Simultaneous' },
    { name: 'HAAS UMC VF3', specs: '5-Axis CNC Machining Center' },
    { name: 'HAAS UMC 750', specs: '5-Axis CNC Machining Center' },
  ]},
  { category: '3-Axis CNC Machining Centers', machines: [
    { name: 'DMC 1035 V', specs: 'DMG MORI — 3-Axis' },
    { name: 'DMC 1035 V', specs: 'DMG MORI — 3-Axis (2nd unit)' },
    { name: 'DMC 835 V', specs: 'DMG MORI — 3-Axis' },
  ]},
  { category: 'Horizontal CNC Machining Centers', machines: [
    { name: 'NHC 5000 (1)', specs: 'Horizontal CNC Machining Center' },
    { name: 'NHC 5000 (2)', specs: 'Horizontal CNC Machining Center' },
    { name: 'NHC 5000 (3)', specs: 'Horizontal CNC Machining Center' },
  ]},
  { category: 'Wire EDM', machines: [
    { name: 'CUT 30P', specs: 'GF Machining (1st unit)' },
    { name: 'CUT 30P', specs: 'GF Machining (2nd unit)' },
    { name: 'CUT 20P', specs: 'GF Machining' },
  ]},
  { category: 'Lathe & Sinker EDM', machines: [
    { name: 'CNC Lathe', specs: 'CNC Turning Machine' },
    { name: 'Sinker EDM', specs: 'Sinker EDM Machine' },
  ]},
  { category: 'Grinding', machines: [
    { name: 'Surface Grinding', specs: 'Surface Grinding Machine' },
    { name: 'Cylindrical Grinding', specs: 'Cylindrical & Internal Grinding' },
    { name: 'Tool Grinding', specs: 'Tool Grinding Machine' },
  ]},
  { category: 'Laser Marking', machines: [
    { name: 'Laser Marking', specs: 'Laser Marking System' },
  ]},
  { category: 'Plastic Injection', machines: [
    { name: 'LS LST 280', specs: 'LS — Plastic Injection Machine' },
  ]},
];
---

<BaseLayout title="Machine Park — MKT Makina" description="MKT Makina machine park: DMG MORI 5-axis CNC, HAAS, GF Machining wire EDM and more." lang="en" hasHero={false}>
  <PageHero title="Machine Park" subtitle="Advanced technology production infrastructure" image="/images/slide3.jpg" />

  <section class="section-padding">
    <div class="container-custom">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-[1px] bg-border mb-14" data-animate="fade-up">
        {[
          { value: '4', label: '5-Axis CNC' },
          { value: '3', label: '3-Axis CNC' },
          { value: '3', label: 'Horizontal CNC (NHC 5000)' },
          { value: '20+', label: 'Total Machines' },
        ].map((stat) => (
          <div class="text-center p-5 bg-primary-dark">
            <div class="font-heading text-2xl sm:text-3xl font-bold text-accent">{stat.value}</div>
            <div class="text-white/60 text-xs mt-1 uppercase tracking-wider">{stat.label}</div>
          </div>
        ))}
      </div>

      <div class="space-y-10">
        {machineGroups.map((group) => (
          <div data-animate="fade-up">
            <div class="flex items-center gap-3 mb-5">
              <div class="accent-bar"></div>
              <h2 class="font-heading text-lg font-bold text-white tracking-wide">{group.category}</h2>
            </div>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-[1px] bg-border">
              {group.machines.map((machine) => (
                <div class="p-5 bg-primary-light hover:bg-primary-light transition-colors">
                  <h3 class="font-heading text-sm font-semibold text-white mb-1 tracking-wide">{machine.name}</h3>
                  <p class="text-text-light text-xs">{machine.specs}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA lang="en" />
</BaseLayout>
