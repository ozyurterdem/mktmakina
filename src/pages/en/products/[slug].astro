---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHero from '../../../components/PageHero.astro';
import CTA from '../../../components/CTA.astro';
import { products } from '../../../data/products';

export function getStaticPaths() {
  return products.map((p) => ({ params: { slug: p.slug }, props: { product: p } }));
}

const { product } = Astro.props;
const otherProducts = products.filter((p) => p.slug !== product.slug);
---

<BaseLayout title={`${product.name.en} — MKT Makina`} description={product.description.en} lang="en">
  <PageHero title={product.name.en} subtitle="Our Products" image={product.image} />

  <section class="section-padding bg-white">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <div class="reveal">
          <div class="relative overflow-hidden">
            <img src={product.image} alt={product.name.en} class="w-full aspect-[4/3] object-cover" />
            <div class="absolute bottom-0 left-0 w-24 h-1 bg-accent-500"></div>
          </div>
        </div>

        <div class="reveal-right">
          <span class="text-accent-500 text-xs font-semibold uppercase tracking-[0.2em] mb-2 block">Product Detail</span>
          <h2 class="font-heading text-2xl sm:text-3xl font-bold text-navy-800 mb-3">{product.name.en}</h2>
          <div class="accent-bar mb-6"></div>
          <p class="text-steel-600 text-[15px] leading-relaxed mb-8">{product.description.en}</p>

          <h3 class="font-heading text-base font-semibold text-navy-800 mb-4">Scope</h3>
          <ul class="space-y-2.5 mb-8">
            {product.details.en.map((item) => (
              <li class="flex items-start gap-3 text-sm text-steel-700">
                <span class="w-1.5 h-1.5 bg-accent-500 rounded-full mt-2 shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>

          <a href="/en/contact" class="inline-flex items-center gap-2 px-6 py-3 bg-accent-500 text-white text-sm font-semibold uppercase tracking-wider hover:bg-accent-600 transition-colors">
            Contact Us
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>

      <div class="mt-20">
        <h3 class="font-heading text-xl font-bold text-navy-800 mb-6 reveal">Other Products</h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-[1px] bg-steel-200">
          {otherProducts.map((p) => (
            <a href={`/en/products/${p.slug}`} class="group block bg-white overflow-hidden reveal">
              <div class="relative aspect-[4/3] overflow-hidden">
                <img src={p.image} alt={p.name.en} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-navy-950/70 to-transparent"></div>
              </div>
              <div class="p-3">
                <h4 class="font-heading text-xs font-semibold text-navy-800 group-hover:text-accent-600 transition-colors tracking-wide">{p.name.en}</h4>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTA lang="en" />
</BaseLayout>
