---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTA from '../../components/CTA.astro';

const references = [
  { name: 'Toyota Boshoku', image: '/images/references/toyota-boshoku_197.jpg', sector: 'Automotive' },
  { name: 'TSI', image: '/images/references/tsi_198.jpg', sector: 'Aviation' },
  { name: 'Dogus', image: '/images/references/dogus_187.jpg', sector: 'Automotive' },
  { name: 'Elimsan', image: '/images/references/elimsan_188.jpg', sector: 'Industry' },
  { name: 'Mikrosan', image: '/images/references/mikrosan_192.jpg', sector: 'Industry' },
  { name: 'Demka Dovme Celik', image: '/images/references/demka-dovme-celik-sanayi_186.jpg', sector: 'Steel' },
  { name: 'Neutec Ilac', image: '/images/references/neutec-ilac-sanayi_193.jpg', sector: 'Pharma' },
  { name: 'Rad-Tek Radyator', image: '/images/references/rad-tek-radyator-metal_195.jpg', sector: 'Metal' },
  { name: 'Arma Filtre', image: '/images/references/arma-filtre-sistemleri_185.jpg', sector: 'Filter Systems' },
];
---

<BaseLayout title="References — MKT Makina" description="MKT Makina references and partners." lang="en" hasHero={false}>
  <PageHero title="References" subtitle="Our trusted partners" />

  <section class="section-padding bg-white">
    <div class="container-custom max-w-[1200px]">
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-[1px] bg-border">
        {references.map((ref) => (
          <div class="flex items-center justify-center p-8 bg-white hover:bg-surface transition-colors" data-animate="fade-up">
            <img src={ref.image} alt={ref.name} class="max-h-14 max-w-[140px] object-contain ref-logo" loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA lang="en" />
</BaseLayout>
