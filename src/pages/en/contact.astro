---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import FormHandler from '../../components/FormHandler.astro';
---

<BaseLayout title="Contact — MKT Makina" description="MKT Makina contact information. Address: Hanlıköy Mah. Akgün Cad. No:1 Arifiye / Sakarya, Turkey." lang="en">
  <PageHero title="Contact" subtitle="Get in touch with us" />

  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12">
        <div class="reveal">
          <h2 class="font-heading text-2xl font-bold text-navy-800 mb-8">MKT Makina Kalıp Takım</h2>
          <div class="space-y-6">
            <div class="flex gap-4 p-5 bg-steel-50 rounded-lg">
              <div class="w-12 h-12 bg-accent-500 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-sm font-semibold text-navy-800 uppercase tracking-wide mb-1">Address</h3>
                <p class="text-steel-600">Hanlıköy Mah. Akgün Cad. No:1<br />Arifiye / Sakarya, Turkey</p>
              </div>
            </div>
            <div class="flex gap-4 p-5 bg-steel-50 rounded-lg">
              <div class="w-12 h-12 bg-accent-500 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-sm font-semibold text-navy-800 uppercase tracking-wide mb-1">Phone</h3>
                <a href="tel:+902642761880" class="text-steel-600 hover:text-accent-600 transition-colors block">+90 264 276 18 80</a>
                <span class="text-steel-400 text-sm">Fax: +90 264 276 18 77</span>
              </div>
            </div>
            <div class="flex gap-4 p-5 bg-steel-50 rounded-lg">
              <div class="w-12 h-12 bg-accent-500 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-sm font-semibold text-navy-800 uppercase tracking-wide mb-1">Email</h3>
                <a href="mailto:info@mktmakina.com" class="text-steel-600 hover:text-accent-600 transition-colors">info@mktmakina.com</a>
              </div>
            </div>
          </div>
        </div>

        <div class="reveal">
          <div class="bg-navy-800 rounded-xl p-8">
            <h2 class="font-heading text-xl font-bold text-white mb-6">Contact Form</h2>
            <form class="space-y-4" id="contact-form">
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label for="en-name" class="block text-steel-400 text-sm mb-1">Full Name</label>
                  <input type="text" id="en-name" name="name" required class="w-full px-4 py-3 bg-navy-900 border border-navy-700 rounded-md text-white placeholder-steel-600 focus:border-accent-500 focus:outline-none transition-colors" />
                </div>
                <div>
                  <label for="en-email" class="block text-steel-400 text-sm mb-1">Email</label>
                  <input type="email" id="en-email" name="email" required class="w-full px-4 py-3 bg-navy-900 border border-navy-700 rounded-md text-white placeholder-steel-600 focus:border-accent-500 focus:outline-none transition-colors" />
                </div>
              </div>
              <div>
                <label for="en-message" class="block text-steel-400 text-sm mb-1">Message</label>
                <textarea id="en-message" name="message" rows="5" required class="w-full px-4 py-3 bg-navy-900 border border-navy-700 rounded-md text-white placeholder-steel-600 focus:border-accent-500 focus:outline-none transition-colors resize-none"></textarea>
              </div>
              <button type="submit" class="w-full px-6 py-4 bg-accent-500 text-white font-semibold uppercase tracking-wide rounded-md hover:bg-accent-600 transition-colors text-sm">Send</button>
            </form>
          </div>
        </div>
      </div>
      <!-- Map -->
      <div class="mt-16 reveal">
        <div class="rounded-xl overflow-hidden shadow-lg h-80">
          <iframe
            src="https://maps.google.com/maps?q=40.7257778,30.3876111&z=17&output=embed"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="MKT Makina Location"
          ></iframe>
        </div>
      </div>
    </div>
  </section>
  <FormHandler formId="contact-form" successMessage="Message sent!" />
</BaseLayout>
