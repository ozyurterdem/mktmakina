---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTA from '../../components/CTA.astro';

const certGroups = [
  {
    title: 'Quality Certificates',
    subtitle: 'Compliance with aviation and automotive industry standards',
    items: [
      { name: 'AS9100D Certificate', desc: 'Aerospace Quality Management System', image: '/images/belgeler/AS9100D.jpg' },
      { name: 'KIWA Certificate', desc: 'International Quality Certification', image: '/images/belgeler/KIWA.jpg' },
      { name: 'Quality Certificate', desc: 'ISO 9001:2015 Quality Management System', image: '/images/belgeler/Belge1.jpg' },
      { name: 'Quality Certificate', desc: 'Certificate Supplement', image: '/images/belgeler/Belge2.jpg' },
    ],
  },
  {
    title: 'ERP System',
    subtitle: 'Enterprise resource planning and production tracking',
    items: [
      { name: 'ERP System', desc: 'Production, inventory, quality and customer tracking — Integrated management', image: '/images/belgeler/5.jpg' },
      { name: 'ERP Dashboard', desc: 'Real-time production and performance monitoring', image: '/images/belgeler/6.jpg' },
    ],
  },
  {
    title: 'CAD / CAM',
    subtitle: 'Computer-aided design and manufacturing software',
    items: [
      { name: 'CAD - CAM Software', desc: 'SolidWorks, Mastercam — 3D modeling and CNC programming', image: '/images/belgeler/7.jpg' },
      { name: 'CAD - CAM Applications', desc: 'Computer-aided manufacturing for precision machining', image: '/images/belgeler/8.jpg' },
    ],
  },
];
---

<BaseLayout title="Certificates — MKT Makina" description="MKT Makina quality certificates, AS9100D certification, ISO 9001:2015, ERP system and CAD/CAM infrastructure." lang="en">
  <PageHero title="Certificates" subtitle="Quality certificates, ERP system and CAD/CAM infrastructure" />

  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="space-y-20">
        {certGroups.map((group) => (
          <div class="reveal">
            <div class="flex items-center gap-4 mb-8">
              <div class="accent-bar"></div>
              <div>
                <h2 class="font-heading text-2xl sm:text-3xl font-bold text-navy-800">{group.title}</h2>
                <p class="text-steel-500 text-sm mt-1">{group.subtitle}</p>
              </div>
            </div>

            <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
              {group.items.map((item, i) => (
                <a
                  href={item.image}
                  target="_blank"
                  rel="noopener"
                  class={`group block rounded-xl overflow-hidden card-premium reveal delay-${(i % 4) + 1}`}
                >
                  <div class="relative aspect-[3/4] overflow-hidden bg-steel-100">
                    <img
                      src={item.image}
                      alt={item.name}
                      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-navy-950/0 group-hover:bg-navy-950/30 transition-colors duration-500 flex items-center justify-center">
                      <div class="w-14 h-14 rounded-full bg-white/90 flex items-center justify-center opacity-0 group-hover:opacity-100 scale-50 group-hover:scale-100 transition-all duration-500 shadow-xl">
                        <svg class="w-6 h-6 text-navy-800" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
                        </svg>
                      </div>
                    </div>
                  </div>
                  <div class="p-4 bg-white">
                    <h3 class="font-heading text-sm font-semibold text-navy-800 uppercase tracking-wide mb-1">{item.name}</h3>
                    <p class="text-steel-500 text-xs leading-relaxed">{item.desc}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA lang="en" />
</BaseLayout>
