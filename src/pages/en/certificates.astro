---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTA from '../../components/CTA.astro';

const certGroups = [
  {
    title: 'Quality Certificates',
    subtitle: 'Aviation and automotive industry compliance',
    items: [
      { name: 'AS9100D Certificate', desc: 'Aerospace Quality Management System', image: '/images/belgeler/AS9100D.jpg' },
      { name: 'KIWA Certificate', desc: 'International Quality Certification', image: '/images/belgeler/KIWA.jpg' },
      { name: 'Quality Certificate', desc: 'ISO 9001:2015 Quality Management', image: '/images/belgeler/Belge1.jpg' },
      { name: 'Certificate Annex', desc: 'Certificate Supplement', image: '/images/belgeler/Belge2.jpg' },
    ],
  },
  {
    title: 'ERP System',
    subtitle: 'Enterprise resource planning and production tracking',
    items: [
      { name: 'ERP System', desc: 'Production, inventory, quality and customer tracking', image: '/images/belgeler/5.jpg' },
      { name: 'ERP Dashboard', desc: 'Real-time production and performance monitoring', image: '/images/belgeler/6.jpg' },
    ],
  },
  {
    title: 'CAD / CAM',
    subtitle: 'Computer-aided design and manufacturing software',
    items: [
      { name: 'CAD - CAM Software', desc: 'SolidWorks, Mastercam — 3D modeling and CNC programming', image: '/images/belgeler/7.jpg' },
      { name: 'CAD - CAM Applications', desc: 'Computer-aided manufacturing for precision machining', image: '/images/belgeler/8.jpg' },
    ],
  },
];
---

<BaseLayout title="Certificates — MKT Makina" description="MKT Makina quality certificates, AS9100D, ISO 9001:2015, ERP and CAD/CAM." lang="en">
  <PageHero title="Certificates" subtitle="Quality certificates, ERP system and CAD/CAM infrastructure" />

  <section class="section-padding bg-white">
    <div class="max-w-[1400px] mx-auto px-6">
      <div class="space-y-16">
        {certGroups.map((group) => (
          <div class="reveal">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-10 h-[2px] bg-accent-500"></div>
              <div>
                <h2 class="font-heading text-xl sm:text-2xl font-bold text-navy-800">{group.title}</h2>
                <p class="text-steel-500 text-sm mt-0.5">{group.subtitle}</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
              {group.items.map((item) => (
                <a href={item.image} target="_blank" rel="noopener" class="group block border border-steel-200 overflow-hidden card-hover">
                  <div class="relative aspect-[3/4] overflow-hidden bg-steel-100">
                    <img src={item.image} alt={item.name} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                  </div>
                  <div class="p-4 bg-white">
                    <h3 class="font-heading text-xs font-semibold text-navy-800 uppercase tracking-wide mb-0.5">{item.name}</h3>
                    <p class="text-steel-500 text-xs">{item.desc}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA lang="en" />
</BaseLayout>
