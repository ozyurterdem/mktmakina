---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTA from '../../components/CTA.astro';
---

<BaseLayout title="About — MKT Makina" description="About MKT Makina: high quality precision machined parts and plastic injection solutions for aviation and automotive industry since 2007." lang="en">
  <PageHero title="About Us" subtitle="Aviation-grade precision manufacturing since 2007" />

  <section class="section-padding bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-start reveal">
        <div>
          <h2 class="font-heading text-2xl font-bold text-navy-800 mb-6">About Us</h2>
          <div class="space-y-4 text-steel-600 leading-relaxed">
            <p>MKT Makina manufactures high quality precision machined parts and plastic injection parts for the aviation and automotive industry. Founded in 2007, the company has produced molds, fixtures, apparatus and quality control gauges for many sectors since early years of business.</p>
            <p>It expanded the machine park and has supplied its products to TSI Aviation Seats since 2012.</p>
            <p>MKT Makina has been certified to AS9100, the quality management system has been structured according to the requirements of aviation and automotive industry.</p>
          </div>

          <h3 class="font-heading text-lg font-semibold text-navy-800 mt-8 mb-4">Product Range</h3>
          <ul class="space-y-3">
            {[
              'Machining parts and sub-assemblies',
              'Fixtures',
              'Apparatuses',
              'Quality control gauges',
              'Plastic injection molds',
              'Plastic injection parts',
            ].map((item) => (
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-accent-500 flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <span class="text-steel-700">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="relative">
          <img src="/images/slide1.jpg" alt="MKT Makina Production" class="rounded-xl shadow-2xl w-full aspect-[4/3] object-cover" />
          <div class="absolute -bottom-4 -left-4 bg-navy-800 text-white px-6 py-4 rounded-lg shadow-xl">
            <div class="font-heading text-3xl font-bold text-accent-500">2007</div>
            <div class="text-xs text-steel-400 uppercase tracking-wider">Since</div>
          </div>
        </div>
      </div>

      <!-- Mission & Vision -->
      <div class="grid lg:grid-cols-2 gap-12 mt-16 reveal">
        <div class="p-8 bg-navy-800 rounded-xl text-white">
          <h2 class="font-heading text-2xl font-bold mb-4">Our Mission</h2>
          <div class="space-y-4 text-steel-300 leading-relaxed">
            <p>To manage the customers' expectations with consistent quality approach, to focus on creating value with our customer oriented working strategy, and to provide customer satisfaction by engineering and management science with the latest technological facilities.</p>
          </div>
        </div>
        <div class="p-8 bg-accent-500 rounded-xl text-white">
          <h2 class="font-heading text-2xl font-bold mb-4">Our Vision</h2>
          <div class="space-y-4 text-white/90 leading-relaxed">
            <p>To provide easy, reliable, economic and high quality service. The customer satisfaction is the first priority. To have 100% quality performance and find fast, correct and reliable solutions with continuous progress.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA lang="en" />
</BaseLayout>
