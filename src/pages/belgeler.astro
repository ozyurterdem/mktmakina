---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTA from '../components/CTA.astro';

const certGroups = [
  {
    title: 'Kalite Belgeleri',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />',
    items: [
      { name: 'AS9100 Sertifikası', desc: 'Havacılık ve Uzay Kalite Yönetim Sistemi' },
      { name: 'ISO 9001:2015', desc: 'Kalite Yönetim Sistemi' },
    ],
  },
  {
    title: 'ERP Sistemi',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />',
    items: [
      { name: 'ERP System', desc: 'Kurumsal Kaynak Planlama Sistemi — Üretim, stok ve kalite takibi' },
    ],
  },
  {
    title: 'CAD / CAM',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />',
    items: [
      { name: 'CAD Yazılımları', desc: 'Bilgisayar Destekli Tasarım — 3D modelleme ve teknik çizim' },
      { name: 'CAM Yazılımları', desc: 'Bilgisayar Destekli İmalat — CNC programlama ve simülasyon' },
    ],
  },
];
---

<BaseLayout title="Belgelerimiz — MKT Makina Kalıp Takım" description="MKT Makina belgeleri: AS9100, ISO 9001 sertifikaları, ERP sistemi, CAD/CAM yazılımları." lang="tr">
  <PageHero title="Belgelerimiz" subtitle="Kalite standartlarımız ve teknoloji altyapımız" />

  <section class="section-padding bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <div class="space-y-12">
        {certGroups.map((group) => (
          <div class="reveal">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 bg-accent-50 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-accent-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={group.icon} />
              </div>
              <h2 class="font-heading text-xl font-bold text-navy-800">{group.title}</h2>
            </div>
            <div class="grid sm:grid-cols-2 gap-4">
              {group.items.map((item) => (
                <div class="p-6 bg-steel-50 rounded-lg border border-steel-200 hover:border-accent-500/30 hover:shadow-md transition-all">
                  <h3 class="font-heading text-base font-semibold text-navy-800 mb-2">{item.name}</h3>
                  <p class="text-steel-500 text-sm">{item.desc}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA lang="tr" />
</BaseLayout>
