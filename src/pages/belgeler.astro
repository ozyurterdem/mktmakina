---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTA from '../components/CTA.astro';

const certGroups = [
  {
    title: 'Kalite Belgeleri',
    subtitle: 'Havacilik ve otomotiv sanayi standartlarina uygunluk',
    items: [
      { name: 'AS9100D Sertifikasi', desc: 'Havacilik ve Uzay Kalite Yonetim Sistemi', image: '/images/belgeler/AS9100D.jpg' },
      { name: 'KIWA Sertifikasi', desc: 'Uluslararasi Kalite Belgelendirme', image: '/images/belgeler/KIWA.jpg' },
      { name: 'Kalite Belgesi', desc: 'ISO 9001:2015 Kalite Yonetim Sistemi', image: '/images/belgeler/Belge1.jpg' },
      { name: 'Kalite Belgesi', desc: 'Sertifika Eki', image: '/images/belgeler/Belge2.jpg' },
    ],
  },
  {
    title: 'MES Sistemi',
    subtitle: 'Uretim yurutme sistemi — gercek zamanli uretim kontrolu',
    items: [
      { name: 'MES System', desc: 'Uretim surecleri, is emirleri ve kalite kontrol takibi', image: '/images/belgeler/MES.jpg' },
    ],
  },
  {
    title: 'ERP Sistemi',
    subtitle: 'Kurumsal kaynak planlama ve uretim takip sistemi',
    items: [
      { name: 'ERP System', desc: 'Uretim, stok, kalite ve musteri takibi — Entegre yonetim sistemi', image: '/images/belgeler/5.jpg' },
      { name: 'ERP Dashboard', desc: 'Gercek zamanli uretim ve performans izleme', image: '/images/belgeler/6.jpg' },
    ],
  },
  {
    title: 'CAD / CAM',
    subtitle: 'Bilgisayar destekli tasarim ve uretim yazilimlari',
    items: [
      { name: 'CAD - CAM Yazilimlari', desc: 'SolidWorks, Mastercam — 3D modelleme ve CNC programlama', image: '/images/belgeler/7.jpg' },
      { name: 'CAD - CAM Uygulamalari', desc: 'Hassas isleme icin bilgisayar destekli uretim', image: '/images/belgeler/8.jpg' },
    ],
  },
];
---

<BaseLayout title="Belgeler — MKT Makina A.Ş." description="MKT Makina kalite belgeleri, AS9100D sertifikasi, ISO 9001:2015, ERP sistemi ve CAD/CAM altyapisi." lang="tr" hasHero={false}>
  <PageHero title="Belgelerimiz" subtitle="Kalite belgeleri, ERP sistemi ve CAD/CAM altyapimiz" />

  <section class="section-padding">
    <div class="container-custom">
      <div class="space-y-16">
        {certGroups.map((group) => (
          <div data-animate="fade-up">
            <div class="flex items-center gap-4 mb-6">
              <div class="accent-bar"></div>
              <div>
                <h2 class="font-heading text-xl sm:text-2xl font-bold text-white">{group.title}</h2>
                <p class="text-text-light text-sm mt-0.5">{group.subtitle}</p>
              </div>
            </div>

            <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
              {group.items.map((item) => (
                <a href={item.image} target="_blank" rel="noopener" class="group card overflow-hidden">
                  <div class="relative aspect-[3/4] overflow-hidden bg-surface">
                    <img src={item.image} alt={item.name} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                    <div class="absolute inset-0 bg-primary-dark/0 group-hover:bg-primary-dark/30 transition-colors duration-500 flex items-center justify-center">
                      <div class="w-10 h-10 bg-primary-light flex items-center justify-center opacity-0 group-hover:opacity-100 scale-75 group-hover:scale-100 transition-all duration-300">
                        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" /></svg>
                      </div>
                    </div>
                  </div>
                  <div class="p-4">
                    <h3 class="font-heading text-xs font-semibold text-white uppercase tracking-wide mb-0.5">{item.name}</h3>
                    <p class="text-text-light text-xs">{item.desc}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA lang="tr" />
</BaseLayout>
