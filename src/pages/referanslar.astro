---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTA from '../components/CTA.astro';

const references = [
  { name: 'Toyota Boshoku', image: '/images/references/toyota-boshoku_197.jpg', sector: 'Otomotiv' },
  { name: 'TSI', image: '/images/references/tsi_198.jpg', sector: 'Havacılık' },
  { name: 'Doğuş', image: '/images/references/dogus_187.jpg', sector: 'Otomotiv' },
  { name: 'Elimsan', image: '/images/references/elimsan_188.jpg', sector: 'Sanayi' },
  { name: 'Mikrosan', image: '/images/references/mikrosan_192.jpg', sector: 'Sanayi' },
  { name: 'Demka Dövme Çelik', image: '/images/references/demka-dovme-celik-sanayi_186.jpg', sector: 'Çelik' },
  { name: 'Neutec İlaç', image: '/images/references/neutec-ilac-sanayi_193.jpg', sector: 'İlaç' },
  { name: 'Rad-Tek Radyatör', image: '/images/references/rad-tek-radyator-metal_195.jpg', sector: 'Metal' },
  { name: 'Arma Filtre', image: '/images/references/arma-filtre-sistemleri_185.jpg', sector: 'Filtre Sistemleri' },
];
---

<BaseLayout title="Referanslar — MKT Makina Kalıp Takım" description="MKT Makina referansları: Toyota Boshoku, TSI Havacılık, Doğuş, Elimsan ve daha fazlası." lang="tr">
  <PageHero title="Referanslar" subtitle="Güvenilir iş ortaklarımız" />

  <section class="section-padding bg-white">
    <div class="max-w-[1200px] mx-auto px-6">
      <p class="text-center text-steel-500 text-base mb-12 max-w-2xl mx-auto reveal">
        Havacılık, otomotiv, ilaç ve ağır sanayi sektörlerinden güçlü referanslarımızla uzun vadeli iş birlikleri sürdürüyoruz.
      </p>

      <div class="grid grid-cols-2 sm:grid-cols-3 gap-[1px] bg-steel-200">
        {references.map((ref) => (
          <div class="group flex flex-col items-center justify-center p-8 bg-white hover:bg-steel-50 transition-colors reveal">
            <div class="h-16 flex items-center justify-center mb-3">
              <img src={ref.image} alt={ref.name} class="max-h-14 max-w-[140px] object-contain ref-logo" loading="lazy" />
            </div>
            <h3 class="font-heading text-xs font-semibold text-navy-800 text-center tracking-wide">{ref.name}</h3>
            <span class="text-accent-500 text-[10px] mt-1 uppercase tracking-wider opacity-0 group-hover:opacity-100 transition-opacity">{ref.sector}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA lang="tr" />
</BaseLayout>
