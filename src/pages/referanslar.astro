---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTA from '../components/CTA.astro';

const references = [
  { name: 'Toyota Boshoku', image: '/images/references/toyota-boshoku_197.jpg', sector: 'Otomotiv' },
  { name: 'TSI', image: '/images/references/tsi_198.jpg', sector: 'Havacilik' },
  { name: 'Dogus', image: '/images/references/dogus_187.jpg', sector: 'Otomotiv' },
  { name: 'Elimsan', image: '/images/references/elimsan_188.jpg', sector: 'Sanayi' },
  { name: 'Mikrosan', image: '/images/references/mikrosan_192.jpg', sector: 'Sanayi' },
  { name: 'Demka Dovme Celik', image: '/images/references/demka-dovme-celik-sanayi_186.jpg', sector: 'Celik' },
  { name: 'Neutec Ilac', image: '/images/references/neutec-ilac-sanayi_193.jpg', sector: 'Ilac' },
  { name: 'Rad-Tek Radyator', image: '/images/references/rad-tek-radyator-metal_195.jpg', sector: 'Metal' },
  { name: 'Arma Filtre', image: '/images/references/arma-filtre-sistemleri_185.jpg', sector: 'Filtre Sistemleri' },
];
---

<BaseLayout title="Referanslar — MKT Makina Kalip Takim" description="MKT Makina referanslari: Toyota Boshoku, TSI Havacilik, Dogus, Elimsan ve daha fazlasi." lang="tr" hasHero={false}>
  <PageHero title="Referanslar" subtitle="Guvenilir is ortaklarimiz" />

  <section class="section-padding bg-white">
    <div class="container-custom max-w-[1200px]">
      <p class="text-center text-text-light text-base mb-12 max-w-2xl mx-auto" data-animate="fade-up">
        Havacilik, otomotiv, ilac ve agir sanayi sektorlerinden guclu referanslarimizla uzun vadeli is birlikleri surduruyo ruz.
      </p>

      <div class="grid grid-cols-2 sm:grid-cols-3 gap-[1px] bg-border">
        {references.map((ref) => (
          <div class="group flex flex-col items-center justify-center p-8 bg-white hover:bg-surface transition-colors" data-animate="fade-up">
            <div class="h-16 flex items-center justify-center mb-3">
              <img src={ref.image} alt={ref.name} class="max-h-14 max-w-[140px] object-contain ref-logo" loading="lazy" />
            </div>
            <h3 class="font-heading text-xs font-semibold text-primary text-center tracking-wide">{ref.name}</h3>
            <span class="text-accent text-[10px] mt-1 uppercase tracking-wider opacity-0 group-hover:opacity-100 transition-opacity">{ref.sector}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA lang="tr" />
</BaseLayout>
