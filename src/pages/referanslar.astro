---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTA from '../components/CTA.astro';

const references = [
  { name: 'Toyota Boshoku', image: '/images/references/toyota-boshoku_197.jpg' },
  { name: 'TSI', image: '/images/references/tsi_198.jpg' },
  { name: 'Dogus', image: '/images/references/dogus_187.jpg' },
  { name: 'Elimsan', image: '/images/references/elimsan_188.jpg' },
  { name: 'Mikrosan', image: '/images/references/mikrosan_192.jpg' },
  { name: 'Demka Dovme Celik', image: '/images/references/demka-dovme-celik-sanayi_186.jpg' },
  { name: 'Neutec Ilac', image: '/images/references/neutec-ilac-sanayi_193.jpg' },
  { name: 'Rad-Tek Radyator', image: '/images/references/rad-tek-radyator-metal_195.jpg' },
  { name: 'Arma Filtre', image: '/images/references/arma-filtre-sistemleri_185.jpg' },
];
---

<BaseLayout title="Referanslar — MKT Makina Kalip Takim" description="MKT Makina referanslari: Toyota Boshoku, TSI Havacilik, Dogus, Elimsan ve daha fazlasi." lang="tr" hasHero={false}>
  <PageHero title="Referanslar" subtitle="Güvenilir iş ortaklarımız" />

  <section class="ref-page-section">
    <div class="container-custom max-w-[1000px]">
      <p class="text-center text-white/40 text-base mb-14 max-w-2xl mx-auto" data-animate="fade-up">
        Havacilik, otomotiv, ilac ve agir sanayi sektorlerinden guclu referanslarimizla uzun vadeli is birlikleri surduruyoruz.
      </p>

      <div class="ref-page-grid">
        {references.map((ref, i) => (
          <div class="ref-page-card" data-animate="fade-up" data-delay={String(i * 80)}>
            <img src={ref.image} alt={ref.name} class="ref-page-logo" loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA lang="tr" />
</BaseLayout>

<style>
  .ref-page-section {
    padding-block: 4rem 6rem;
    background: linear-gradient(180deg, var(--color-primary-dark) 0%, var(--color-primary) 100%);
    position: relative;
  }

  .ref-page-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .ref-page-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
  }

  .ref-page-card {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 16 / 9;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 2rem;
    backdrop-filter: blur(8px);
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .ref-page-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(200, 162, 60, 0.2);
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.3);
  }

  .ref-page-logo {
    max-height: 56px;
    max-width: 80%;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.7;
    transition: all 0.4s ease;
  }
  .ref-page-card:hover .ref-page-logo {
    opacity: 1;
  }
</style>
