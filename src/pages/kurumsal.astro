---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTA from '../components/CTA.astro';

const tabs = [
  { id: 'about', label: 'Hakkımızda' },
  { id: 'mission', label: 'Misyon & Vizyon' },
  { id: 'quality', label: 'Kalite Politikamız' },
];
---

<BaseLayout title="Kurumsal — MKT Makina Kalıp Takım" description="MKT Makina hakkında, misyon, vizyon ve kalite politikamız. AS9100 sertifikalı havacılık ve otomotiv parça üreticisi." lang="tr">
  <PageHero title="Kurumsal" subtitle="2007'den bu yana havacılık hassasiyetinde üretim" />

  <section class="section-padding bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <!-- Tab Navigation -->
      <div class="flex flex-wrap gap-2 mb-12 border-b border-steel-200 pb-4" id="corp-tabs">
        {tabs.map((tab, i) => (
          <button
            data-tab={tab.id}
            class:list={[
              'px-5 py-2.5 font-heading text-sm uppercase tracking-wide rounded-md transition-all',
              i === 0 ? 'bg-accent-500 text-white' : 'text-navy-800 hover:bg-steel-50',
            ]}
          >
            {tab.label}
          </button>
        ))}
      </div>

      <!-- Hakkımızda -->
      <div id="tab-about" class="tab-content">
        <div class="grid lg:grid-cols-2 gap-12 items-start">
          <div>
            <h2 class="font-heading text-2xl font-bold text-navy-800 mb-6">Hakkımızda</h2>
            <div class="space-y-4 text-steel-600 leading-relaxed">
              <p>MKT Makina, havacılık ve otomotiv sanayii için yüksek kaliteli hassas işleme parçalar ve plastik enjeksiyon parçalar üretmektedir. 2007 yılında kurulan şirket, iş hayatının ilk yıllarından bu yana kalıp, fikstür, aparat ve kalite kontrol mastarı imalatı da yapmaktadır.</p>
              <p>Makina parkurunu büyüterek 2012 yılından itibaren TSI Uçak Koltuk firmasına talaşlı imalat parçalarının üretimine başlamıştır.</p>
              <p>AS9100 sertifikasına sahip olup, kalite yönetim sistemini havacılık ve otomotiv sanayi gerekliliklerine uygun olarak yapılandırmıştır.</p>
            </div>

            <h3 class="font-heading text-lg font-semibold text-navy-800 mt-8 mb-4">Ürün Yelpazemiz</h3>
            <ul class="space-y-3">
              {[
                'Talaşlı imalat parçaları ve montaj grupları',
                'Fikstürler',
                'Aparatlar',
                'Kalite kontrol mastarları',
                'Plastik enjeksiyon kalıpları',
                'Plastik enjeksiyon baskı',
              ].map((item) => (
                <li class="flex items-start gap-3">
                  <div class="w-5 h-5 rounded-full bg-accent-500 flex items-center justify-center shrink-0 mt-0.5">
                    <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                  </div>
                  <span class="text-steel-700">{item}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="relative">
            <img src="/images/slide1.jpg" alt="MKT Makina Üretim" class="rounded-xl shadow-2xl w-full aspect-[4/3] object-cover" />
            <div class="absolute -bottom-4 -left-4 bg-navy-800 text-white px-6 py-4 rounded-lg shadow-xl">
              <div class="font-heading text-3xl font-bold text-accent-500">2007</div>
              <div class="text-xs text-steel-400 uppercase tracking-wider">Kuruluş</div>
            </div>
          </div>
        </div>

        <h3 class="font-heading text-lg font-semibold text-navy-800 mt-12 mb-4">Temel Prensiplerimiz</h3>
        <div class="grid sm:grid-cols-2 gap-4">
          {[
            'Müşteri gereksinimlerini karşılayan yüksek kalite ürünler üretmek',
            'Son teknoloji ekipman, alet ve yazılım programlarını kullanmak',
            'Müşteriye özgü çözümler sunmak',
            'İleri endüstriyel standartlara uygun kalite yönetim sistemini sürdürmek',
          ].map((item) => (
            <div class="flex items-start gap-3 p-4 bg-steel-50 rounded-lg">
              <svg class="w-5 h-5 text-accent-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <span class="text-steel-700 text-sm">{item}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Misyon & Vizyon -->
      <div id="tab-mission" class="tab-content hidden">
        <div class="grid lg:grid-cols-2 gap-12">
          <div class="p-8 bg-navy-800 rounded-xl text-white">
            <div class="w-12 h-12 bg-accent-500/20 rounded-lg flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-accent-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h2 class="font-heading text-2xl font-bold mb-4">Misyon</h2>
            <div class="space-y-4 text-steel-300 leading-relaxed">
              <p>Müşterilerimizin beklentilerini istikrarlı kalite anlayışı ile karşılayarak değer yaratmayı esas alan kurumsal yapımız, müşteri odaklı çalışma stratejimiz ve rekabetçi büyüme potansiyelimiz ile "en iyi" şekilde değerleri yönetmek.</p>
              <p>Mühendislik ve yönetim bilimlerindeki en son teknolojik olanakları kullanarak daima yüksek kalite standartlarında gelişen imalat teknolojileriyle, müşteri memnuniyetini ön planda tutmak ve mükemmelleşme anlayışını esas alarak, insana, doğaya, çevreye ve topluma saygılı ürünler üretmektedir.</p>
            </div>
          </div>
          <div class="p-8 bg-accent-500 rounded-xl text-white">
            <div class="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            </div>
            <h2 class="font-heading text-2xl font-bold mb-4">Vizyon</h2>
            <div class="space-y-4 text-white/90 leading-relaxed">
              <p>İmalat sanayisinde kolay, güvenli, ekonomik ve kaliteli bir hizmet sunabilmek, müşteri memnuniyeti öncelikli, toplam hizmet kalitesi felsefesi ile çalışarak, %100 kalite performansı ve kusursuz hizmet anlayışı ile hızlı, doğru, güvenilir çözümler üretmek ve sürekli gelişmek MKT Makina'nın en önemli vizyonudur.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Kalite Politikası -->
      <div id="tab-quality" class="tab-content hidden">
        <div class="max-w-3xl">
          <div class="flex items-center gap-4 mb-8">
            <div class="w-16 h-16 bg-accent-50 rounded-xl flex items-center justify-center">
              <svg class="w-8 h-8 text-accent-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div>
              <h2 class="font-heading text-2xl font-bold text-navy-800">Kalite Politikamız</h2>
              <p class="text-steel-500">AS9100 Sertifikalı Kalite Yönetim Sistemi</p>
            </div>
          </div>

          <p class="text-steel-600 leading-relaxed mb-8">Havacılık ve otomotiv sanayii için metal ve metal olmayan parçalar ile montaj gruplarının imalatını yapan firmamız, kuruluşun bağlamı ve stratejik planıyla uyumlu olarak kalite politikasını aşağıdaki gibi belirlemiştir:</p>

          <div class="space-y-4">
            {[
              'İlgili tarafların şartları ve AS9100 standardı şartlarını karşılayan bir Kalite Yönetim Sistemi kurmak ve bu kapsamda istenen şartlara uygun ürünler üretmek',
              'Kalite Yönetim Sistemini sürekli iyileştirmek, bu amaçla kalite hedeflerini oluşturmak ve takibini sağlamak',
              'Müşteri memnuniyetini sağlamak, yenilikçi ve güvenilir yaklaşımlarla beklentilerin önüne geçmek',
              'Tüm çalışanlarımızın kalite politikası bilincine sahip olması ve bu doğrultuda çalışmasını sağlamak',
              'Ürettiğimiz her ürünün sorumluluğunu taşımak ve müşteriye gerekli bilgi ve teknik desteği sağlamak',
              'İstenen kalite hammadde, son teknoloji makine parkuru ve uzman işgücünü birleştirmek',
            ].map((item, i) => (
              <div class="flex items-start gap-4 p-4 bg-steel-50 rounded-lg">
                <span class="w-8 h-8 bg-accent-500 text-white rounded-full flex items-center justify-center shrink-0 font-heading font-bold text-sm">{i + 1}</span>
                <span class="text-steel-700 leading-relaxed">{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA lang="tr" />
</BaseLayout>

<script>
  const tabs = document.querySelectorAll('#corp-tabs button');
  const contents = document.querySelectorAll('.tab-content');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-tab');
      tabs.forEach((t) => { t.classList.remove('bg-accent-500', 'text-white'); t.classList.add('text-navy-800'); });
      tab.classList.add('bg-accent-500', 'text-white'); tab.classList.remove('text-navy-800');
      contents.forEach((c) => c.classList.add('hidden'));
      document.getElementById(`tab-${target}`)?.classList.remove('hidden');
    });
  });
</script>
