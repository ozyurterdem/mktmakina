---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout title="Teklif Talep Formu — MKT Makina Kalıp Takım" description="MKT Makina teklif talep formu. Projeniz için fiyat teklifi alın." lang="tr">
  <PageHero title="Teklif Talep Formu" subtitle="Projeniz için fiyat teklifi alın" />

  <section class="section-padding bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <div class="bg-steel-50 rounded-xl p-8 sm:p-10 border border-steel-200 reveal">
        <div class="flex items-center gap-4 mb-8 pb-6 border-b border-steel-200">
          <div class="w-14 h-14 bg-accent-500 rounded-xl flex items-center justify-center">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <div>
            <h2 class="font-heading text-xl font-bold text-navy-800">Teklif Formu</h2>
            <p class="text-steel-500 text-sm">Lütfen aşağıdaki bilgileri doldurun</p>
          </div>
        </div>

        <form class="space-y-5" id="quote-form">
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="q-name" class="block text-navy-800 text-sm font-medium mb-1.5">Ad Soyad *</label>
              <input type="text" id="q-name" name="name" required
                class="w-full px-4 py-3 border border-steel-300 rounded-md focus:border-accent-500 focus:ring-1 focus:ring-accent-500 focus:outline-none transition-colors" />
            </div>
            <div>
              <label for="q-company" class="block text-navy-800 text-sm font-medium mb-1.5">Firma</label>
              <input type="text" id="q-company" name="company"
                class="w-full px-4 py-3 border border-steel-300 rounded-md focus:border-accent-500 focus:ring-1 focus:ring-accent-500 focus:outline-none transition-colors" />
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="q-email" class="block text-navy-800 text-sm font-medium mb-1.5">E-posta *</label>
              <input type="email" id="q-email" name="email" required
                class="w-full px-4 py-3 border border-steel-300 rounded-md focus:border-accent-500 focus:ring-1 focus:ring-accent-500 focus:outline-none transition-colors" />
            </div>
            <div>
              <label for="q-phone" class="block text-navy-800 text-sm font-medium mb-1.5">Telefon *</label>
              <input type="tel" id="q-phone" name="phone" required
                class="w-full px-4 py-3 border border-steel-300 rounded-md focus:border-accent-500 focus:ring-1 focus:ring-accent-500 focus:outline-none transition-colors" />
            </div>
          </div>

          <div>
            <label for="q-product" class="block text-navy-800 text-sm font-medium mb-1.5">İlgilendiğiniz Ürün/Hizmet</label>
            <select id="q-product" name="product"
              class="w-full px-4 py-3 border border-steel-300 rounded-md focus:border-accent-500 focus:ring-1 focus:ring-accent-500 focus:outline-none transition-colors bg-white">
              <option value="">Seçiniz</option>
              <option value="aparatlar">Aparatlar</option>
              <option value="fikstur">Fikstür</option>
              <option value="kaliplar">Kalıplar</option>
              <option value="talasli-imalat">Talaşlı İmalat Parçaları</option>
              <option value="mastarlar">Kalite Kontrol Mastarları</option>
              <option value="plastik-enjeksiyon">Plastik Enjeksiyon</option>
              <option value="diger">Diğer</option>
            </select>
          </div>

          <div>
            <label for="q-detail" class="block text-navy-800 text-sm font-medium mb-1.5">Detaylı Açıklama *</label>
            <textarea id="q-detail" name="detail" rows="6" required
              class="w-full px-4 py-3 border border-steel-300 rounded-md focus:border-accent-500 focus:ring-1 focus:ring-accent-500 focus:outline-none transition-colors resize-none"
              placeholder="Projeniz hakkında detaylı bilgi veriniz. Malzeme, adet, tolerans gibi bilgiler teklif sürecini hızlandırır."></textarea>
          </div>

          <div>
            <label for="q-file" class="block text-navy-800 text-sm font-medium mb-1.5">Dosya Ekle (Teknik çizim, 3D model vb.)</label>
            <input type="file" id="q-file" name="file" accept=".pdf,.dwg,.step,.stp,.iges,.igs,.stl,.jpg,.png"
              class="w-full px-4 py-3 border border-steel-300 rounded-md text-steel-600 file:mr-4 file:py-1 file:px-4 file:rounded-md file:border-0 file:text-sm file:bg-accent-500 file:text-white hover:file:bg-accent-600" />
            <p class="text-steel-400 text-xs mt-1">PDF, DWG, STEP, IGES, STL, JPG, PNG — Maks. 10MB</p>
          </div>

          <button type="submit"
            class="w-full px-6 py-4 bg-accent-500 text-white font-semibold uppercase tracking-wide rounded-md hover:bg-accent-600 transition-colors text-sm shadow-lg">
            Teklif Talebini Gönder
          </button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
