---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTA from '../components/CTA.astro';

const machineGroups = [
  {
    category: '5 Eksen CNC İşleme Merkezleri',
    icon: '⚙️',
    machines: [
      { name: 'DMU 85', specs: 'DMG MORI — 5 Eksen Simultane İşleme' },
      { name: 'DMU 75', specs: 'DMG MORI — 5 Eksen Simultane İşleme' },
      { name: 'HAAS UMC VF3', specs: '5 Eksen CNC İşleme Merkezi' },
      { name: 'HAAS UMC 750', specs: '5 Eksen CNC İşleme Merkezi' },
    ],
  },
  {
    category: '3 Eksen CNC İşleme Merkezleri',
    icon: '🔧',
    machines: [
      { name: 'DMC 1035 V', specs: 'DMG MORI — 3 Eksen İşleme Merkezi' },
      { name: 'DMC 1035 V', specs: 'DMG MORI — 3 Eksen İşleme Merkezi (2. ünite)' },
      { name: 'DMC 835 V', specs: 'DMG MORI — 3 Eksen İşleme Merkezi' },
    ],
  },
  {
    category: 'Tel Erozyon Tezgahları',
    icon: '⚡',
    machines: [
      { name: 'CUT 30P', specs: 'GF Machining — Tel Erozyon (1. ünite)' },
      { name: 'CUT 30P', specs: 'GF Machining — Tel Erozyon (2. ünite)' },
      { name: 'CUT 20P', specs: 'GF Machining — Tel Erozyon' },
    ],
  },
  {
    category: 'Torna & Erozyon',
    icon: '🔩',
    machines: [
      { name: 'CNC Torna', specs: 'CNC Torna Tezgahı' },
      { name: 'Dalma Erozyon', specs: 'Dalma Erozyon Tezgahı' },
    ],
  },
  {
    category: 'Taşlama & Bileme',
    icon: '💎',
    machines: [
      { name: 'Yüzey Taşlama', specs: 'Yüzey Taşlama Makinası' },
      { name: 'Silindirik & Delik Taşlama', specs: 'Silindirik ve Delik Taşlama Makinası' },
      { name: 'Takım Bileme', specs: 'Takım Bileme Tezgahı' },
    ],
  },
  {
    category: 'Konvansiyonel Tezgahlar',
    icon: '🔧',
    machines: [
      { name: 'Universal Freze', specs: 'Universal Freze Tezgahı' },
      { name: 'Universal Torna', specs: 'Universal Torna Tezgahı' },
    ],
  },
  {
    category: 'Plastik Enjeksiyon & Markalama',
    icon: '🏭',
    machines: [
      { name: 'LS LST 280', specs: 'LS — Plastik Enjeksiyon Makinası' },
      { name: 'Laser Markalama', specs: 'Laser Markalama Sistemi' },
    ],
  },
];
---

<BaseLayout title="Makina Parkımız — MKT Makina Kalıp Takım" description="MKT Makina makina parkı: DMG MORI 5 eksen CNC, HAAS işleme merkezleri, GF Machining tel erozyon, plastik enjeksiyon ve daha fazlası." lang="tr">
  <PageHero title="Makina Parkımız" subtitle="İleri teknoloji üretim altyapımız" image="/images/slide3.jpg" />

  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <!-- Summary Stats -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-16 reveal">
        {[
          { value: '4', label: '5 Eksen CNC' },
          { value: '3', label: '3 Eksen CNC' },
          { value: '3', label: 'Tel Erozyon' },
          { value: '20+', label: 'Toplam Tezgah' },
        ].map((stat) => (
          <div class="text-center p-5 bg-navy-800 rounded-lg">
            <div class="font-heading text-3xl font-bold text-accent-500">{stat.value}</div>
            <div class="text-steel-400 text-sm mt-1">{stat.label}</div>
          </div>
        ))}
      </div>

      <!-- Machine Groups -->
      <div class="space-y-12">
        {machineGroups.map((group) => (
          <div class="reveal">
            <h2 class="font-heading text-xl font-bold text-navy-800 mb-6 flex items-center gap-3">
              <span class="text-2xl">{group.icon}</span>
              {group.category}
            </h2>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
              {group.machines.map((machine) => (
                <div class="p-5 bg-steel-50 rounded-lg border border-steel-200 hover:border-accent-500/30 hover:shadow-md transition-all">
                  <h3 class="font-heading text-base font-semibold text-navy-800 mb-1">{machine.name}</h3>
                  <p class="text-steel-500 text-sm">{machine.specs}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA lang="tr" />
</BaseLayout>
