---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTA from '../components/CTA.astro';

const machineGroups = [
  {
    category: '5 Eksen CNC Isleme Merkezleri',
    machines: [
      { name: 'DMU 85', specs: 'DMG MORI — 5 Eksen Simultane Isleme' },
      { name: 'DMU 75', specs: 'DMG MORI — 5 Eksen Simultane Isleme' },
      { name: 'HAAS UMC VF3', specs: '5 Eksen CNC Isleme Merkezi' },
      { name: 'HAAS UMC 750', specs: '5 Eksen CNC Isleme Merkezi' },
    ],
  },
  {
    category: '3 Eksen CNC Isleme Merkezleri',
    machines: [
      { name: 'DMC 1035 V', specs: 'DMG MORI — 3 Eksen Isleme Merkezi' },
      { name: 'DMC 1035 V', specs: 'DMG MORI — 3 Eksen Isleme Merkezi (2. unite)' },
      { name: 'DMC 835 V', specs: 'DMG MORI — 3 Eksen Isleme Merkezi' },
    ],
  },
  {
    category: 'Tel Erozyon Tezgahlari',
    machines: [
      { name: 'CUT 30P', specs: 'GF Machining — Tel Erozyon (1. unite)' },
      { name: 'CUT 30P', specs: 'GF Machining — Tel Erozyon (2. unite)' },
      { name: 'CUT 20P', specs: 'GF Machining — Tel Erozyon' },
    ],
  },
  {
    category: 'Torna & Erozyon',
    machines: [
      { name: 'CNC Torna', specs: 'CNC Torna Tezgahi' },
      { name: 'Dalma Erozyon', specs: 'Dalma Erozyon Tezgahi' },
    ],
  },
  {
    category: 'Taslama & Bileme',
    machines: [
      { name: 'Yuzey Taslama', specs: 'Yuzey Taslama Makinasi' },
      { name: 'Silindirik & Delik Taslama', specs: 'Silindirik ve Delik Taslama Makinasi' },
      { name: 'Takim Bileme', specs: 'Takim Bileme Tezgahi' },
    ],
  },
  {
    category: 'Konvansiyonel Tezgahlar',
    machines: [
      { name: 'Universal Freze', specs: 'Universal Freze Tezgahi' },
      { name: 'Universal Torna', specs: 'Universal Torna Tezgahi' },
    ],
  },
  {
    category: 'Plastik Enjeksiyon & Markalama',
    machines: [
      { name: 'LS LST 280', specs: 'LS — Plastik Enjeksiyon Makinasi' },
      { name: 'Laser Markalama', specs: 'Laser Markalama Sistemi' },
    ],
  },
];
---

<BaseLayout title="Makina Parkimiz — MKT Makina Kalip Takim" description="MKT Makina makina parki: DMG MORI 5 eksen CNC, HAAS isleme merkezleri, GF Machining tel erozyon, plastik enjeksiyon ve daha fazlasi." lang="tr" hasHero={false}>
  <PageHero title="Makina Parkimiz" subtitle="Ileri teknoloji uretim altyapimiz" image="/images/slide3.jpg" />

  <section class="section-padding">
    <div class="container-custom">
      <!-- Summary Stats -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-[1px] bg-border mb-14" data-animate="fade-up">
        {[
          { value: '4', label: '5 Eksen CNC' },
          { value: '3', label: '3 Eksen CNC' },
          { value: '3', label: 'Tel Erozyon' },
          { value: '20+', label: 'Toplam Tezgah' },
        ].map((stat) => (
          <div class="text-center p-5 bg-primary-dark">
            <div class="font-heading text-2xl sm:text-3xl font-bold text-accent">{stat.value}</div>
            <div class="text-white/60 text-xs mt-1 uppercase tracking-wider">{stat.label}</div>
          </div>
        ))}
      </div>

      <!-- Machine Groups -->
      <div class="space-y-10">
        {machineGroups.map((group) => (
          <div data-animate="fade-up">
            <div class="flex items-center gap-3 mb-5">
              <div class="accent-bar"></div>
              <h2 class="font-heading text-lg font-bold text-white tracking-wide">{group.category}</h2>
            </div>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-[1px] bg-border">
              {group.machines.map((machine) => (
                <div class="p-5 bg-primary-light hover:bg-primary-light transition-colors">
                  <h3 class="font-heading text-sm font-semibold text-white mb-1 tracking-wide">{machine.name}</h3>
                  <p class="text-text-light text-xs">{machine.specs}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA lang="tr" />
</BaseLayout>
