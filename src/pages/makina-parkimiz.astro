---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTA from '../components/CTA.astro';

const machineGroups = [
  {
    category: '5 Eksen CNC İşleme Merkezleri',
    machines: [
      { name: 'DMU 85', specs: 'DMG MORI — 5 Eksen Simültane İşleme' },
      { name: 'DMU 75', specs: 'DMG MORI — 5 Eksen Simültane İşleme' },
      { name: 'HAAS UMC VF3', specs: '5 Eksen CNC İşleme Merkezi' },
      { name: 'HAAS UMC 750', specs: '5 Eksen CNC İşleme Merkezi' },
    ],
  },
  {
    category: '3 Eksen CNC İşleme Merkezleri',
    machines: [
      { name: 'DMC 1035 V', specs: 'DMG MORI — 3 Eksen İşleme Merkezi' },
      { name: 'DMC 1035 V', specs: 'DMG MORI — 3 Eksen İşleme Merkezi (2. ünite)' },
      { name: 'DMC 835 V', specs: 'DMG MORI — 3 Eksen İşleme Merkezi' },
    ],
  },
  {
    category: 'Yatay CNC İşleme Merkezleri',
    machines: [
      { name: 'NHC 5000 (1)', specs: 'Yatay CNC İşleme Merkezi' },
      { name: 'NHC 5000 (2)', specs: 'Yatay CNC İşleme Merkezi' },
      { name: 'NHC 5000 (3)', specs: 'Yatay CNC İşleme Merkezi' },
    ],
  },
  {
    category: 'Tel Erozyon Tezgâhları',
    machines: [
      { name: 'CUT 30P', specs: 'GF Machining — Tel Erozyon (1. ünite)' },
      { name: 'CUT 30P', specs: 'GF Machining — Tel Erozyon (2. ünite)' },
      { name: 'CUT 20P', specs: 'GF Machining — Tel Erozyon' },
    ],
  },
  {
    category: 'Torna & Erozyon',
    machines: [
      { name: 'CNC Torna', specs: 'CNC Torna Tezgâhı' },
      { name: 'Dalma Erozyon', specs: 'Dalma Erozyon Tezgâhı' },
    ],
  },
  {
    category: 'Taşlama & Bileme',
    machines: [
      { name: 'Yüzey Taşlama', specs: 'Yüzey Taşlama Makinası' },
      { name: 'Silindirik & Delik Taşlama', specs: 'Silindirik ve Delik Taşlama Makinası' },
      { name: 'Takım Bileme', specs: 'Takım Bileme Tezgâhı' },
    ],
  },
  {
    category: 'Konvansiyonel Tezgâhlar',
    machines: [
      { name: 'Üniversal Freze', specs: 'Üniversal Freze Tezgâhı' },
      { name: 'Üniversal Torna', specs: 'Üniversal Torna Tezgâhı' },
    ],
  },
  {
    category: 'Lazer Markalama',
    machines: [
      { name: 'Lazer Markalama', specs: 'Lazer Markalama Sistemi' },
    ],
  },
  {
    category: 'Plastik Enjeksiyon',
    machines: [
      { name: 'LS LST 280', specs: 'LS — Plastik Enjeksiyon Makinası' },
    ],
  },
];
---

<BaseLayout title="Makina Parkuru — MKT Makina A.Ş." description="MKT Makina Parkuru: DMG MORI 5 eksen CNC, yatay CNC işleme merkezleri (NHC 5000 ×3), HAAS, GF Machining tel erozyon ve plastik enjeksiyon." lang="tr" hasHero={false}>
  <PageHero title="Makina Parkuru" subtitle="İleri teknoloji üretim altyapımız" image="/images/slide3.jpg" />

  <section class="section-padding">
    <div class="container-custom">
      <!-- Summary Stats -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-[1px] bg-border mb-14" data-animate="fade-up">
        {[
          { value: '4', label: '5 Eksen CNC' },
          { value: '3', label: '3 Eksen CNC' },
          { value: '3', label: 'Yatay CNC (NHC 5000)' },
          { value: '20+', label: 'Toplam Tezgâh' },
        ].map((stat) => (
          <div class="text-center p-5 bg-primary-dark">
            <div class="font-heading text-2xl sm:text-3xl font-bold text-accent">{stat.value}</div>
            <div class="text-white/60 text-xs mt-1 uppercase tracking-wider">{stat.label}</div>
          </div>
        ))}
      </div>

      <!-- Machine Groups -->
      <div class="space-y-10">
        {machineGroups.map((group) => (
          <div data-animate="fade-up">
            <div class="flex items-center gap-3 mb-5">
              <div class="accent-bar"></div>
              <h2 class="font-heading text-lg font-bold text-white tracking-wide">{group.category}</h2>
            </div>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-[1px] bg-border">
              {group.machines.map((machine) => (
                <div class="p-5 bg-primary-light hover:bg-primary-light transition-colors">
                  <h3 class="font-heading text-sm font-semibold text-white mb-1 tracking-wide">{machine.name}</h3>
                  <p class="text-text-light text-xs">{machine.specs}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA lang="tr" />
</BaseLayout>
