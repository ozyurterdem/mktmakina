---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — Sayfa Bulunamadı | Page Not Found — MKT Makina"
  description="Aradığınız sayfa bulunamadı. The page you are looking for could not be found."
  lang="tr"
  hasHero={false}
>
  <section class="section-padding">
    <div class="container-custom">
      <div class="max-w-2xl mx-auto text-center py-16">
        <p class="section-label text-accent mb-4">Error 404</p>
        <h1 class="font-heading text-6xl sm:text-7xl font-bold text-white mb-6">404</h1>
        <div class="accent-bar mx-auto mb-8"></div>

        <h2 class="font-heading text-2xl sm:text-3xl font-semibold text-white mb-3">
          Sayfa Bulunamadı
        </h2>
        <p class="text-text-light text-base mb-2">
          Aradığınız sayfa taşınmış, silinmiş veya hiç var olmamış olabilir.
        </p>

        <h2 class="font-heading text-xl sm:text-2xl font-semibold text-white/80 mt-10 mb-3">
          Page Not Found
        </h2>
        <p class="text-text-light text-base mb-10">
          The page you are looking for may have been moved, deleted, or never existed.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/" class="btn-primary">
            Anasayfaya Dön
          </a>
          <a href="/en" class="btn-primary">
            Back to Home
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
